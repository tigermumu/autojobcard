            "mimeType": "application/javascript",
            "text": "\r\n//检验工卡是否已打印\r\nfunction checkJcPrinted(workOrder)\r\n{\r\n\tvar flag = false;\r\n\tvar url = BASE_URL + \"/fgm/workOrder/ajax/checkJcPrinted.jsp?workOrder=\"+workOrder+\"&jobcard=\"+jobcard+\"&jsonpcallback=?\";\r\n\t\r\n\t$.ajax({\r\n\t\ttype: \"POST\",\t\t\t\t\t// 请求方式\r\n\t\turl: url,\t\t\t\t\t\t// 请求地址\r\n\t\tjsonp: \"jsonpcallback\",\t\t\t// 回调函数名字\r\n\t\tasync: false,\t\t\t\t\t// 设置是否需要异步\r\n\t\tdataType: \"jsonp\",\t\t\t\t// 返回的数据格式\r\n\t\tsuccess: function(data)\t\t\t// 成功返回时，所调用的回调函数\t\r\n\t\t{\r\n\t\t\tif(data!=\"\")\r\n\t\t\t{\r\n\t\t\t\tflag = data.flag;\r\n\t\t\t}\r\n\t\t}\r\n\t});\r\n\t\r\n\treturn flag;\r\n}\r\n\r\n//打印信息\r\nfunction alterNRCPRT(workOrder)\r\n{\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn;\r\n\t}\r\n\t\r\n\tvar url = BASE_URL + \"/fgm/workOrder/jobcard/alterNRCPRT.jsp?workorder=\"+workOrder+\"&jobcard=\"+jobcard+\"&jcSeq=\"+jcSeq+\"&jcType=\"+jcType;\r\n\t//var value = window.showModalDialog(url,\"\",\"dialogWidth:850px;dialogHeight:600px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tvar value = __CP_FUNC_open__(window,url,\"\",\"width=850px,height=600px,toolbar=no,menubar=no,scrollbars=yes,resizable=yes,status=no\");\r\n}\r\n\r\n//打印历史\r\nfunction alterNRCPRTLog(workOrder)\r\n{\r\n\tvar url = BASE_URL + \"/fgm/workOrder/jobcard/alterNRCPRTLog.jsp?workorder=\"+workOrder+\"&jobcard=\"+jobcard+\"&jcSeq=\"+jcSeq+\"&jcType=\"+jcType;\r\n\t//var value = window.showModalDialog(url,\"\",\"dialogWidth:850px;dialogHeight:400px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tvar value = __CP_FUNC_open__(window,url,\"nrcprtLog\",\"width=1200px,height=540px,toolbar=no,menubar=no,scrollbars=yes,resizable=yes,status=no,top=\"\r\n\t\t\t+ (screen.availWidth-1400)/2 + \",left=\" + (screen.availHeight-460)/2);\r\n}\r\n\r\n//移交信息\r\nfunction transferNRCPRT(workOrder)\r\n{\r\n\tvar url = BASE_URL + \"/fgm/workOrder/jobcard/alterNRCTransferHistory.jsp?jcrid=\"+jcRid+\"&jcseq=\"+jcSeq\r\n\t\t+\"&workOrder=\"+workOrder+\"&jobCard=\"+jobcard+\"&jcType=\"+jcType;\r\n\t//var value = window.showModalDialog(url,\"\",\"dialogWidth:820px;dialogHeight:400px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tvar value = __CP_FUNC_open__(window,url,\"\",\"width=820px,height=400px,toolbar=no,menubar=no,scrollbars=yes,resizable=yes,status=no\");\r\n}\r\n\r\n//对网址传递的特殊符号参数进行编码\r\nfunction getEncodeURI(content) {\r\n\tcontent = content.replace(/\\+/g, \"%2B\");\r\n\tcontent = content.replace(/\\ /g, \"%20\");\r\n\tcontent = content.replace(/\\//g, \"%2F\");\r\n\tcontent = content.replace(/\\?/g, \"%3F\");\r\n\tcontent = content.replace(/\\%/g, \"%25\");\r\n\tcontent = content.replace(/\\#/g, \"%23\");\r\n\tcontent = content.replace(/\\&/g, \"%26\");\r\n\tcontent = content.replace(/\\=/g, \"%3D\");\r\n\r\n\treturn content;\r\n}\r\nfunction changeRep() {\r\n\tvar im = $(\"#strRepair\").val();\r\n\tvar fcs=$(\"#fcs\");\r\n\tvar causeStrr=$(\"#causeStrr\");\r\n\tvar rplStrPart=$(\"#rplStrPart\");\r\n\tvar pse=$(\"#pse\");\r\n\t\r\n\tif (im == 'N') {\r\n\t\tfcs.empty();\r\n\t\tfcs.append(\"<option value='A'>NA</option>\");\r\n\t\t\r\n\t\tcauseStrr.empty();\r\n\t\tcauseStrr.append(\"<option value='A'>NA</option>\");\r\n\t\t\r\n\t\t/* rplStrPart.empty();\r\n\t\trplStrPart.append(\"<option value='N'>N</option>\"); */\r\n\t\t\r\n\t\tpse.empty();\r\n\t\tpse.append(\"<option value='N'>N</option>\");\r\n\t}else if(im=='Y'){\r\n\t\tfcs.empty();\r\n\t\tfcs.append(\"<option value=''></option>\");\r\n\t\tfcs.append(\"<option value='Y'>Y</option>\");\r\n\t\tfcs.append(\"<option value='N'>N</option>\");\r\n\t\t\r\n\t\tcauseStrr.empty();\r\n\t\tcauseStrr.append(\"<option value=''></option>\");\r\n\t\tcauseStrr.append(\"<option value='损伤'>损伤</option>\");\r\n\t\tcauseStrr.append(\"<option value='改装'>改装</option>\");\r\n\t\t\r\n\t\trplStrPart.empty();\r\n\t\trplStrPart.append(\"<option value=''></option>\");\r\n\t\trplStrPart.append(\"<option value='Y'>Y</option>\");\r\n\t\trplStrPart.append(\"<option value='N'>N</option>\");\r\n\t\t\r\n\t\tpse.empty();\r\n\t\tpse.append(\"<option value=''></option>\");\r\n\t\tpse.append(\"<option value='Y'>Y</option>\");\r\n\t\tpse.append(\"<option value='N'>N</option>\");\r\n\t}\r\n}\r\n//登记Fedex的解决措施\r\nfunction registFedexRecAction()\r\n{\r\n\tvar pass = true;\r\n\tvar fedexRecActionObj = $(\"#fedexRecActionId\");\t// Fedex工卡推荐措施\r\n\tvar fedexJpfObj = $(\"#fedexJpfId\");\t\t\t\t// 是否有JPF\r\n\tvar stepArray = $(\".stepTdClass\");\t\t\t\t// 步骤对象集合\r\n\t\r\n\tif(\"FEDEX\"!=ownerCode)\r\n\t\treturn pass;\r\n\t\r\n\tif($.trim(fedexRecActionObj.val())==\"\")\r\n\t{\r\n\t\talert(\"请填写推荐措施!\");\r\n\t\tfedexRecActionObj.select();\r\n\t\treturn false;\r\n\t}\r\n\tif(fedexJpfObj.val()==\"\")\r\n\t{\r\n\t\talert(\"Fedex JPF选项不能为空!\");\r\n\t\tfedexJpfObj.focus();\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\t// 没有JPF\r\n\tif(fedexJpfObj.val()==\"N\")\r\n\t{\r\n\t\tif(stepArray.length==0)\r\n\t\t{\r\n\t\t\talert(\"缺少步骤!\");\r\n\t\t\tpass = false;\r\n\t\t}\r\n\t\telse if(stepArray.length==1)\r\n\t\t{\r\n\t\t\t//alert($.trim(fedexRecActionObj.val()).toUpperCase());alert($.trim($(\".stepEnDescClass\").eq(0).val()).toUpperCase());\r\n\t\t\tif($.trim(fedexRecActionObj.val()).toUpperCase()!=$.trim($(\".stepEnDescClass\").eq(0).val()).toUpperCase())\r\n\t\t\t{\r\n\t\t\t\tif(confirm(\"推荐措施与步骤一的描述不一致，确认更改为一致?\"))\r\n\t\t\t\t{\r\n\t\t\t\t\t//$(\".stepEnDescClass\").eq(0).attr(\"value\",fedexRecActionObj.val());\r\n\t\t\t\t\t//$(\".stepEnDescClass\").eq(0).select();\r\n\t\t\t\t\t//changeJCStp($(\".stepEnDescClass\").eq(0).parent().parent().parent().parent());\r\n\t\t\t\t\teditFedexRecAction();\r\n\t\t\t\t\tfedexRecActionObj.attr(\"value\",$(\".stepEnDescClass\").eq(0).val());\r\n\t\t\t\t\tfedexRecActionObj.select();\r\n\t\t\t\t\tpass = false;\r\n\t\t\t\t}\r\n\t\t\t\telse\r\n\t\t\t\t{\r\n\t\t\t\t\tpass = false;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t\telse if(stepArray.length>1)\r\n\t\t{\r\n\t\t\talert(\"没有JPF 只允许有一个步骤!\");\r\n\t\t\tpass = false;\r\n\t\t}\r\n\t}\r\n\t\r\n\treturn pass;\r\n}\r\n// 删除计划已设置的当前步骤\r\nfunction delWophsStp(stepRid)\r\n{\r\n\tvar url = BASE_URL + \"/fgm/workOrder/ajax/delWophsStp.jsp?stepRid=\"+stepRid;\r\n\t\r\n\tjQuery.ajax({\r\n\t  type: \"post\",\r\n\t  async: true,//控制同步=false 异步=true\r\n\t  url: url,\r\n\t  contentType: \"application/json; charset=gbk\",\r\n\t  dataType: \"json\",\r\n\t  cache: false,\r\n\t  success: function (data) {\r\n\t  \tif(data.flag==\"true\")\r\n\t  \t{\r\n\t  \t\talert(\"删除成功\");\r\n\t  \t}\r\n\t  },\r\n\t  error: function (err) {\r\n\t\talert(err);\r\n\t  }\r\n\t});\r\n}\r\n// 夺取操作权组\r\nfunction seizeTechPrcGrp(obj, stepRid, qc1st, qc2nd)\r\n{\r\n\t//alert(\"夺取操作权组!\"+stepRid+$(obj));\r\n\t//var action = \"seizeTechPrcGrp\";\r\n\tvar delTd = getObj($(obj).parent().parent(),\"delTdClass\",\"countermarch\");\r\n\tvar stepVidObj = delTd.children(\".vidClass\");\t// 步骤版本\r\n\t//alert(stepVidObj.val());\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn false;\r\n\t}\r\n\t//检查方案是否被锁定\r\n\tvar checkIsLockResult = getRequest(BASE_URL + \"/fgm/fgm.do?method=checkIsLockStep\", \"{\\\"stepRid\\\": \" + stepRid + \"}\");\r\n\tif(false == checkIsLockResult){\r\n\t\treturn;\r\n\t}\r\n\tif(checkIsLockResult.flag){\r\n\t\talert(\"超规范锁定的步骤不允许夺权！\");\r\n\t\treturn;\r\n\t}\r\n\t/*if('Y' == qc1st || 'Y' == qc2nd){\r\n\t\talert('独立检验步骤只能由检验员编写！');\r\n\t\treturn false;\r\n\t}*/\r\n\tif (checkUsing(stepRid)){\r\n\t\treturn;\r\n\t}\r\n\tif(!confirm(\"确定夺取操作权组?\"))\r\n\t\treturn false;\r\n\r\n\tvar scrollTop = document.documentElement.scrollTop || document.body.scrollTop;\r\n\tvar scrollLeft = document.documentElement.scrollLeft || document.body.scrollLeft;\r\n\r\n\tvar url = BASE_URL + \"/fgm/workOrder/jobcard/seizeTechPrcGrp.jsp?stepRid=\"+stepRid+\"&stepVid=\"+stepVidObj.val()+\"&scrollTop=\"+scrollTop+\"&scrollLeft=\"+scrollLeft;\r\n\t__CP_SET_URL_ATT__(document.form,'action', url);\r\n\tdocument.form.submit();\r\n\t\r\n\t$(\":button\").attr(\"disabled\",\"disabled\");\r\n}\r\n// 弹出窗体\r\nfunction showWin(obj,title,winWidth)\r\n{\r\n\t$(obj).window\r\n\t({\r\n\t\twidth:winWidth,\t\t\t\t\t//窗口宽度\r\n\t\ttop:($(window).height()/2)*0.5,\t//高居中\r\n\t\tleft:($(window).width()/2)*0.5,\t//宽居中\r\n\t\tcollapsible:false,\t\t\t\t//不显示折叠按钮\r\n\t\tminimizable:false,\t\t\t\t//不显示最小化按钮\r\n\t\tmaximizable:false,\t\t\t\t//不显示最大化按钮\r\n\t\tresizable:true,\t\t\t\t\t//窗口可否调整尺寸\r\n\t\ttitle:title,\t\t\t\t\t//窗口标题\r\n\t\tmodal:true\t\t\t\t\t\t//模态窗口即背后页面不可操作\r\n\t});\r\n}\r\n\r\n// 跳转导入界面\r\nfunction changeMoel(model,op) {\r\n\t// 关闭提示框\r\n\t$('.uniq_win').window('close');\r\n\t\r\n\t// 模板导入\r\n\tif(op == \"1\") {\r\n\t\tif(model == \"more\") {\r\n\t\t\tjcInfo(op);//步骤批量导入\r\n\t\t}else if(model == \"single\"){\r\n\t\t\tstepInfo(eventObj,op);//单步骤导入\r\n\t\t}\r\n\t// 工作包工卡导入\r\n\t} else if(op == \"2\") {\r\n\t\tif(model == \"more\") {\r\n\t\t\tjcInfo(op);//步骤批量导入\r\n\t\t}else if(model == \"single\") {\r\n\t\t\tstepInfo(eventObj,op);//单步骤导入\r\n\t\t}\r\n\t}\r\n\t// 上次追踪号导入\r\n\telse if(op == \"3\") {\r\n\t\tif(model == \"more\") {\r\n\t\t\tjcInfo(op);//步骤批量导入\r\n\t\t}else if(model == \"single\") {\r\n\t\t\tstepInfo(eventObj,op);//单步骤导入\r\n\t\t}\r\n\t}\r\n}\r\n\r\n\r\nfunction showOpen(url, height, width){\r\n\t//获取屏幕的宽高\r\n\tvar top = (window.screen.height - 30 - height) / 2; //获取窗口的垂直位置\r\n\tvar left = (window.screen.width - 10 - width) / 2; //获取窗口的水平位置\r\n\tvar value = __CP_FUNC_open__(window,url, \"_blank\", 'height=' + height + ',width=' + width + ',top=' + top + ',left=' + left \r\n\t\t+ ',toolbar=no,menubar=no,scrollbars=aut,location=no,status=no,alwaysRaised=yes,directories=no,personalbar=no');\r\n\treturn value;\r\n}\r\n\r\n\r\n// 步骤签署要求的人员职能级别\r\nfunction changeMeAv(obj)\r\n{\r\n\tvar schedtradeObj = $(obj);\r\n\tvar meAvObj = getObj($(obj).parent().parent(),\"eSignTdClass\",\"countermarch\").find(\".meAvClass\");\r\n\t\r\n\t// 如果是电子或机电工种时默认为\"AT2\"职能级别\r\n\t//700824\r\n\tif(schedtradeObj.val().indexOf(\"AIRP\")>-1 || schedtradeObj.val().indexOf(\"AVIO\")>-1){\r\n\t\tmeAvObj.val(\"AT2\");\r\n\t\t//$(meAvObj).removeAttr(\"disabled\");\r\n\t}else{\r\n\t\tmeAvObj.val(\"\");\r\n\t\t//$(meAvObj).attr(\"disabled\",\"disabled\");\r\n\t}\r\n}\r\n\r\n//步骤批量处理\r\nfunction stpBatchDeal()\r\n{\r\n\t// QA写卡授权检查\r\n\tif(1 != checkQAAuth()){\r\n\t\treturn;\r\n\t}\r\n\tvar url = BASE_URL + \"/fgm/workOrder/jobcard/batchSubmitStp.jsp?wgp=\"+wgp+\"&jcrid=\"+jcRid+\"&woRid=\"+woRid+\"&printed=\"+printed+\"&addJC=\"+addJC+\"&ownerCode=\"+ownerCode;\r\n\tvar width = \"800px\";\r\n\tvar height = \"600px\";\r\n\t//window.showModalDialog(url,window,\"dialogTop:100px;dialogWidth:\"+ width + \";dialogHeight:\" + height + \";help:no;status:no;resizable:yes;toolbar:no;menubar:no;center:yes\");\r\n\t__CP_FUNC_open__(window,url,window,\"width=\"+width+\",height=\"+height+\",top=100px,toolbar=no,menubar=no,scrollbars=yes,resizable=yes,status=no\");\r\n}\r\n//刷新当前页面\r\nfunction reloadPage()\r\n{\r\n\tvar url = BASE_URL + \"/fgm/workOrder/jobcard/batchSubmitStpSuccess.jsp?wgp=\"+wgp+\"&jcrid=\"+jcRid+\"&woRid=\"+woRid+\"&printed=\"+printed+\"&addJC=\"+addJC+\"&ownerCode=\"+ownerCode;\r\n\t__CP_SET_URL_ATT__(document.form,'action', url);\r\n\tdocument.form.submit();\r\n}\r\n//子窗口返回，刷新页面为防止出现重试按钮，调用父窗口方法重新提交表单刷新页面，非reload()\r\nfunction goBack()\r\n{\r\n\t$(\":button\").attr(\"disabled\",\"disabled\");\r\n\tparent.refreshPage();\r\n}\r\n\r\n// add by 700683 增加并行签署步骤的功能 2018-09-04 start\r\n// 并行签署步骤\r\nfunction goPesignStep(jcrid) {\r\n\t// QA写卡授权检查\r\n\tif(\"\" != wgp && 1 != checkQAAuth()){\r\n\t\treturn;\r\n\t}\r\n\t__CP_SET_URL_ATT__(document.form,'action', BASE_URL + \"/fgm/fgmEsign.do?method=showStepPesignList&jcrid=\"+jcrid);\r\n\tdocument.form.submit();\r\n\t//JqueryDialog.Open1(\"并行签署步骤\",url,document.body.clientWidth-80,document.body.clientHeight-120);\r\n}\r\n// add by 700683 增加并行签署步骤的功能 2018-09-04 end\r\n\r\n// add by 700683 APS/MT信息 2019-05-23 start\r\nfunction goApsMt(jcrid) {\r\n\t__CP_SET_URL_ATT__(document.form,'action', BASE_URL + \"/fgm/fgmApsMt.do?method=showJcApsMt&jcrid=\"+jcrid);\r\n\tdocument.form.submit();\r\n}\r\n// add by 700683 APS/MT信息 2019-05-23 end\r\n\r\n\r\n// add by 700824 维修影像 2021-06-02 start\r\nfunction goHmTmpl(jcrid) {\r\n\t__CP_SET_URL_ATT__(document.form,'action', BASE_URL + \"/fgm/fgmApsMt.do?method=showHmTmpl&jcrid=\"+jcrid);\r\n\tdocument.form.submit();\r\n}\r\n// add by 700824 维修影像 2021-06-02 end\r\n\r\n//方案锁定\r\nfunction schemeLock(){\r\n\tvar jcRid = $(\"#primaryJCId\").val();\r\n\tvar jcVid = $(\"input[name='jcVid']\").val();\r\n\tvar url = BASE_URL + \"/fgm/fgm.do?method=checkJCIsStandard\";\r\n\tvar data = '{\"jcRid\":\"' + jcRid + '\", \"jcVid\":\"' + jcVid + '\", \"txtMenuID\":\"' + $(\"#txtMenuID\").val() + '\"}';\r\n\tvar result = getRequest(url, data);\r\n\tif(false == result){\r\n\t\treturn;\r\n\t}\r\n\tif(!result.flag){\r\n\t\talert(\"不是超规范非卡！\");\r\n\t\treturn;\r\n\t}\r\n\tvar url = BASE_URL + \"/fgm/fgm.do?method=schemeLockList&jcRid=\" + $(\"input[name='primaryJC']\").val()\r\n\t\t\t+ \"&wgp=\"+$(\"#wgpId\").val() + \"&woRid=\" + $(\"#woRidId\").val() + \"&txtMenuID=\" + $(\"#txtMenuID\").val();\r\n\t__CP_SET_URL_ATT__(__CP_GET_LOCATION__(window,window.location),'href', url);\r\n}\r\n\r\n//ajax get请求\r\nfunction getRequest(url, data){\r\n\tvar result;\r\n\t$.ajax({\r\n\t\turl: url,\r\n\t\ttype: 'get',\r\n\t\tasync: false,\r\n\t\tdata: eval(__CP_FUNC_EVAL__(self,\"(\" + data + \")\")),\r\n\t\tdataType: 'json',\r\n\t\tcache: false,\r\n\t\tsuccess: function(data) {\r\n\t\t\tresult = data;\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常, 发送请求失败!\");\r\n\t\t\tresult = false;\r\n\t\t}\r\n\t});\r\n\treturn result;\r\n}\r\n\r\n//检查是否跳到下一个\r\nfunction checkSkipNextSlnAtaNo(event){\r\n\tvar code = event.keyCode;// 键码\r\n\tvar ipt = event.target; //当前input标签\r\n\tvar obj = $(ipt);// 当前input对象\r\n\tvar objId = obj.attr(\"id\");//当前input对象id\r\n\tvar val = $.trim(obj.val());//当前input值\r\n\tvar len = val.length;//当前input值长度\r\n\tvar shiftKey = event.shiftKey;//shift是否被按下\r\n\tvar preVal;// 前一个值\r\n\tvar nextVal;// 下一个值\r\n\tvar cursorStart = ipt.selectionStart;//当前input里光标的起始位置\r\n\tif(\"keyup\" == event.type){ // 弹起按键\r\n\t\tif((47<code && code<58) || (95<code && code<106)){\t\r\n\t\t\t//数字: 48-57||96-105\r\n\t\t\tif(1<len && (\"slnAtaNo1\"==objId || \"slnAtaNo2\"==objId)){\r\n\t\t\t\tnextVal = obj.next().val();\r\n\t\t\t\tobj.next().val(\"\").focus().val(nextVal);//使得光标移到到后面\r\n\t\t\t}\r\n\t\t}else if(8==code){\r\n\t\t\t// 退格键\r\n\t\t\tif(0==len && shiftKey && (\"slnAtaNo2\"==objId || \"slnAtaNo3\"==objId)){\r\n\t\t\t\tpreVal = obj.prev().val();\r\n\t\t\t\tobj.prev().val(\"\").focus().val(preVal);//使得光标移到到后面\r\n\t\t\t}\r\n\t\t}else if(13==code){\r\n\t\t\t// 回车\r\n\t\t\tif(\"slnAtaNo1\"==objId || \"slnAtaNo2\"==objId){\r\n\t\t\t\tnextVal = obj.next().val();\t\t\t\r\n\t\t\t\tobj.next().val(\"\").focus().val(nextVal);//使得光标移到到后面\r\n\t\t\t}else{\r\n\t\t\t\tobj.blur();\r\n\t\t\t}\r\n\t\t}else if(32==code){\r\n\t\t\t// 空格\r\n\t\t}\r\n\t}else if(\"keydown\" == event.type){ //按下按键\r\n\t\tif(39==code){\r\n\t\t\t// 右方向键 -->\r\n\t\t\tif(len == cursorStart){//光标在最右边\r\n\t\t\t\tif(\"slnAtaNo1\"==objId || \"slnAtaNo2\"==objId){\r\n\t\t\t\t\tnextVal = obj.next().val();\r\n\t\t\t\t\tobj.next().val(\"\").focus().val(nextVal);//使得光标移到到后面\r\n\t\t\t\t}else{\r\n\t\t\t\t\tobj.blur();\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}else if(37==code){\r\n\t\t\t// 左方向键 <--\r\n\t\t\tif(0 == cursorStart){//光标在最左边\r\n\t\t\t\tif(\"slnAtaNo2\"==objId || \"slnAtaNo3\"==objId){\r\n\t\t\t\t\tpreVal = obj.prev().val();\r\n\t\t\t\t\t//obj.prev().val(\"\");\r\n\t\t\t\t\tobj.prev().focus();\r\n\t\t\t\t\t//obj.prev().val(preVal);\r\n\t\t\t\t\tobj.prev().get(0).setSelectionRange(0,preVal.length);\r\n\t\t\t\t\tevent.preventDefault();\r\n\t\t\t\t}else{\r\n\t\t\t\t\tobj.blur();\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\nfunction initSlnAtaNo(obj){\r\n\tvar slnAtaNoArr = $(obj).parent().find(\"input[type='text'][id^='slnAtaNo']\");\r\n\tvar slnAtaNo = \"\";\r\n\t$.each(slnAtaNoArr, function(i, n){\r\n\t\tslnAtaNo += $.trim($(n).val());\r\n\t});\r\n\t$(\"#slnAtaNo\").val(slnAtaNo);\r\n\tchangeJobCard();\r\n}\r\nfunction setSlnAtaNoVal(obj){\r\n\r\n\tvar referenceDesc = $.trim($(obj).val()); // 依据文件\t\r\n\tif(\"\" == referenceDesc){\r\n\t\treturn;\r\n\t}\r\n\tif(getStrLength(obj,45,\"依据文件\")){\r\n\t\treturn;\r\n\t}\r\n\tvar slnAtaNo = $(\"#slnAtaNo\"); //参考文件ATA号\r\n\tif(\"\" != slnAtaNo.val()){ //ata号不为空\r\n\t\treturn;\r\n\t}\r\n\tvar pattern = /[0-9xX]{2}-[0-9xX]{2}-[0-9xX]{2}/;\r\n\tif(!pattern.test(referenceDesc)){\r\n\t\treturn;\r\n\t}\r\n\tvar ataValArr = referenceDesc.match(pattern)[0].replace(/[xX]/g,\"0\").split(\"-\");\r\n\tvar slnAtaNoArr = $(\"input[type='text'][id^='slnAtaNo']\");\r\n\tif(ataValArr.length != slnAtaNoArr.length){\r\n\t\treturn;\r\n\t}\r\n\t$.each(slnAtaNoArr, function(i, n){\r\n\t\t$(n).val(ataValArr[i]);\r\n\t\tslnAtaNo.val(slnAtaNo.val() + ataValArr[i]);\r\n\t});\r\n\tchangeJobCard();\r\n}\r\nfunction showhideHciTr(){\r\n\tif(\"Y\" == $(\"#flagHci\").val()){\r\n\t\t$(\".hciTr\").show();\r\n\t}else{\r\n\t\t$(\".hciTr\").hide();\r\n\t}\r\n}\r\n//打印状态\r\nfunction getNrcHdPrtStatus(){\r\n\tvar nrcHdPrt;\r\n\tvar flagPrt;\r\n\tvar result = 0;\r\n\t$.ajax({\r\n\t\turl: BASE_URL + '/fgm/fgm.do?method=getNrcHdPrtStatus',\r\n\t\ttype: 'get',\r\n\t\tasync: false,\r\n\t\tdata: {\"jcRid\":$(\"#primaryJCId\").val(),\"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\tdataType: 'json',\r\n\t\t//contentType: 'application/x-www-form-urlencoded;charset=utf-8',\r\n\t\tsuccess: function(data) {\r\n\t\t\tnrcHdPrt = data.nrcHdPrt;\r\n\t\t\tflagPrt = data.flagPrt;\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常, 获取打印状态失败!\");\r\n\t\t\tresult = -1;\r\n\t\t\treturn;\r\n\t\t}\r\n\t});\r\n\tif(\"N\"==nrcHdPrt && \"1\"==flagPrt){\r\n\t\treturn 1;\r\n\t}\r\n\treturn result;\r\n}\r\n\r\n// QA授权校验\r\nfunction checkQAAuth(){\r\n\tvar result;\r\n\t$.ajax({\r\n\t\turl: BASE_URL + '/fgm/fgm.do?method=checkQAAuth',\r\n\t\ttype: 'get',\r\n\t\tasync: false,\r\n\t\tdata: {\"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\tdataType: 'json',\r\n\t\tcache:false,\r\n\t\tsuccess: function(data) {\r\n\t\t\tif(data.flag){\r\n\t\t\t\tresult = 1;\r\n\t\t\t}else{\r\n\t\t\t\tresult = 0;\r\n\t\t\t\talert(\"[\"+data.user+\"]不在QA写卡授权中\");\r\n\t\t\t}\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常, 获取QA授权状态失败!\");\r\n\t\t\tresult = -1;\r\n\t\t\treturn;\r\n\t\t}\r\n\t});\r\n\treturn result;\r\n}\r\n\r\n// 检查步骤是否入卡\r\nfunction isStepIn(stepNum, stepRid){\r\n\tvar result;\r\n\t$.ajax({\r\n\t\turl: BASE_URL + '/fgm/fgm.do?method=isStepIn',\r\n\t\ttype: 'get',\r\n\t\tasync: false,\r\n\t\tdata: {\"stepRid\":stepRid, \"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\tdataType: 'json',\r\n\t\tcache:false,\r\n\t\tsuccess: function(data) {\r\n\t\t\tif(data.flag){\r\n\t\t\t\tresult = 1;\r\n\t\t\t}else{\r\n\t\t\t\tresult = 0;\r\n\t\t\t\tvar workers = \"\";\r\n\t\t\t\t$.each(data.stepInList, function(i, n){\r\n\t\t\t\t\tif(i != 0){\r\n\t\t\t\t\t\tworkers += \", \";\r\n\t\t\t\t\t}\r\n\t\t\t\t\tworkers += (n.codename + \" \" + n.mechanic);\r\n\t\t\t\t});\r\n\t\t\t\talert(\"所要删除的步骤[\"+stepNum+\"]有工作者[\"+ workers +\"]正在入卡工作，请通知退卡后才能操作！\");\r\n\t\t\t}\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常, 检查步骤入卡状态失败!\");\r\n\t\t\tresult = -1;\r\n\t\t\treturn;\r\n\t\t}\r\n\t});\r\n\treturn result;\r\n}\r\n\r\n// 检查员工是否正在入卡工作\r\nfunction checkUsing(stepRid){\r\n\tvar result = true;\r\n\tvar url = BASE_URL + \"/fgm/fgm.do?method=checkUsing\";\r\n\t$.ajax({\r\n\t\turl: url,\r\n\t\ttype: 'get',\r\n\t\tasync: false,\r\n\t\tdata: {\"stepRid\":stepRid},\r\n\t\tdataType: 'json',\r\n\t\tcache: false,\r\n\t\tsuccess: function(data) {\r\n\t\t\tif (data.flag){\r\n\t\t\t\talert(\"(\"+data.returnString+\")正在入卡工作，退卡后才可修订！\");\r\n\t\t\t}else {\r\n\t\t\t\tresult = false;\r\n\t\t\t}\r\n\t\t}\r\n\t});\r\n\treturn result;\r\n}\r\n\r\n\r\n\r\nfunction getReviewInfo(rid){\r\n\tvar result;\r\n\tvar err = false;\r\n\t$.ajax({\r\n\t\turl: BASE_URL + \"/fgm/fgm.do?method=getReviewInfo\",\r\n\t\ttype: 'get',\r\n\t\tasync: false,\r\n\t\tdata: {\"jcRid\": rid},\r\n\t\tdataType: 'json',\r\n\t\tcache: false,\r\n\t\tsuccess: function(data) {\r\n\t\t\tif (data.flag){\r\n\t\t\t\tresult = __CP_GET_URL_ATT__(data,'data');\r\n\t\t\t}else {\r\n\t\t\t\talert(\"系统异常, 方案审核信息获取失败!\");\r\n\t\t\t\terr = true;\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常, 方案审核信息请求失败!\");\r\n\t\t\terr = true;\r\n\t\t\treturn false;\r\n\t\t}\r\n\t});\r\n\treturn {\r\n\t\t'err': err,\r\n\t\t'data': result\r\n\t}\r\n}\r\n\r\n// 方案审核人\r\nfunction schemeReviewer(insertSISUser){\r\n\tvar jcRid = $(\"#primaryJCId\").val();\r\n\tvar result  = getReviewInfo(jcRid);\r\n\tif(result.err) return false;\r\n\tif( 1 != __CP_GET_URL_ATT__(result,'data').repType){\r\n\t\talert('该非卡不为MAJOR，不需复核！');\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tif(!confirm('确定审核该方案？')){\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tinsertSISUser = insertSISUser.substring(insertSISUser.indexOf(' ') + 1) + ' ' + insertSISUser.substring(0, insertSISUser.indexOf(' '));\r\n\t$.ajax({\r\n\t\turl: BASE_URL + \"/fgm/fgm.do?method=saveReviewInfo\",\r\n\t\ttype: 'post',\r\n\t\tasync: false,\r\n\t\tdata: {\"rid\": jcRid, \"slnReviewBy\": encodeURIComponent(insertSISUser), \"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\tdataType: 'json',\r\n\t\tcache: false,\r\n\t\tcontentType: 'application/x-www-form-urlencoded;charset=utf-8',\r\n\t\tsuccess: function(data) {\r\n\t\t\tif (data.flag && !data.msg){\r\n\t\t\t\talert(\"操作成功\");\r\n\t\t\t\thistory.go(0);\r\n\t\t\t} else if (data.msg){\r\n\t\t\t\talert(data.msg);\r\n\t\t\t\treturn false;\r\n\t\t\t} else {\r\n\t\t\t\talert(\"系统异常, 方案审核获取失败!\");\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常, 方案审核请求失败!\");\r\n\t\t\treturn false;\r\n\t\t}\r\n\t});\r\n}\r\n\r\n\r\n// 独立检验删除后续步骤\r\nfunction delIndInspAffterStep($tr){\r\n\tvar delTdArr = $tr.nextAll().find('.delTdClass');\r\n\tif(0 < delTdArr.length){\r\n\t\tvar td = delTdArr.eq(0);\r\n\t\tvar qc1st = td.find('.qc1st').val();\r\n\t\tvar qc2nd = td.find('.qc2nd').val();\r\n\t\tif('Y' == qc1st || 'Y' == qc2nd){// 独立检验步骤\r\n\t\t\tvar tr2 = td.parent();\r\n\t\t\tvar tr1 = tr2.prev();\r\n\t\t\tvar tr3 = tr2.next();\r\n\t\t\tif('Y' == qc1st){\r\n\t\t\t\tif(!confirm('删除独立检验步骤同时删除步骤判断添加的两个步骤。')){\r\n\t\t\t\t\treturn false;\r\n\t\t\t\t}\r\n\t\t\t\tdelIndInspAffterStep(tr2);\r\n\t\t\t}\r\n\t\t\t// 删除步骤\r\n\t\t\tremove(tr1, tr2, tr3);\r\n\t\t\t// 删除步骤后，重新设置步骤号\r\n\t\t\talterStep($.trim(tr1.find(\".stepTdClass\").text()), 'subtract');\r\n\t\t}\r\n\t}\r\n\treturn true;\r\n}\r\n\r\n// 添加步骤检查是否独立检验步骤与独立检验添加的步骤之间\r\nfunction checkindInspStep(step){\r\n\tvar hiddenStepInput = $(\"input[class='hiddenStepClass'][value='\" + step + \"']\");\r\n\tvar qc1st = hiddenStepInput.siblings('.qc1st').val();\r\n\tvar qc2nd = hiddenStepInput.siblings('.qc2nd').val();\r\n\tif('Y' == qc1st || 'Y' == qc2nd){\r\n\t\talert('添加步骤不能是独立检验步骤与独立检验添加的步骤之间。');\r\n\t\treturn false;\r\n\t}\r\n\treturn true;\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n"
          },
