_cvpn_prefix_portal+'/Login/images/__CP_FNB__add_off.png\\'\" style=\"cursor: pointer; cursor: hand;border-right: 0px; padding-right: 0px; border-top: 0px; padding-left: 0px;padding-bottom: 0px;margin: 0px;border-left: 0px;padding-top: 0px;border-bottom: 0px;\" />&nbsp;<img id=\"___fnbLogOutButton\" src=\"'+___cp_cvpn_prefix_portal+'/Login/images/__CP_FNB__arrow_off.png\" border=\"0\" width=\"21\" height=\"20\" title=\"Sign Out\" align=\"absmiddle\" onclick=\"___GoToLogOut();\" onMouseOver=\"this.src=\\''+___cp_cvpn_prefix_portal+'/Login/images/__CP_FNB__arrow_over.png\\'\" onMouseOut=\"this.src=\\''+___cp_cvpn_prefix_portal+'/Login/images/__CP_FNB__arrow_off.png\\'\" style=\"cursor:pointer;cursor:hand;border-right: 0px; padding-right: 0px; border-top: 0px; padding-left: 0px;padding-bottom: 0px;margin: 0px;border-left: 0px;padding-top: 0px;border-bottom: 0px;\" /></td></tr></table>';\n\nfunction ___FnbSSOCallback(userChoice, neverAskAgain) {}; \n\nvar ssoPopupContent = \"\";\n\nvar fnbContent = \"<table cellpadding='0' cellspacing='0' width='94px' height='28px' style='width: 100%; \"+___tableStyle+\"text-align:left;' border='0'><tr><td>\"+___fnbLeftMaxCode+\"</td></tr></tr></table>\";\n\nfunction ___FnbSsoSetPopupContent()\n{\n\t\n\tssoPopupContent = \"<table style='border: solid #D1E5FE 3px;' bgcolor='#FDFDFD'><tr><td style='padding: 3px; padding-top: 7px; font-family: sans-serif;'>\"+\n\t\t\t\t\t  \"<table cellpadding='0' cellspacing='0' border='0' style='color: #333333;'>\"+\n\t\t\t\t\t  \"<tr><td align='right'>\"+\n\t\t\t\t\t  \n\t\t\t\t\t  \"<img width='14' height='13' src='\"+___cp_cvpn_prefix_portal+\"/Login/images/__CP_FNB__cancel.gif' align='absmiddle' ondragstart='return false;' onclick='___FnbHideSSOContent()'\"+\n\t\t\t\t\t    \"style='cursor: pointer; cursor: hand;border-right: 0px; padding-right: 0px; border-top: 0px; padding-left: 0px;padding-bottom: 0px;margin: 0px;border-left: 0px;padding-top: 0px;border-bottom: 0px;' title='Close'>\"+\n\t\t\t\t\t  \"</td></tr>\"+\n\t\t\t\t\t  \"<tr><td style='font-size: 12px; padding-top: 7px;'><b style='font-size: 12px;'>\"+\n\t\t\t\t\t\t   \"<span id=\\\"\"+___fnbSSOUserName+\"\\\">&nbsp;</span>\"+\n\t\t\t\t\t  \"</b>, your credentials will be recorded for future access.</font></td></tr>\"+\n\t\t\t\t\t  \"<tr><td align='center'>\"+\n\t\t\t\t\t  \n\t\t\t\t\t  \"<div id=\\\"\"+___fnbSSOButtons+\"\\\" style='display: block; padding-top: 7px;'>\"+\n\t\t\t\t\t\t\"<input type='button' name='___fnbSsoForm_no' id='___fnbSsoForm_no' style='font-size: 12px;' value='&nbsp;&nbsp;Don&rsquo;t record&nbsp;&nbsp;' onclick='___FnbCallSSOCallback(false);'></td></tr>\"+\n\t\t\t\t\t  \"</div>\"+\n\t\t\t\t\t  \n\t\t\t\t\t  \"<tr><td align='center' style='font-size: 12px'>\"+\n\t\t\t\t\t  \"<div id=\\\"\"+___fnbSSOAsk+\"\\\" style='display: \"+(___fnbSSODisplayAsk ? \"block\" : \"none\")+\"; padding-top: 7px;'>\"+\n\t\t\t\t\t  \"<input name='___fnbSsoForm_ask' id='___fnbSsoForm_ask' type='checkbox' value='Never'><label for='___fnbSsoForm_ask'>Never ask for this application</label><br><br>\"+\n\t\t\t\t\t  \"</div>\"+\n\t\t\t\t\t  \"</td></tr>\"+\n\t\t\t\t\t  \n\t\t\t\t\t  \"<tr><td align='center' style='font-size: 12px'>\"+\n\t\t\t\t\t  \"<div id=\\\"\"+___fnbSSOAdminHintLink+\"\\\" onclick='___FnbShowSsoAdminHint();' style='display: block; padding-top: 7px;'><span style='color: #0000CC; text-decoration: underline; cursor: pointer;'>Help me choose credentials</span></div>\"+\t\t\t\t\t  \n\t\t\t\t\t  \"<div id=\\\"\"+___fnbSSOAdminHint+\"\\\" style='display: none; padding-top: 7px;'>&nbsp;</div>\"+\t\t\t\t\t  \n\t\t\t\t\t  \"</td></tr>\"+\n\t\t\t\t\t  \"</table>\"+\n\n\t\t\t\t\t  \"</td></tr></table>\";\n\t\n}\n\n\nfunction ___FnbHandleSSOContent()\n{\n\tif(___fnbSSONeedToShow == true)\n\t{\n\t\t___FnbShowSSOContentActual(\t___SSOuserName, ___SSOappName, ___SSOadminHint, ___SSOnotifyOnly, ___SSOcallBack);\n\t}\n\telse\n\t{\n\t\t___FnbHideSSOContent(false);\n\t}\n}\n\n\nfunction ___FnbShowSSOContent(userName, appName, adminHint, notifyOnly, callBack)\n{\n\tif(___fnbWasDrawn == true)\n\t{\n\t\t___FnbShowSSOContentActual(userName, appName, adminHint, notifyOnly, callBack);\n\t}\n\telse\n\t{\n\t\t___fnbSSONeedToShow = true;\n\t\t___SSOuserName \t\t= userName;\n\t\t___SSOappName \t\t= appName;\n\t\t___SSOadminHint \t= adminHint;\n\t\t___SSOnotifyOnly \t= notifyOnly;\n\t\t___SSOcallBack \t\t= callBack;\n\t}\n}\n\nfunction ___FnbShowSSOContentActual(userName, appName, adminHint, notifyOnly, callBack)\n{\n\tif (notifyOnly == true)\n\t{\n\t\tdocument.getElementById(___fnbSSOButtons).style.display = \"none\";\n\t}\n\telse\n\t{\n\t\tdocument.getElementById(___fnbSSOButtons).style.display = \"block\";\n\t}\n\t\n\tif (!___fnbDropDownState)\n\t{\n\t\t___ShowFNB();\n\t}\n\n\tif ( (callBack != undefined) && (callBack != null))\n\t{\n\t\t___FnbSSOCallback = callBack;\n\t}\n\t\n\tif ( (adminHint != undefined) &&(adminHint != null) && (adminHint.length > 0) ) \n\t{\n\t\tdocument.getElementById(___fnbSSOAdminHintLink).style.display \t= \"block\";\n\t}\n\telse\n\t{\n\t\tdocument.getElementById(___fnbSSOAdminHintLink).style.display \t= \"none\";\n\t}\n\t\n\tdocument.getElementById(___fnbSSOAdminHint).style.display \t= \"none\";\n\tdocument.getElementById(___fnbSSODivId).style.display \t= \"block\";\n\tdocument.getElementById(___fnbSSOUserName).innerHTML \t= userName;\n\t\n\tdocument.getElementById(___fnbSSOAdminHint).innerHTML \t= adminHint;\n\n\t___FnbSsoRolldown();\t\n}\n\n\nfunction ___FnbShowSsoAdminHint()\n{\n\tdocument.getElementById(___fnbSSOAdminHintLink).style.display \t= \"none\";\n\tdocument.getElementById(___fnbSSOAdminHint).style.display \t= \"block\";\n\t___FnbValidateSsoVerticalPosition();\n}\n\n\nfunction ___FnbSsoRolldown()\n{\n\tvar ssoDiv = document.getElementById(___fnbSSODivId);\n\tvar top = ssoDiv.style.top;\n\t\n\tif (parseInt(top) < -20)\n\t{\n\t\tssoDiv.style.top = parseInt(top) + 10;\n\t\t___FnbValidateSsoVerticalPosition();\n\t\tsetTimeout('___FnbSsoRolldown()', ___fntSSOScrollSpeed);\n\t}\n\telse\n\t{\n\t\tssoDiv.style.top = -20;\n\t\t___fnbSSOEffectiveHeight = ___fnbSSOHeight - 20;\n\t\t___FnbValidateSsoVerticalPosition();\n\t}\n}\n\n\nfunction ___FnbSsoRollup()\n{\n\tvar ssoDiv = document.getElementById(___fnbSSODivId);\n\tvar top = ssoDiv.style.top;\n\t\n\tif (parseInt(top) > (-1 * ___fnbSSOHeight))\n\t{\n\t\tssoDiv.style.top = parseInt(top) - 10;\n\t\tsetTimeout('___FnbSsoRollup()', ___fntSSOScrollSpeed);\n\t}\n\telse\n\t{\n\t\tssoDiv.style.top = (-1 * ___fnbSSOHeight);\n\t\tdocument.getElementById(___fnbSSODivId).style.display = \"none\";\n\t\t___fnbSSOEffectiveHeight = 0;\n\t}\n}\n\n\nfunction ___FnbHideSSOContent(doRollup)\n{\n\tif (doRollup===false)\n\t{\n\t\tdocument.getElementById(___fnbSSODivId).style.display = \"none\";\n\t}\n\t___FnbSsoRollup();\n}\n\n\nfunction ___FnbCallSSOCallback(yesButton)\n{\n\tvar neverAskAgainChecked = (document.getElementById('___fnbSsoForm_ask').checked == true);\n\t___FnbSSOCallback(yesButton, neverAskAgainChecked);\n\t___FnbHideSSOContent();\n}\n\n\nvar ___fnbDocumentDir\t= (document.dir == 'rtl') || (document.body && (document.body.dir == 'rtl')) ? 'rtl' : 'ltr';\n\n\n__CP_GET_BROWSER_TYPE__ = window.__CP_GET_BROWSER_TYPE__ || function() \n{\n\n\t\n\n\t\n\t\n\t\n\tif(typeof navigator != \"undefined\")\n\t{\n\t\tif ( typeof navigator.userAgent == \"string\" )\n\t\t{\n\t\t\tvar agt = navigator.userAgent.toLowerCase();\n\t\t\tif (agt.indexOf(\"opera\") != -1)\n\t\t\t{\n\t\t\t \treturn \"Opera\";\n\t\t\t}\n\t\t\telse if (agt.indexOf(\"safari\") != -1)\n\t\t\t{\n\t\t\t\treturn \"Safari\";\n\t\t\t}\n\t\t}\n\n\t\tif ( typeof navigator.appName == \"string\" )\n\t\t{\n\t\t\tif(/Microsoft/i.exec(navigator.appName))\n\t\t\t{\n\t\t\t\treturn \"IE\";\n\t\t\t}\n\n\t\t\tif(/Netscape/i.exec(navigator.appName))\n\t\t\t{\n\t\t\t\treturn \"NS\";\n\t\t\t}\n\t\t}\n\t}\n\n\t\n\tif(\ttypeof top.document.implementation != \"undefined\" && \n\t\t\ttypeof top.document.doctype != \"undefined\" \t\t\t\t&&\n\t\t\ttypeof top.document.height == \"number\" \t\t\t\t\t\t&&\n\t\t\ttypeof top.document.width == \"number\" )\n\t{\n\t\treturn \"NS\";\n\t}\n\t\t\n\tif(\ttypeof top.document.activeElement != \"undefined\" \t&&\n\t\t\ttypeof top.document.charset == \"string\" \t\t\t\t\t&&\n\t\t\ttypeof top.document.frames != \"undefined\" \t\t\t\t&&\n\t\t\ttypeof top.ActiveXObject != \"undefined\" )\n\t{\n\t\treturn \"IE\";\n\t}\t\n\t\n\treturn \"other\";\n}\n\t\n\nvar ___szBrowserType \t\t= __CP_GET_BROWSER_TYPE__();\t\t\t\nvar ___fnbIE\t\t\t\t\t\t= (___szBrowserType == \"IE\");\t\t\t\nvar ___fnbWinHeight\t    = 28 - ( ( ___fnbIE ) ? 0 : 1 );\nvar ___fnbTitleHeight   = 17 - ( ( ___fnbIE ) ? 0 : 2 );\nvar ___fnbContentHeight = 28 - ( ( ___fnbIE ) ? 0 : 1 );\n\n\nfunction ___SetMinimizedBarDimensions()\n{\n\t___fnbWinWidth -= ___fnbLeftWidth;\n\t___fnbWinHeight = ___fnbMinHeight;\n}\n\nfunction ___SetMaximizedBarDimensions()\n{\n\t___fnbWinWidth += ___fnbLeftWidth;\n\t___fnbWinHeight = ___fnbLeftHeight;\n}\n\nfunction ___GetContentWidth()\n{\n\ttry\n\t{\n\t\tif ( ___fnbIE )\n\t\t{\n\t\t\treturn document.body.scrollWidth;\n\t\t}\n\t\telse\n\t\t{\n\t\t\treturn self.document.body.scrollWidth;\n\t\t}\n\t}\n\tcatch ( e )\n\t{\n\t\treturn 0;\n\t}\n}\n\n\nfunction ___GetContentHeight()\n{\n\ttry\n\t{\n\t\tif ( ___fnbIE )\n\t\t{\n\t\t\treturn document.body.scrollHeight;\n\t\t}\n\t\telse\n\t\t{\n\t\t\treturn document.body.scrollHeight;\n\t\t}\n\t}\n\tcatch ( e )\n\t{\n\t\treturn 0;\n\t}\n}\n\n\nfunction ___GetClientWidth()\n{\n\ttry\n\t{\n\t\tif ( ___fnbIE )\n\t\t{\n\t\t\tvar maxClientWidth = Math.max(  (typeof( self.innerWidth ) == \"undefined\"? 0:self.innerWidth), document.body.clientWidth );\n\t\t\treturn maxClientWidth;\n\t\t}\n\t\telse\n\t\t{\n\t\t\tif ( ___GetContentHeight() > self.innerHeight)\n\t\t\t{\n\t\t\t\treturn self.innerWidth - 17;\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\treturn self.innerWidth;\n\t\t\t}\n\t\t}\n\t}\n\tcatch ( e )\n\t{\n\t\treturn 0;\n\t}\n}\n\n\nfuncti