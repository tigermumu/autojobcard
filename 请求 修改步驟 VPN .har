t\tdataType: \"json\",\r\n\t\t\tsuccess: function(data){\r\n\t\t\t\tif(data.cnt===0 || data.cnt==='0'){\r\n\t\t\t\t\tpass=false;\r\n\t\t\t\t}else {\r\n\t\t\t\t\t//如果值大于0时进入\r\n\t\t\t\t\talert(\"已附航材的步骤不允许选为技术陈述！原因：技术陈述步骤不需签署，但电子签非卡使用的航材需签署确认。\")\r\n\t\t\t\t\tselectElement.value = \"N\";\r\n\t\t\t\t\tpass=true;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\r\n\r\n\t}\r\n\tif(pass) {\r\n\t\treturn;\r\n\t}\r\n\tvar td = getObj($(obj).parent().parent(),\"delTdClass\",\"countermarch\");\r\n\tif(td == null)\r\n\t{\r\n\t\ttd = getObj($(obj).parent().parent(),\"delTdClass\",\"onward\");\r\n\t}\r\n\tvar isUpd = td.children(\".isupdClass\");\r\n\tvar onlyUpdStep = td.children(\".onlyUpdStepClass\");\r\n\tvar updatedBy = td.children(\".updatedByClass\");\r\n\tvar editorGrp = td.children(\".editorGrpClass\");\r\n\r\n\tisUpd.attr(\"value\",\"true\");\r\n\tonlyUpdStep.attr(\"value\",\"true\");\r\n\tupdatedBy.attr(\"value\",\"005558 WU WEILING\");\r\n\teditorGrp.attr(\"value\",wgp);\r\n\r\n\tchangeTheValue();\r\n}\r\n\r\nfunction changeJCStp(obj)\r\n{\r\n\tvar td = getObj($(obj).parent().parent(),\"delTdClass\",\"countermarch\");\r\n\tif(td == null)\r\n\t{\r\n\t\ttd = getObj($(obj).parent().parent(),\"delTdClass\",\"onward\");\r\n\t}\r\n\tvar isUpd = td.children(\".isupdClass\");\r\n\tvar onlyUpdStep = td.children(\".onlyUpdStepClass\");\r\n\tvar updatedBy = td.children(\".updatedByClass\");\r\n\tvar editorGrp = td.children(\".editorGrpClass\");\r\n\t\t\t\t\r\n\tisUpd.attr(\"value\",\"true\");\r\n\tonlyUpdStep.attr(\"value\",\"true\");\r\n\tupdatedBy.attr(\"value\",\"005558 WU WEILING\");\r\n\teditorGrp.attr(\"value\",wgp);\r\n\t\r\n\tchangeTheValue();\r\n}\r\n\r\nfunction changeJobCard()\r\n{\r\n\tvar flag = $(\"#updjobcardId\");\r\n\tflag.attr(\"value\",\"true\");\r\n\tchangeTheValue();\r\n}\r\n\r\nfunction assistant(rid,actype)\r\n{\r\n\t/*\r\n\tvar url = \"assistant/assistant.jsp?actype=\"+actype+\"&rid=\"+rid;\r\n\tvar value = window.showModalDialog(url,\"\",\r\n\t\"dialogHeight:600px;dialogWidth:800px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tif(value == \"refurbish\" || value == null)\r\n\t{\r\n\t\tdocument.form.action = \"alterPPJCSTP.jsp?rid=\"+rid+\"&addppjc=\"+addJC;\r\n\t\tdocument.form.submit();\r\n\t\tdocument.form.action = \"\";\r\n\t}\r\n\t*/\r\n}\r\n\r\nfunction goPanel()\r\n{\r\n\t/*\r\n\tvar url = \"coverBoard/coverBoard.jsp?ppjcrid=\"+rid;\r\n\tvar value = window.showModalDialog(url,\"\",\r\n\t\"dialogHeight:420px;dialogWidth:500px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tif(value == \"refurbish\" || value == null)\r\n\t{\r\n\t\tdocument.form.action = \"alterPPJCSTP.jsp?rid=\"+jcRid+\"&addppjc=\"+addJC;\r\n\t\tdocument.form.submit();\r\n\t\tdocument.form.action = \"\";\r\n\t}\r\n\t*/\r\n}\r\n\r\n// 复制工具或航材信息到别的工种上\r\n// 意思为从其他工卡中的工种内的工具/航材复制到本工种中\t\r\nfunction copy(rid)\r\n{\r\n\t/*\r\n\tvar url = \"copy/copy.jsp?rid=\"+rid+\"&jobcard=\"+jobcard;\r\n\tvar value = window.showModalDialog(url,\"\",\r\n\t\"dialogHeight:420px;dialogWidth:500px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tif(value == \"refurbish\" || value == null)\r\n\t{\r\n\t\tdocument.form.action = \"alterPPJCSTP.jsp?rid=\"+rid+\"&addppjc=\"+addJC;\r\n\t\tdocument.form.submit();\r\n\t\tdocument.form.action = \"\";\r\n\t}\r\n\t*/\r\n}\r\n\r\n// 检索对应工种下的工具/航材是否有数据\r\nfunction selectAdscription(id,type)\r\n{\r\n\tvar url = \"../ajax/selectAdscription.jsp?rid=\"+id+\"&type=\"+type;\r\n\t// tempId、tempResult、tempType3个全部变量是为此方法准备\r\n\t// 如果传入的ID和TYPE值与全局变量的值不相等，则向服务器发送请求\r\n\t// 主要为了防止鼠标移动且在同一TD中时所产生的多次访问服务器\r\n\t//if(tempId != id || tempType != type)\r\n\tif(tempId != id)\r\n\t{\r\n\t\ttempId = id;\r\n\t\t//tempType = type;\r\n\t\t// 需要使用同步的AJAX请求\r\n\t\tjQuery.ajax({\r\n\t\t\ttype: \"post\",\r\n\t\t\tasync: true,//控制同步=false 异步=true\r\n\t\t\turl: url,\r\n\t\t\tcontentType: \"application/json; charset=gbk\",\r\n\t\t\tdataType: \"json\",\r\n\t\t\tcache: false,\r\n\t\t\tsuccess: function (data) {\r\n\t\t\t\t//返回的数据用data.d获取内容\r\n\t\t\t\tif(data!=\"\")\r\n\t\t\t\t{\r\n\t\t\t\t\tif(data.info != null)\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\ttempResult = data.info;\r\n\t\t\t\t\t\tshowtip(tempResult);\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\ttempResult = \"\";\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t},\r\n\t\t\terror: function (err) {\r\n\t\t\t\talert(err);\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\telse // 如果传入的ID和TYPE值与全局变量的值相等，直接调用此方法\r\n\t{\r\n\t\tshowtip(tempResult);\r\n\t}\r\n}\r\n\r\n// 显示链接的说明\r\n/* function showtip(text)\r\n{\r\n\tif(text==\"\")return false;\r\n\tif (document.all&&document.readyState==\"complete\")  //针对IE\r\n\t{\r\n\t\tdocument.all.tooltip.innerHTML=\"<div vAlign=center><font SIZE=2>\"+text+\"</font></div>\";\r\n\t\tdocument.all.tooltip.style.pixelLeft=event.clientX+document.body.scrollLeft+10;\r\n\t\tdocument.all.tooltip.style.pixelTop=event.clientY+document.body.scrollTop+10;\r\n\t\tdocument.all.tooltip.style.visibility=\"visible\";\r\n\t}\r\n}\r\n\r\n// 隐藏链接的说明\r\nfunction hidetip()  \r\n{\r\n\tif (document.all)\r\n\tdocument.all.tooltip.style.visibility=\"hidden\";\r\n} */\r\nfunction showtip(text){\r\n\tif(text==\"\"){return false;}\r\n\tif((!!window.ActiveXObject || \"ActiveXObject\" in window) && document.readyState==\"complete\"){\r\n\t\t__CP_SET_HTML_ATT__(document.all.tooltip,'innerHTML',\"<div vAlign=center><font SIZE=2>\"+text+\"</font></div>\");\r\n\t\tdocument.all.tooltip.style.pixelLeft=event.clientX+document.body.scrollLeft+10;\r\n\t\tdocument.all.tooltip.style.pixelTop=event.clientY+document.body.scrollTop+10;\r\n\t\tdocument.all.tooltip.style.visibility=\"visible\";\r\n \t}else{\r\n \t\t__CP_SET_HTML_ATT__(document.all.tooltip,'innerHTML',\"<div vAlign=center><font SIZE=2>\"+text+\"</font></div>\");\r\n\t\tdocument.all.tooltip.style.left=event.clientX+document.body.scrollLeft+10;\r\n\t\tdocument.all.tooltip.style.top=event.clientY+document.body.scrollTop+10;\r\n\t\tdocument.all.tooltip.style.visibility=\"visible\";\r\n\t\tdocument.all.tooltip.style.height=\"auto\";\r\n\t} \r\n}\r\nfunction hidetip()  {\r\n\tdocument.all.tooltip.style.visibility=\"hidden\";\r\n} \r\n\r\n//T=工具,M=航材\r\nfunction goMAT(type,rid,updateable)\r\n{\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn;\r\n\t}\r\n\tvar wo = \"120000587070\";\r\n\tvar fcno = \"3C\";\r\n\tvar tailno = \"A6-EUD\";\r\n\tvar jcwo = \"500007989096\";\r\n\tvar station = \"CAN\";\r\n\tvar flagCmt = \"Y\";\r\n\tvar url = \"\";\r\n\t\r\n\tif(station==\"\")\r\n\t{\r\n\t\talert(\"该工卡在ME中未登记!\");\r\n\t\treturn;\r\n\t}\r\n\tvar urlName = \"\";\r\n\tif(type == \"T\")\r\n\t{\r\n\t\turlName = \"工具\";\r\n\t\turl = \"MAT/alterTool.jsp?woRid=\"+woRid+\"&type=\"+type\r\n\t\t+\"&jobcard=\"+jobcard.replace(/#/g,'%23')+\"&rid=\"+rid+\"&jcSeq=\"+jcSeq+\"&wo=\"+wo\r\n\t\t+\"&updateable=\"+updateable+\"&station=\"+station;\r\n\t}\r\n\telse if(type == \"M\")\r\n\t{\r\n\t\turlName = \"航材\";\r\n\t\turl = \"MAT/alterMAT.jsp?woRid=\"+woRid+\"&type=\"+type\r\n\t\t+\"&jobcard=\"+jobcard.replace(/#/g,'%23')+\"&rid=\"+rid+\"&jcSeq=\"+jcSeq+\"&wo=\"+wo+\"&wgp=\"+wgp\r\n\t\t+\"&updateable=\"+updateable+\"&fcno=\"+fcno.replace(/\\+/g,\"%2B\")+\"&tailno=\"+tailno+\"&jcwo=\"+jcwo\r\n\t\t+\"&station=\"+station+\"&ownerCode=\"+ownerCode+\"&flagCmt=\"+flagCmt;\r\n\t}\r\n\t//\r\n\t__CP_FUNC_Open__(JqueryDialog,urlName,url,document.body.clientWidth-50,document.body.clientHeight-100);\r\n}\r\n\r\nfunction goMATForM(type,rid,updateable,strFlagEr)\r\n{\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn;\r\n\t}\r\n\tvar wo = \"120000587070\";\r\n\tvar fcno = \"3C\";\r\n\tvar tailno = \"A6-EUD\";\r\n\tvar jcwo = \"500007989096\";\r\n\tvar station = \"CAN\";\r\n\tvar flagCmt = \"Y\";\r\n\tvar url = \"\";\r\n\r\n\tif(station==\"\")\r\n\t{\r\n\t\talert(\"该工卡在ME中未登记!\");\r\n\t\treturn;\r\n\t}\r\n\tvar urlName = \"\";\r\n\tif(type === \"M\")\r\n\t{\r\n\t\t//如果是电子签非卡,当技术陈述拦为'Y'时\r\n\t\tvar eSign=\"\";\r\n\t\tif(eSign==='1'&&strFlagEr==='Y'){\r\n\t\t\talert(\"不允许附航材！原因：技术陈述步骤不需签署，但电子签非卡使用的航材需签署确认。\")\r\n\t\t\treturn;\r\n\t\t}\r\n\t\turlName = \"航材\";\r\n\t\turl = \"MAT/alterMAT.jsp?woRid=\"+woRid+\"&type=\"+type\r\n\t\t\t\t+\"&jobcard=\"+jobcard.replace(/#/g,'%23')+\"&rid=\"+rid+\"&jcSeq=\"+jcSeq+\"&wo=\"+wo+\"&wgp=\"+wgp\r\n\t\t\t\t+\"&updateable=\"+updateable+\"&fcno=\"+fcno.replace(/\\+/g,\"%2B\")+\"&tailno=\"+tailno+\"&jcwo=\"+jcwo\r\n\t\t\t\t+\"&station=\"+station+\"&ownerCode=\"+ownerCode+\"&flagCmt=\"+flagCmt;\r\n\t}\r\n\t//\r\n\t__CP_FUNC_Open__(JqueryDialog,urlName,url,document.body.clientWidth-50,document.body.clientHeight-100);\r\n}\r\n// 检查用户是否第一次编写步骤\r\nfunction firstInputStep()\r\n{\r\n\tvar fis_flag = true;\r\n\tvar userInfo = '005558 WU WEILING';\r\n\tvar url = \"../ajax/checkFirstInputStep.jsp?info=\"+userInfo+\"&jsonpcallback=?\";\r\n\t\r\n\t// 需要使用同步的AJAX请求\r\n\t$.ajax({\r\n\t\ttype: \"POST\",\t\t\t\t\t// 请求方式\r\n\t\turl: url,\t\t\t\t\t\t// 请求地址\r\n\t\tjsonp: \"jsonpcallback\",\t\t\t// 回调函数名字\r\n\t\tasync: false,\t\t\t\t\t// 设置是否需要异步 true=异步,false=同步\r\n\t\tdataType: \"jsonp\",\t\t\t\t// 返回的数据格式\r\n\t\tsuccess: function(data)\t\t\t// 成功返回时，所调用的回调函数\t\r\n\t\t{\r\n\t\t\tif(data.flag==false)\r\n\t\t\t{\r\n\t\t\t\tfis_flag = data.flag;\r\n\t\t\t}\r\n\t\t}\r\n\t});\r\n\t\r\n\treturn fis_flag;\r\n}\r\n// 检查编写者格式是否正确 格式：员工号+\" \"+中文姓名 (或) 员工号+\" \"+拼音姓名\r\nfunction checkSISUseName()\r\n{\r\n\tvar userInfo = '005558 WU WEILING';\r\n\t//if(jQuery.trim(userInfo).length>6)\r\n\tif($.trim(userInfo)!=\"\")\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\telse\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n}\r\n// type为0，表示添加步骤\r\n// type为1，表示添加工种\r\nfunction checkCurrentlyStep(table_id,textId,type)\r\n{\r\n\tif(checkSISUseName())\r\n\t{\r\n\t\tvar userInfo = '005558 WU WEILING';\r\n\t\tvar fis_flag = firstInputStep();\r\n\t\t\r\n\t\tif(!fis_flag&&oneTime)\r\n\t\t{\r\n\t\t\talert(\"您好!您的编写者署名为：\"+userInfo+\"\\n如正确不需理会，否则请联系人事部门完善相关信息后再编写!\");\r\n\t\t\toneTime = false;\r\n\t\t}\r\n\t}\r\n\telse\r\n\t{\r\n\t\talert(\"您好!您的中文名或拼音名不完整，请联系人事部门在人事系统完善信息后方可编写!\");\r\n\t\t//return false;\r\n\t}\r\n\t// 查找table内所有的tr元素\r\n\tvar trArray = $(\"#\" + table_id + ' tr');\r\n\tvar re = new RegExp(\"^[1-9]{1}[0-9]*$\");\r\n\t// 最大的步骤号\r\n\tvar maxStep = $.trim($(\".stepTdClass\").last().html()) * 1;\r\n\t// 插入的步骤号\r\n\tvar step = $.trim($(\"#\"+textId).val()) * 1;\r\n\t//alert(step);\r\n\t// 添加步骤\r\n\tif(type == 0)\r\n\t{\r\n\t\t// 步骤号为空或为不是数字值或大于最大步骤号，则在表的最后添加一行\r\n\t\tif(step == \"\" || !re.test(step) || step > maxStep)\r\n\t\t{\r\n\t\t\t// table最后一行\r\n\t\t\tvar lastTr = trArray.last();\r\n\t\t\tvar seq = 0;\r\n\t\t\tif(trArray.length == 1)\r\n\t\t\t{\r\n\t\t\t\tseq = 1;\r\n\t\t\t}\r\n\t\t\telse\r\n\t\t\t{\r\n\t\t\t\tseq = maxStep*1+1;\r\n\t\t\t}\r\n\t\t\t// 在最后一行后添加\r\n\t\t\t//alert(lastTr.html());\r\n\t\t\taddTr(lastTr,type,\"after\",seq);\r\n\t\t}\r\n\t\t// 步骤号非空且输入值有效\r\n\t\telse {\r\n\t\t\tif('Y' == $(\"#indInsp\").val() && !checkindInspStep(step)){// 独立检验插入的步骤是否合理\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t\t// 获得所有的步骤\r\n\t\t\tvar stepArray = $(\".stepTdClass\");\r\n\t\t\tvar stepTr;\t\t// 步骤行\r\n\t\t\tvar stepTd;\t\t// 步骤列\r\n\t\t\tvar stepNum;\t// 步骤号\r\n\t\t\tvar flag = true;\r\n\t\t\tfor(var i = 0;i < stepArray.length;i++)\r\n\t\t\t{\r\n\t\t\t\tstepTd = $(stepArray[i]);\r\n\t\t\t\tstepTr = stepTd.parent();\r\n\t\t\t\t//stepTr = stepTd.parent().next(\"tr\");\r\n\t\t\t\tstepNum = stepTr.children(\".stepTdClass\").html() * 1;\r\n\t\t\t\tstepTr = $(stepTr).prev(\"tr\");\r\n\t\t\t\t\r\n\t\t\t\tvar eSignInfo = $(\"#\"+stepNum).val();\r\n\t\t\t\tvar stepStatus = $(\"#\"+stepNum+\"StepStatus\").val();\r\n\t\t\t\tif(eSignInfo.length != 0 && (eSignInfo == \"已签\" || stepStatus!='N' )){\r\n\t\t\t\t\tflag = false;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tflag = true;\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\tif(stepNum == step)\r\n\t\t\t\t{\r\n\t\t\t\t\tif(!flag)\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\talert(\"第\"+stepNum+\"步存在已电子签署,不允许在其之前添加步骤！\");\r\n\t\t\t\t\t\treturn false;\r\n\t\t\t\t\t}\r\n\t\t\t\t\t\r\n\t\t\t\t\t// 重新设置步骤号(增操作)\r\n\t\t\t\t\talterStep(step,\"add\");\r\n\t\t\t\t\t// 在对应步骤号前添加\r\n\t\t\t\t\taddTr(stepTr,type,\"before\",stepNum);\r\n\t\t\t\t\tbreak;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n\r\n// 根据步骤TD，获取指定class的TD对象\r\nfunction getObj(trObj,tdClassName,aspect)\r\n{\r\n\tvar targetTd = null;\r\n\ttargetTd = $(trObj).children(\".\"+tdClassName);\r\n\t// 如果当前行已经有所需要的TD对象，则不在向前或向后操作\r\n\tif(targetTd.length > 0)\r\n\t{\r\n\t\treturn targetTd;\r\n\t}\r\n\t// 向前找\r\n\tif(aspect == \"onward\")\r\n\t{\r\n\t\t// 根据表单格式不同，会有所修改\r\n\t\ttargetTd = $(trObj).prev().children(\".\"+tdClassName);\r\n\t}\r\n\t// 向后找\r\n\telse if(aspect == \"countermarch\")\r\n\t{\r\n\t\t// 根据表单格式不同，会有所修改\r\n\t\ttargetTd = $(trObj).next().children(\".\"+tdClassName);\r\n\t}\r\n\tif(targetTd.length > 0)\r\n\t{\r\n\t\treturn targetTd;\r\n\t}\r\n\telse\r\n\t{\r\n\t\treturn null;\r\n\t}\r\n}\r\n\r\n// 根据表单格式不同，会有所修改\r\nfunction nextTr(td)\r\n{\r\n\treturn $(td).parent().next().next();\r\n}\r\n\r\n// 获取某一步骤里的值\r\nfunction getStpValue(tr)\r\n{\r\n\tvar obj = new Object();\r\n\t/*\r\n\talert($(tr).html());\r\n\talert($(tr).prev().html());\r\n\t*/\r\n\tobj.stepDesc = $(tr).find(\".stepDescClass\").attr(\"value\");\t\t\t\t// 中文描述\r\n\tobj.stepEnDesc = $(tr).find(\".stepEnDescClass\").attr(\"value\");\t\t\t// 英文描述\r\n\tobj.schedphase = $(tr).next().find(\".schedphaseClass\").attr(\"value\");\t// 阶段\r\n\tobj.schedtrade = $(tr).next().find(\".schedtradeClass\").attr(\"value\");\t// 工种\r\n\tobj.area = $(tr).next().find(\".areaClass\").attr(\"value\");\t\t\t\t// 区域\r\n\tobj.flagTank = $(tr).next().next().find('.flagTank').val();// 进入燃油箱\r\n\treturn obj;\r\n}\r\n\r\n// type为0，表示添加步骤\r\n// type为1，表示添加工种\r\n// option为before或after\r\nfunction addTr(tr,type,option,stepNum) {\r\n\tchangeTheValue();\r\n\tvar seq = stepNum;\r\n\tvar stepTd = tr.prev().children(\".stepTdClass\");\r\n\tvar phase = \"\";\r\n\tvar laborCode = \"\";\r\n\tvar area = \"\";\r\n\tvar meAv = \"\";\r\n\tvar delAction = \"\";\r\n\tvar obj = getStpValue(tr.prev().prev());\r\n\t\r\n\tlaborCode = '<select style=\"width:100%\" name=\"schedtrade\" class=\"schedtradeClass\" onchange=\"changeMeAv(this);\">';\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='--')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"--\" selected>--</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"--\">--</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP-UPR')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-UPR\" selected>机电-机上</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-UPR\">机电-机上</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP-LOW')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-LOW\" selected>机电-机下</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-LOW\">机电-机下</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP-WING')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-WING\" selected>机电-大翼</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-WING\">机电-大翼</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP-ENG')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-ENG\" selected>机电-发动机</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-ENG\">机电-发动机</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP-GEAR')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-GEAR\" selected>机电-起落架</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-GEAR\">机电-起落架</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP-TAIL')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-TAIL\" selected>机电-尾部</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP-TAIL\">机电-尾部</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AVIO')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AVIO\" selected>电子</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AVIO\">电子</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='S/M')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"S/M\" selected>金工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"S/M\">金工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='TRIM')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"TRIM\" selected>机上</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"TRIM\">机上</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='AIRP')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP\" selected>机电</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"AIRP\">机电</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='HM3_S/M')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"HM3_S/M\" selected>三部金工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"HM3_S/M\">三部金工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='COMP')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"COMP\" selected>CRC复合材料</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"COMP\">CRC复合材料</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='MCH')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"MCH\" selected>CRC机加工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"MCH\">CRC机加工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='SPEC TR')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"SPEC TR\" selected>CRC特种处理</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"SPEC TR\">CRC特种处理</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='HM3_CABIN')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"HM3_CABIN\" selected>三部客舱</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"HM3_CABIN\">三部客舱</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='CABIN_PNT')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"CABIN_PNT\" selected>客舱漆工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"CABIN_PNT\">客舱漆工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='PNT')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"PNT\" selected>漆工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"PNT\">漆工</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='CLN')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"CLN\" selected>清洁</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"CLN\">清洁</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='WIP')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"WIP\" selected>WIP</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"WIP\">WIP</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t\tif(obj.schedtrade=='ENG')\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"ENG\" selected>发动机</option>';\r\n\t\t\t\t\t}\r\n\t\t\t\t\telse\r\n\t\t\t\t\t{\r\n\t\t\t\t\t\tlaborCode+='<option value=\"ENG\">发动机</option>';\r\n\t\t\t\t\t}\r\n\