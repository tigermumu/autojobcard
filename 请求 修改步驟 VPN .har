 style=\"border-top-width: 0.1cm;\">';\r\n\tvar str2 = false==true?'<td class=\"eSignTdClass\"><select name=\"meAv\" class=\"meAvClass\" style=\"width: 100%;\"><option value=\"\"></option><option value=\"AT1\">AT1</option><option value=\"AT2\">AT2</option><option value=\"AT3\">AT3</option></select></td>':'<td class=\"eSignTdClass\"></td>';\r\n\tvar newTr = \r\n\t\t\t '<tr bgcolor=\"#FFFFFF\">'\r\n\t\t\t\t+'<td class=\"stepTdClass\" align=\"center\" width=\"40px\" rowspan=\"3\" style=\"border-top-width: 0.1cm;\">'+seq+'</td>'\r\n\t\t\t\t\t+str\r\n\t\t\t\t\t+'<table border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" bgcolor=\"\" width=\"100%\" style=\"table-layout : fixed\">'\r\n\t\t\t\t\t\t+'<tr bgcolor=\"\">'\r\n\t\t\t\t\t\t\t+'<td width=\"120px\" align=\"center\">步骤描述(中文)</td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"58%\" class=\"stepDescTdClass\" align=\"left\" style=\"text-align:center;word-break:break-all\" colspan=\"2\">'\r\n\t\t\t\t\t\t\t\t+'<input type=\"text\" name=\"stepDesc\" class=\"stepDescClass textType\" readonly style=\"width:99%\"/>'\r\n\t\t\t\t\t\t\t\t\r\n\t\t\t\t\t\t\t+'</td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"100px\" align=\"center\"></td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"100\" align=\"center\"></td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"60px\" align=\"center\"><a href=\"#\" onclick=\\\"showChangeModel(this,\\'single\\');return false;\\\"\" : \"\">导入信息</a></td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td align=\"center\">'\r\n\t\t\t\t\t\t\t+'<td/>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"50px\"><select name =\"flagEr\"> <option value=\"N\">N</option>   <option value=\"Y\">Y</option> </select></td>'\r\n\t\t\t\t\t\t+'</tr>'\r\n\t\t\t\t\t\t+'<tr height=\"1\">'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" colspan=\"13\" width=\"\"></td>'\r\n\t\t\t\t\t\t+'</tr>'\r\n\t\t\t\t\t\t+'<tr>'\r\n\t\t\t\t\t\t\t+'<td width=\"120px\" align=\"center\" width=\"120\">步骤描述(英文)</td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td class=\"stepEnDescTdClass\" align=\"left\" style=\"text-align:center;word-break:break-all\" colspan=\"4\">'\r\n\t\t\t\t\t\t\t\t+'<input type=\"text\" name=\"stepEnDesc\" class=\"stepEnDescClass\"   style=\"width:99%\"/>'\r\n\t\t\t\t\t\t\t+'</td>'\r\n\t\t\t\t\t\t\t+'<td bgcolor=\"#3366FF\" width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"100\" align=\"center\"><td/>'\r\n\t\t\t\t\t\t\t+'<td width=\"1px\"></td>'\r\n\t\t\t\t\t\t\t+'<td width=\"1px\"></td>'\r\n\t\t\t\t\t\t+'</tr>'\r\n\t\t\t\t\t+'</table>'\r\n\t\t\t\t+'</td>'\r\n\t\t\t+'</tr>'\r\n\t\t\t+'<tr bgcolor=\"#FFFFFF\">'\r\n\t\t\t\t+'<td class=\"schedphaseTdClass\" align=\"center\" width=\"235px\">'+phase+'</td>'\r\n\t\t\t\t+'<td class=\"schedtradeTdClass\" align=\"center\" width=\"115px\">'+laborCode+'</td>'\r\n\t\t\t\t+'<td class=\"schedlaborTdClass\" align=\"center\" width=\"40px\"><input onchange=\"checkText(this)\" name=\"schedlabor\" style=\"width:100%\" type=\"text\" value=\"\"/></td>'\r\n\t\t\t\t+'<td class=\"schedmhTdClass\" align=\"center\" width=\"60px\"><input onchange=\"checkText(this)\" name=\"schedmh\" style=\"width:100%\" type=\"text\" value=\"\"/></td>'\r\n\t\t\t\t+'<td class=\"summanhourTdClass\" align=\"center\" width=\"60px\"></td>'\r\n\t\t\t\t+'<td class=\"areaTdClass\" align=\"center\" width=\"160px\">'+area+'</td>'\r\n\t\t\t\t+'<td class=\"remarkTdClass\" align=\"center\" width=\"100\" style=\"text-align:center;word-break:break-all\"><input type=\"text\" name=\"remark\" value=\"\" style=\"width:100%\"/></td>'\r\n\t\t\t\t+'<td class=\"toolTdClass\" align=\"center\" width=\"0px\">未保存</td>'\r\n\t \t\t\t+'<td class=\"materialTdClass\" align=\"center\" width=\"0px\">未保存</td>'\r\n\t \t\t\t+'<td class=\"assistantTdClass\" align=\"center\" width=\"0px\">未保存</td>'\r\n\t \t\t\t+'<td class=\"pmiTdClass\" align=\"center\" width=\"0px\">未保存</td>'\r\n\t\t\t\t+'<td class=\"delTdClass\" align=\"center\" width=\"30px\">'+delAction\r\n\t\t\t\t\t+'<input class=\"rid\" type=\"hidden\" name=\"primary\" value=\"\"/>'\r\n\t\t\t\t\t+'<input class=\"updatedByClass\" type=\"hidden\" name=\"updatedBy\" value=\"005558 WU WEILING\"/>'\r\n\t\t\t\t\t+'<input class=\"editorGrpClass\" type=\"hidden\" name=\"editorGrp\" value=\"'+wgp+'\"/>'\r\n\t\t\t\t\t+'<input class=\"isupdClass\" type=\"hidden\" name=\"isupd\" value=\"false\"/>'\r\n\t\t\t\t\t+'<input class=\"onlyUpdStepClass\" type=\"hidden\" name=\"onlyUpdStep\" value=\"false\"/>'\r\n\t\t\t\t\t+'<input class=\"hiddenStepClass\" type=\"hidden\" name=\"step\" value=\"'+seq+'\"/>'\r\n\t\t\t\t\t+'<input class=\"vidClass\" type=\"hidden\" name=\"stepVid\" value=\"\"/>'\r\n\t\t\t\t\t+'<input class=\"stepRiiClass\" type=\"hidden\" name=\"stepRii\" value=\"\"/>'\r\n\t\t\t\t\t+'<input type=\"hidden\" name=\"taskDsc\" value=\"\"/>'\r\n\t\t\t\t\t+'<input type=\"hidden\"class=\"qc1st\" value=\"\"/>'\r\n\t\t\t\t\t+'<input type=\"hidden\"class=\"qc2nd\" value=\"\"/>'\r\n\t\t\t\t+'</td>'\r\n\t\t\t\t+str2\r\n\t\t\t\t+'<td width=\"1px\"></td>'\r\n\t\t\t+'</tr>'\r\n\t\t\t+'<tr align=\"center\" bgcolor=\"#FFFFFF\">'\r\n\t\t\t\t+'<td align=\"right\" style=\"padding-right: 4px;\">进入燃油箱工作</td>'\r\n\t\t\t\t+'<td>' + flagTank +'</td>'\r\n\t\t\t\t+'<td colspan=\"12\"></td>'\r\n\t\t\t+'</tr>';\r\n\t// \r\n\tif(option == \"after\")\r\n\t{\r\n\t\t$(tr).after(newTr);\r\n\t}\r\n\telse if(option == \"before\")\r\n\t{\r\n\t\t$(tr).next(\"tr\").before(newTr);\r\n\t}\r\n}\r\n\r\n// 重新设置步骤号\r\n// option为add(增)或subtract(减)\r\nfunction alterStep(stepNum,option)\r\n{\r\n\tvar stepArray = $(\".stepTdClass\");\r\n\t// 加操作\t\r\n\tif(option == \"add\")\r\n\t{\r\n\t\tfor(var i = 0;i < stepArray.length;i++)\r\n\t\t{\r\n\t\t\tvar stepTd = $(stepArray[i]);\r\n\t\t\tvar delTd = getObj(stepTd.parent(),\"delTdClass\",\"countermarch\");\r\n\t\t\tvar num = stepTd.html()*1;\r\n\t\t\tif(num >= stepNum*1)\r\n\t\t\t{\r\n\t\t\t\tstepTd.html(num + 1);\r\n\t\t\t\tdelTd.children(\".hiddenStepClass\").attr(\"value\",num + 1);\r\n\t\t\t\tdelTd.children(\".isupdClass\").attr(\"value\",\"true\");\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t// 减操作\r\n\telse if(option == \"subtract\")\r\n\t{\r\n\t\tfor(var i = 0;i < stepArray.length;i++)\r\n\t\t{\r\n\t\t\tvar stepTd = $(stepArray[i]);\r\n\t\t\tvar delTd = getObj(stepTd.parent(),\"delTdClass\",\"countermarch\");\r\n\t\t\tvar num = stepTd.html()*1;\r\n\t\t\tif(num >= stepNum*1)\r\n\t\t\t{\r\n\t\t\t\tstepTd.html(num - 1);\r\n\t\t\t\tdelTd.children(\".hiddenStepClass\").attr(\"value\",num - 1);\r\n\t\t\t\tdelTd.children(\".isupdClass\").attr(\"value\",\"true\");\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n\r\nfunction changeText(obj)\r\n{\r\n\tchangeJCStp(obj);\r\n\tcheckText(obj);\r\n}\r\n\r\n// 检查输入值是否符合要求\r\nfunction checkText(obj)\r\n{\r\n\tvar text = obj;\r\n\tvar textValue = text.value.toString().replace(/(^\\s+)|\\s+$/g,\"\");\r\n\tvar textName = text.name;\r\n\t\r\n\t\r\n\t// 正整数，且不能0开头\r\n\tif(textName == \"schedlabor\")\r\n\t{\r\n\t\tif(textValue == \"\")\r\n\t\t{\r\n\t\t\talert(\"人力不能为空!\");\r\n\t\t}\r\n\t\tvar re1 = new RegExp(\"^[1-9]{1}[0-9]*$\");\r\n\t\tif(!re1.test(textValue))\r\n\t\t{\r\n\t\t\talert(\"人力请输入有效值!\");\r\n\t\t\tselectText(text);\r\n\t\t\treturn true;\r\n\t\t}\r\n\t\tvar labor = $(text);\r\n\t\tvar mh = labor.parent().parent().children(\".schedmhTdClass\").children();\r\n\t\tvar result = labor.parent().parent().children(\".summanhourTdClass\");\r\n\t\tif(labor.attr(\"value\") != \"\" && mh.attr(\"value\") != \"\")\r\n\t\t{\r\n\t\t\tresult.html(Math.round(labor.attr(\"value\")*(mh.attr(\"value\"))*100)/100);\r\n\t\t}\r\n\t}\r\n\t// 正数，2位小数\r\n\tif(textName == \"schedmh\")\r\n\t{\r\n\t\tif(textValue == \"\")\r\n\t\t{\r\n\t\t\talert(\"停场时间不能为空!\");\r\n\t\t}\r\n\t\tvar re2 = new RegExp(\"^[0-9]+$|^[0-9]+\\.{1}[0-9]{1,2}$\");\r\n\t\tif(!re2.test(textValue))\r\n\t\t{\r\n\t\t\talert(\"停场时间请输入有效值!\");\r\n\t\t\tselectText(text);\r\n\t\t\treturn true;\r\n\t\t}\t\t\r\n\t\tvar mh = $(text);\r\n\t\tvar labor = mh.parent().parent().children(\".schedlaborTdClass\").children();\r\n\t\tvar result = mh.parent().parent().children(\".summanhourTdClass\");\r\n\t\tif(labor.attr(\"value\") != \"\" && mh.attr(\"value\") != \"\")\r\n\t\t{\r\n\t\t\tresult.html(Math.round(labor.attr(\"value\")*(mh.attr(\"value\"))*100)/100);\r\n\t\t}\r\n\t}\r\n\t\r\n\treturn false;\r\n}\r\n\r\n// 文本框内容全选\r\nfunction selectText(obj)\r\n{\r\n\tobj.select();\r\n}\r\n\r\n// 保存\r\nfunction updateJCSTP()\r\n{\r\n\tif(!checkFedexOptions()){\r\n\t\treturn;\r\n\t}\r\n\tvar mainlabor = $(\"select[name='mainlabor']\");\t//\t主工种\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t//\t判断工程师\r\n\tvar stepArray = $(\".stepTdClass\");\r\n\tvar referenceDescObj = $(\"#referenceDesc\");\t\t//\t依据文件\r\n\tvar riiObj = $(\"#riiId\");\t\t\t\t\t\t//\t必检\r\n\tvar strWorkGroupRii = $(\"#strWorkGroupRiiId\");\t//\t工作组rii\r\n\t//var pse = $(\"#pse\").val();\t\t\t\t\t    //\t重要结构件\r\n\t//var strPse = $(\"#txtPse\").val(); \t\t\t\t//  重要结构件 旧值 \r\n\tvar sdrrFlag = false;\t\t\t\t\t\t\t//\tSDRR增删标识\r\n\t// Add by 700683 工卡管理增加客户化信息 2018-10-09 start\r\n\tvar lhtWpNo = $(\"#lhtWpNo\").val(); \t\t\t\t//  LHT WP NO.\r\n\tvar lhtRefNo = $(\"#lhtRefNo\").val();\t\t\t//  LHT REF NO.\r\n\tvar lhtCriNo = $(\"#lhtCriNo\").val();\t\t\t//  LHT CRI NO.\r\n\t// Add by 700683 工卡管理增加客户化信息 2018-10-09 end\r\n\t// update by 700683 RII功能验证修订 2018-11-12 start\r\n\tvar strCheckLevel = \"3C\"; \t\t\t// 定检级别\r\n\t// update by 700683 RII功能验证修订 2018-11-12 end\r\n\t// 登记FEDEX的解决措施\r\n\tvar rplStrPart=$(\"#rplStrPart\").val();\t\t\t//\t涉及可更换结构件\r\n\tvar\tsrplStrPart=\"\";\r\n\t\r\n\t//700824 重要结构件 和疲劳关键结构键是否已改变\r\n\tvar jcRid=$.trim($(\"#primaryJCId\").val());\t//工卡主键\r\n\t\r\n\tvar oldPse=\"N\"; \t\t//旧重要结构件的值\r\n\tvar oldFcs=\"\"; \t\t//旧疲劳关键结构件的值\r\n\tvar newPse = $(\"#pse\").val();\t//新的值\r\n\tvar newFcs = $(\"#fcs\").val();\t//新的值\r\n\tvar newStrRepair = $(\"#strRepair\").val();\t//结构修理\r\n\r\n\t// 非工卡站角色保存时进行QA写卡授权检查\r\n\tif(\"\" != wgp && 1 != checkQAAuth()){\r\n\t\treturn;\r\n\t}\r\n\t//校验封面是否已签,已签的将不允许修改\r\n\tvar checkAmtSign = false;\r\n\t$.ajax({\r\n\t\turl: \"/trace/fgm/fgm.do?method=countAmtSignByJcRid\",\r\n\t\ttype: 'post',\r\n\t\tasync: false,\r\n\t\tdata: {\"jcRid\":jcRid,\"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\tdataType: 'json',\r\n\t\tcontentType: 'application/x-www-form-urlencoded;charset=utf-8',\r\n\t\tsuccess: function(data) {\r\n\t\t\tif(data.cnt == 0){\r\n\t\t\t\tcheckAmtSign = true;\r\n\t\t\t}\r\n\t\t\t\r\n\t\t},\r\n\t\terror: function() {\r\n\t\t\talert(\"系统异常,操作失败!\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t});\r\n\tif(!checkAmtSign){\r\n\t\talert(\"工作者已签封面，不允许修改！\");\r\n\t\t$(\"#save\").attr(\"disabled\",\"disabled\");\r\n\t\t$(\"#save2\").attr(\"disabled\",\"disabled\");\r\n\t\treturn;\r\n\t}\r\n\t// 禁止签署时,检查步骤是否已签,有已签步骤的禁止选择禁止签署\r\n\tif(\"Y\" == $(\"#forbidEsign\").val()){\r\n\t\tvar checkMchSign = false;\r\n\t\t$.ajax({\r\n\t\t\turl: \"/trace/fgm/fgm.do?method=countMchSignByJcRid\",\r\n\t\t\ttype: 'post',\r\n\t\t\tasync: false,\r\n\t\t\tdata: {\"jcRid\":jcRid,\"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\t\tdataType: 'json',\r\n\t\t\tcontentType: 'application/x-www-form-urlencoded;charset=utf-8',\r\n\t\t\tsuccess: function(data) {\r\n\t\t\t\tif(data.cnt == 0){\r\n\t\t\t\t\tcheckMchSign = true;\r\n\t\t\t\t}\r\n\t\t\t},\r\n\t\t\terror: function() {\r\n\t\t\t\talert(\"系统异常,操作失败!\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t});\r\n\t\tif(!checkMchSign){\r\n\t\t\talert(\"已有签署步骤，不允许设置禁止签署！\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t\r\n\t// 工卡陈诉不为N时,不允许做保存,修改 插入操作\r\n\t/*\r\n\t\tvar flagErStatus = true;\r\n\t\t$(\"[name='flagEr']\").each(function(){\r\n\t\t\tvar t = $(this).val();\r\n\t\t\tif(t=='Y'){\r\n\t\t\t\tvar stepId = $(this).parent().parent().parent().parent().parent().prev(\"td\").text();\r\n\t\t\t\talert(\"关闭步骤[\"+stepId+\"]不允许修改！\");\r\n\t\t\t\tflagErStatus = false;\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t});\r\n\t\tif(!flagErStatus){\r\n\t\t\treturn;\r\n\t\t}\r\n\t*/\r\n\tif(\"CSN\"== ownerCode || \"CKG\" == ownerCode || \"CSG\" == ownerCode || \"CSL\" == ownerCode){\r\n\t\tif(rplStrPart=='Y'){\r\n\t\t\tif(!confirm(\"涉及可更换结构件,步骤方案已留工作者填写位置？\")) {\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\t/*\r\n\t\tif(rplStrPart==\"\"){\r\n\t\t\tsrplStrPart=\"涉及可更换结构件未填写；\";\r\n\t\t\talert(srplStrPart);\r\n\t\t\treturn;  \r\n\t\t}\r\n\t\t*/\r\n\t\t\r\n\t\t/*已往新表FGM_SDRR插入记录\r\n\t\t//新建补充信息语句\r\n\t\tif(\r\n\t\t ((oldPse==\"\" || oldPse ==\"N\") && newPse==\"Y\") || \r\n\t\t ((oldFcs==\"\" || oldFcs ==\"N\") && newFcs==\"Y\") \r\n\t\t ){\r\n\t\t\tif(oldPse == 'Y' || oldFcs == 'Y'){\r\n\t\t\t\t //有一个Y不做任何操作\r\n\t\t\t}else{\r\n\t\t\t\turl = \"../ajax/addFgmPseFcs.jsp?jcRid=\"+jcRid+\"&curTpg=\"+$(\"#workgroupId\").val();\r\n\t\t\t\tjQuery.ajax({\r\n\t\t\t\t\ttype: \"post\",\r\n\t\t\t\t\tasync: false,\t//控制同步=false 异步=true\r\n\t\t\t\t\turl: url,\r\n\t\t\t\t\tcontentType: \"application/json; charset=gbk\",\r\n\t\t\t\t\tdataType: \"json\",\r\n\t\t\t\t\tcache: false,\r\n\t\t\t\t\tsuccess: function (data) {\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t}\r\n\t\t//删除补充信息语句\r\n\t\tif((oldPse==\"Y\" && newPse!=\"Y\" ) || (oldFcs==\"Y\" && newFcs !=\"Y\" )){\r\n\t\t\tif(newPse!=\"Y\" && newFcs !=\"Y\"){\r\n\t\t\t\turl = \"../ajax/deleteFgmPseFcs.jsp?jcRid=\"+jcRid;\r\n\t\t\t\tjQuery.ajax({\r\n\t\t\t\t\ttype: \"post\",\r\n\t\t\t\t\tasync: false,\t//控制同步=false 异步=true\r\n\t\t\t\t\turl: url,\r\n\t\t\t\t\tcontentType: \"application/json; charset=gbk\",\r\n\t\t\t\t\tdataType: \"json\",\r\n\t\t\t\t\tcache: false,\r\n\t\t\t\t\tsuccess: function (data) {\r\n\t\t\t\t\t\t//记录日志\r\n\t\t\t\t\t\turl = \"ajax/addFgmPseFcsLog.jsp?jcRid=\"+jcRid;\r\n\t\t\t\t\t\tjQuery.ajax({\r\n\t\t\t\t\t\t\ttype: \"post\",\r\n\t\t\t\t\t\t\tasync: false,\t//控制同步=false 异步=true\r\n\t\t\t\t\t\t\turl: url,\r\n\t\t\t\t\t\t\tcontentType: \"application/json; charset=gbk\",\r\n\t\t\t\t\t\t\tdataType: \"json\",\r\n\t\t\t\t\t\t\tcache: false,\r\n\t\t\t\t\t\t\tsuccess: function (data) {\r\n\t\t\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t});\r\n\t\t\t\t\t}\r\n\t\t\t\t\t\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t}\r\n\t\t*/\r\n\t}else{\r\n\t\t//非控制操作时，对客户代码不是“CSN”/“CSG”/“CSL”/“CKG”的飞机，“判断工程师”有值时，“判断日期”需要选择\r\n\t\tif(true && \"\"!=$.trim(engSign.val()) && \"\"== $.trim($(\"#engSignDate\").val())){\r\n\t\t\talert(\"请选择判断日期!\");\r\n\t\t\t$(\"#engSignDate\").focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\tif(stepArray.length>0)\r\n\t{\r\n\t\tif(registFedexRecAction()==false)\r\n\t\t{\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t\r\n\t// 工艺组不能为空\r\n\tif(workgroupObj.val() == \"\" || workgroupObj.val() == \"--\")\r\n\t{\r\n\t\talert(\"工艺组不能为空!\");\r\n\t\tworkgroupObj.focus();\r\n\t\treturn;\r\n\t}\r\n\t// 工卡类型不能为空\r\n\tif(jcType == \"\")\r\n\t{\r\n\t\talert(\"工卡类型不能为空!\");\r\n\t\treturn;\r\n\t}\r\n\t// 主工种不能为 -- (注：工卡站才必填)\r\n\tif(\"\"==wgp)\r\n\t{\r\n\t\tif(mainlabor.val() == \"--\")\r\n\t\t{\r\n\t\t\talert(\"主工种不能为 -- !\");\r\n\t\t\tmainlabor.focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t\r\n\t\r\n\t\t// 依据文件\r\n\t\tif(referenceDescObj.val()==\"\" && \"FEDEX\"!= ownerCode) {\r\n\t\t\talert(\"依据文件不能为空!\");\r\n\t\t\treferenceDescObj.focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t\tif(getStrLength(referenceDescObj,45,\"依据文件\")){\r\n\t\t\treturn;\r\n\t\t}\r\n\t\r\n\t\tvar referenceDesc = $.trim(referenceDescObj.val());\r\n\t\tif(!(referenceDesc.indexOf(\"R.\")>-1 || referenceDesc.indexOf(\"V.\")>-1 \r\n\t\t\t\t|| referenceDesc.indexOf(\"REV.\")>-1 || referenceDesc.indexOf(\"VERSION\")>-1)){//不含“R.”/“V.”/“REV.”/\"VERSION\"\r\n\t\t\tif(!confirm(\"请检查依据文件栏录入了版本号！\")){\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t\r\n\t\r\n\t// FGM_WO表NRC_VERSION字段值不为“V1”且“V2”时，五个选项不能为空，必须选Y或N\r\n\t/*\r\n\tif(nrc_version.toUpperCase()!= \"V1\"&&nrc_version.toUpperCase()!= \"V2\")\r\n\t{\r\n\t\tfor(key in mustInput)\r\n\t\t{\r\n\t\t\tif(mustInput[key] == \"\") \r\n\t\t\t{\r\n\t\t\t\talert(key+\"选项不能为空!\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t*/\r\n\t\r\n\t// 检查判断日期是否合法\r\n\t/*005245 保存和方案交互不需要限制工程师和判断日期 20190711 start\r\n\tif($.trim(engSign.val())!=\"\" && !checkSignDate())\r\n\t{\r\n\t\treturn;\r\n\t}\r\n\t005245 保存和方案交互不需要限制工程师和判断日期 20190711 end*/\r\n\t\r\n\t// Add by 700683 工卡管理增加客户化信息 2018-10-09 start\r\n\tif(ownerCode == \"LHT\"||ownerCode == \"DLH\") {\r\n\t\tif(wgp == \"\" && $.trim(lhtWpNo) == \"\") {\r\n\t\t\talert(\"LHT/DLH WP NO.值不可为空！\");\r\n\t\t\t$(\"#lhtWpNo\").focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t\tif (wgp == \"PP\") {\r\n\t\t\tif (getStrGbLen(lhtRefNo) > 60) {\r\n\t\t\t\talert(\"LHT/DLH REF NO.值不可超过60个字符！\");\r\n\t\t\t\t$(\"#lhtRefNo\").select();\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\tif (getStrGbLen(lhtCriNo) > 60) {\r\n\t\t\t\talert(\"LHT/DLH CRI NO.值不可超过60个字符！\");\r\n\t\t\t\t$(\"#lhtCriNo\").select();\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t// Add by 700683 工卡管理增加客户化信息 2018-10-09 end\r\n\t// 验证步骤内容\r\n\tif(!checkStpText())\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\t// SDRR增删判断(南航和重航)\r\n\tif(\"CSN\" == ownerCode || \"CKG\" == ownerCode || \"CSG\" == ownerCode || \"CSL\" == ownerCode){\r\n\t\t\r\n\t\t// “重要结构件” 判断为“Y”，且MNE_NRC_MASTER表的CORROSION字段为“Y”时 增加SDRR\r\n\t\t/* if(\"Y\" == pse && \"Y\" == corrosion){\r\n\t\t\tsdrrFlag = true;\r\n\t\t} */\r\n\t\t// “重要结构件” 判断从“Y”更改为“N”时 删除SDRR\r\n\t\t/* else if(\"N\" == pse && \"Y\" == oldPse){\r\n\t\t\tsdrrFlag = false;\r\n\t\t} */\r\n\t\tif(\"Y\"==newPse || \"Y\"==newFcs || \"Y\"==newStrRepair){\r\n\t\t//if(\"Y\"==newPse || \"Y\"==newFcs){\r\n\t\t\tsdrrFlag = true;\r\n\t\t}else{\r\n\t\t\tsdrrFlag = false;\r\n\t\t}\r\n\t}\r\n\t// Add by 700683 超规范方案接收日期及超期原因记录功能 2018-07-09 start\r\n\tif (!checkEngRsnValue()) {\r\n\t\treturn;\r\n\t}\r\n\t// Add by 700683 超规范方案接收日期及超期原因记录功能 2018-07-09 end\r\n\t\r\n\t//检查超规范锁定步骤\r\n\tif(\"N\" == $(\"#outOfManual\").val()){\r\n\t\tvar checkIsLockResult = getRequest(\"/trace/fgm/fgm.do?method=checkHasLockStep\",\r\n\t\t\t\t'{\"jcRid\":\"' +  $(\"#primaryJCId\").val() + '\", \"txtMenuID\":\"' + $(\"#txtMenuID\").val() + '\"}');\r\n\t\tif(false == checkIsLockResult){\r\n\t\t\treturn;\r\n\t\t}\r\n\t\tif(checkIsLockResult.flag){\r\n\t\t\talert(\"请先解除超规范锁定的步骤！\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t//汉莎\r\n\tif(\"DLH\" == ownerCode){\r\n\t\t//参考文件ATA号\r\n\t\tif(\"\" != $.trim($(\"#slnAtaNo\").val()) && 6 != $.trim($(\"#slnAtaNo\").val()).length){\r\n\t\t\talert(\"参考文件ATA号未填写完整!\");\r\n\t\t\t$.each($(\"input[id^='slnAtaNo'][type='text']\"), function(i, n){\r\n\t\t\t\tif(2 != $.trim($(n).val()).length){\r\n\t\t\t\t\t$(n).focus();\r\n\t\t\t\t\treturn false;\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t\treturn;\r\n\t\t}\r\n\t\tvar reg = /\\d{6}$/;\r\n\t\tif(\"\" != $.trim($(\"#slnAtaNo\").val()) && !reg.test($.trim($(\"#slnAtaNo\").val()))){\r\n\t\t\talert(\"参考文件ATA号非数字输入!\");\r\n\t\t\t$.each($(\"input[id^='slnAtaNo'][type='text']\"), function(i, n){\r\n\t\t\t\tif(!/\\d{2}$/.test($.trim($(n).val()))){\r\n\t\t\t\t\t$(n).focus();\r\n\t\t\t\t\treturn false;\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t\treturn;\r\n\t\t}\r\n\t\tif(\"Y\" == $(\"#flagHci\").val()){\r\n\t\t\t// ACTION\r\n\t\t\tvar dlhAction = \"\";\r\n\t\t\t$.each($(\".dlhAction:checked\"), function(i, n){\r\n\t\t\t\tif(0 != i){\r\n\t\t\t\t\tdlhAction += \",\";\r\n\t\t\t\t}\r\n\t\t\t\tdlhAction += $(n).val();\r\n\t\t\t});\r\n\t\t\t$(\"#dlhAction\").val(dlhAction);\r\n\t\t}else{\r\n\t\t\t// 清除所有值\r\n\t\t\t$(\".hciTr\").find(\"select\").val(\"\");\r\n\t\t\t$(\".hciTr\").find(\"input[type='hidden']\").val(\"\");\r\n\t\t}\r\n\t}\r\n\t\r\n\tvar stepTr;\r\n\tvar descCn = \"\";\r\n\tvar descEn = \"\";\r\n\tvar step = \"\";\r\n\tvar comma = \"\";\r\n\t\r\n\tif(false){\r\n\t\tfor(var i = 0;i < stepArray.length;i++){\r\n\t\t\t\r\n\t\t\tstepTr = $(stepArray[i]).parent();\r\n\t\t\tdescCn = stepTr.find(\"input[name='stepDesc']\").attr(\"value\");\r\n\t\t\tdescEn = stepTr.find(\"input[name='stepEnDesc']\").attr(\"value\");\r\n\t\t\t// update by 700683 2018-12-05 start\r\n\t\t\t//if(descCn.lastIndexOf(\"____\") != -1 || descEn.lastIndexOf(\"____\") != -1){\r\n\t\t\tif(descCn.lastIndexOf(\"____\") != -1 || descEn.lastIndexOf(\"____\") != -1 || descCn.lastIndexOf(\":  \") != -1\r\n\t\t\t\t\t|| descEn.lastIndexOf(\": \") != -1 || descCn.lastIndexOf(\"：  \") != -1 || descEn.lastIndexOf(\"：  \") != -1) {\r\n\t\t\t// update by 700683 2018-12-05 end\r\n\t\t\t\tstep += comma + (i+1);\r\n\t\t\t\tcomma = \" \";\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\tif(step.length != 0){\r\n\t\t\talert(\"第\"+step+\"步,如果要求工作者填写测量值,请在测量值按钮功能里填写.\");\r\n\t\t}\r\n\t\r\n\t\t//如果是电子签飞机，英文步骤含有“TEST”/“CHECK”/“INSPECT”/“MEASURE”之一时，按参考语句判断是否有记录，如没有记录，提示“请提供结果或数据填写栏！”，但不限制保存\r\n\t\tvar stepEnDescArr = $(\"input[name=stepEnDesc]\");\r\n\t\tvar stepRidArr = $(\"input[name=primary]\");\r\n\t\tvar stepEnDesc;\r\n\t\tvar stepRids = \"\";\r\n\t\tstepEnDescArr.each(function(i,n){\r\n\t\t\tstepEnDesc = $.trim($(n).val());\r\n\t\t\tif(stepEnDesc.indexOf(\"TEST\")!=-1 || stepEnDesc.indexOf(\"CHECK\")!=-1 || stepEnDesc.indexOf(\"INSPECT\")!=-1 || stepEnDesc.indexOf(\"MEASURE\")!=-1){\r\n\t\t\t\tif(\"\" != stepRidArr.eq(i).val()){\r\n\t\t\t\t\tstepRids += stepRidArr.eq(i).val();\r\n\t\t\t\t\tif(i<stepEnDescArr.length-1){\r\n\t\t\t\t\t\tstepRids += \",\";\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\r\n\t\tvar strStepRidArr = stepRids.split(\",\");\r\n\t\tstepRids = \"\";\r\n\t\t for(var i=0; i<strStepRidArr.length; i++){\r\n\t\t\tif(\"\"!=strStepRidArr[i]){\r\n\t\t\t\tif(\"\"!=stepRids){\r\n\t\t\t\t\tstepRids += \",\";\r\n\t\t\t\t}\r\n\t\t\t\tstepRids += strStepRidArr[i];\r\n\t\t\t}\r\n\t\t}\r\n\t\tif(\"\" != stepRids){\r\n\t\t\tvar checkResult;\r\n\t\t\t$.ajax({\r\n\t\t\t\turl: \"/trace/fgm/fgm.do?method=checkSetpHasMv\",\r\n\t\t\t\ttype: 'post',\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata: {\"stepRids\":stepRids,\"txtMenuID\":$(\"#txtMenuID\").val()},\r\n\t\t\t\tdataType: 'json',\r\n\t\t\t\tcontentType: 'application/x-www-form-urlencoded;charset=utf-8',\r\n\t\t\t\tsuccess: function(data) {\r\n\t\t\t\t\tcheckResult = data;\r\n\t\t\t\t},\r\n\t\t\t\terror: function() {\r\n\t\t\t\t\talert(\"系统异常,操作失败!\");\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t\tif(!checkResult.flag){\r\n\t\t\t\talert(\"请提供结果或数据填写栏！\");\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\r\n\t// 打印状态\r\n\tvar getNrcHdPrtStatusResult = getNrcHdPrtStatus();\r\n\tif(1 == getNrcHdPrtStatusResult){\r\n\t\tif(\"CSN\"==ownerCode || \"CKG\"==ownerCode || \"CSG\"==ownerCode || \"CSL\"==ownerCode){\r\n\t\t\talert('独立页信息更新后请打印并交接！');\r\n\t\t}else{\r\n\t\t\talert('首页信息更新后请打印并交接！');\r\n\t\t}\r\n\t}else if(-1 == getNrcHdPrtStatusResult){\r\n\t\treturn;\r\n\t}\r\n\r\n\t// 选择所有具有指定名称的元素\r\n\tvar cn = $('[name=\"stepDesc\"]').toArray();\r\n\tvar en = $('[name=\"stepEnDesc\"]');\r\n\r\n\t// 对每个匹配到的元素执行操作\r\n\r\n\tfor (var i = 0; i < cn.length; i++) {\r\n\t\tvar elementCn = $(cn[i]);\r\n\t\tvar elementEn = $(en[i]);\r\n\t\tvar valueCn=decodeEntities(elementCn.val());\r\n\t\tvar valueEn=decodeEntities(elementEn.val());\r\n\t\telementCn.attr(\"value\",valueCn); // 设置元素的值\r\n\t\telementEn.attr(\"value\",valueEn); // 设置元素的值\r\n\t}\r\n\r\n\t$(\"[name='flagEr']\").removeAttr(\"disabled\");\r\n\t//在最后提交的时候解除不可选 防止数据置为null\r\n\t$(\"#fedexCheck\").find('input[type=checkbox]').attr('disabled', false);\r\n\t$(\"#sdrTrNo\").attr('disabled', false);\r\n\tvar dateFlag = true;\r\n\t\r\n\t__CP_SET_URL_ATT__(document.form,'action', \"updateJCSTP.jsp?sdrrFlag=\"+sdrrFlag+\"&flag41=\"+dateFlag);\r\n\tdocument.form.submit();\r\n\t__CP_SET_URL_ATT__(document.form,'action', \"\");\r\n\t$(\":button\").attr(\"disabled\",\"disabled\");\r\n}\r\n\r\nfunction decodeEntities(encodedString) {\r\n\tvar textarea = document.createElement('textarea');\r\n\t__CP_SET_HTML_ATT__(textarea,'innerHTML', encodedString);\r\n\treturn textarea.value;\r\n}\r\n\r\nfunction checkFedexOptions(){\r\n\tvar FunctionalCheckboxYes=  $(\"input[name='FunctionalCheckboxYes']\").attr(\"checked\");\r\n\tvar FunctionalCheckboxNo=  $(\"input[name='FunctionalCheckboxNo']\").attr(\"checked\");\r\n\tif(FunctionalCheckboxYes && FunctionalCheckboxNo){\t//同时选中像个数据\r\n\t\talert(\"Functional Check Req\t不可同时选中\")\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tvar RepairTypeCheckboxMinor=  $(\"input[name='RepairCheckboxMinor']\").attr(\"checked\");\r\n\tvar RepairCheckboxMajor=  $(\"input[name='RepairCheckboxMajor']\").attr(\"checked\");\r\n\tif(RepairTypeCheckboxMinor && RepairCheckboxMajor){\t//同时选中像个数据\r\n\t\talert(\"Repair Type 不可同时选中\")\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tvar MajorCheckboxYes=  $(\"input[name='MajorCheckboxYes']\").attr(\"checked\");\r\n\tvar MajorCheckboxNo=  $(\"input[name='MajorCheckboxNo']\").attr(\"checked\");\r\n\tif(MajorCheckboxYes && MajorCheckboxNo){\t//同时选中像个数据\r\n\t\talert(\"Major Alteration 不可同时选中\")\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tvar SSICheckboxYes=  $(\"input[name='SSICheckboxYes']\").attr(\"checked\");\r\n\tvar SSICheckboxNo=  $(\"input[name='SSICheckboxNo']\").attr(\"checked\");\r\n\tif(SSICheckboxYes && SSICheckboxNo){\t//同时选中像个数据\r\n\t\talert(\"SSI 不可同时选中\")\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tvar ReportableCheckboxYes=  $(\"input[name='ReportableCheckboxYes']\").attr(\"checked\");\r\n\tvar ReportableCheckboxNo=  $(\"input[name='ReportableCheckboxNo']\").attr(\"checked\");\r\n\tif(ReportableCheckboxYes && ReportableCheckboxNo){\t//同时选中像个数据\r\n\t\talert(\"Reportable Discrepancy\t 不可同时选中\")\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tvar SDRCheckboxYes=  $(\"input[name='SDRCheckboxYes']\").attr(\"checked\");\r\n\tvar SDRCheckboxNo=  $(\"input[name='SDRCheckboxNo']\").attr(\"checked\");\r\n\tif(SDRCheckboxYes && SDRCheckboxNo){\t//同时选中像个数据\r\n\t\talert(\"SDR 不可同时选中\")\r\n\t\treturn false;\r\n\t}\r\n\treturn true;\t\r\n}\r\n\r\n// 验证步骤内容\r\nfunction checkStpText()\r\n{\r\n\tvar jcSiteObj = $(\"#jcSiteId\");\t\t\t\t\t// 工作场所对象\r\n\tvar jcModeCheckObj = $(\"input[name='jcMode']\");\t// 是否工卡中英文模式(中英文C,英文E)对象\r\n\tvar flagStepCtrl = 'Y';\t\t// 步骤控制标识\r\n\tvar stepArray = $(\".stepTdClass\");\t\t\t\t// 步骤对象集合\r\n\tvar flagHM = 'true';\t\t\t\t\t// 大修部门\r\n\tvar flagRob = 'false';\t\t\t\t\t// 判断是否串件卡\r\n\tvar strAcType = 'A380';\t\t\t\t// 工卡机型\r\n\t\r\n\t// 验证必填内容\r\n\tfor(var i=0;i<stepArray.length;i++)\r\n\t{\r\n\t\tvar tr1 = $(stepArray[i]).parent();\r\n\t\tvar tr2 = $(stepArray[i]).parent().next();\r\n\t\tvar stepDescObj = tr1.find(\".stepDescClass\");\t\t// 步骤描述(中文)对象\r\n\t\tvar stepEnDescObj = tr1.find(\".stepEnDescClass\");\t// 步骤描述(英文)对象\r\n\t\tvar schedPhaseObj = tr2.find(\".schedphaseClass\");\t// 阶段对象\r\n\t\tvar selectTradeObj = tr2.find(\".schedtradeClass\");\t// 工种对象\r\n\t\tvar selectAreaObj = tr2.find(\".areaClass\");\t\t\t// 区域对象\r\n\t\tvar labor = tr2.find(\"input[name='schedlabor']\").get(0);\t// 人力对象\r\n\t\tvar manhour = tr2.find(\"input[name='schedmh']\").get(0);\t\t// 停场时间对象\r\n\t\tvar meAvObj = tr2.find(\".meAvClass\");\t\t\t\t// 机电电子级别\r\n\r\n\t\tif(jcModeCheckObj.val() == \"C\") {\r\n\t\t\tif($.trim(stepDescObj.val()) == \"\"){\r\n\t\t\t\talert(\"步骤描述(中文) 不能为空!\");\r\n\t\t\t\tstepDescObj.focus();\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t\tif($.trim(stepEnDescObj.val()) == \"\"){\r\n\t\t\t\talert(\"步骤描述(英文) 不能为空!\");\r\n\t\t\t\tstepEnDescObj.focus();\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}else if(jcModeCheckObj.val() == \"E\"){\r\n\t\t\tif($.trim(stepEnDescObj.val()) == \"\"){\r\n\t\t\t\talert(\"步骤描述(英文) 不能为空!\");\r\n\t\t\t\tstepEnDescObj.focus();\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}else if(jcModeCheckObj.val() == \"H\"){\r\n\t\t\tif($.trim(stepDescObj.val()) == \"\"){\r\n\t\t\t\talert(\"步骤描述(中文) 不能为空!\");\r\n\t\t\t\tstepDescObj.focus();\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\t// 机库和按步骤控制才必选\r\n\t\tif(jcSiteObj.val()!=\"LM\" && flagStepCtrl==\"Y\" && $.trim(schedPhaseObj.val()) == \"--\" && strAcType!=\"ENG\") {\r\n\t\t\talert(\"阶段不能为 -- !\");\r\n\t\t\tschedPhaseObj.focus();\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\tif($.trim(selectTradeObj.val()) == \"--\") {\r\n\t\t\talert(\"工种不能为 -- !\");\r\n\t\t\tselectTradeObj.focus();\r\n\t\t\treturn false;\r\n\t\t} else {\r\n\t\t\t// 大修部门才需要校验\r\n\t\t\tif(flagHM==\"true\")\r\n\t\t\t{\r\n\t\t\t\t// 不是串件卡不允许选择机电\r\n\t\t\t\tif(flagRob==\"false\" && $.trim(selectTradeObj.val())==\"AIRP\")\r\n\t\t\t\t{\r\n\t\t\t\t\talert(\"不允许选择机电!\");\r\n\t\t\t\t\tselectTradeObj.focus();\r\n\t\t\t\t\treturn false;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t\t//验证人力是否合法\r\n\t\tif(checkText(labor))\r\n\t\t{\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\t//验证停场时间是否合法\r\n\t\tif(checkText(manhour))\r\n\t\t{\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\tif($.trim(selectAreaObj.val()) == \"--\")\r\n\t\t{\r\n\t\t\talert(\"区域不能为 -- !\");\r\n\t\t\tselectAreaObj.focus();\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\t\r\n\t\t// 电子签署工卡\r\n\t\t\r\n\t}\r\n\t\r\n\treturn true;\r\n}\r\n\r\n// 关闭窗口\r\nfunction closeWindow()\r\n{\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，是否确定退出？\");\r\n\t\tif(!save)\r\n\t\t{\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\tvar value = \"refurbish\";\r\n\twindow.opener.goAddAfter(value);\r\n\twindow.close();\r\n}\r\n\r\nfunction changeTheValue()\r\n{\r\n\tisChange = true;\r\n}\r\n\r\n// 删除步骤\r\nfunction removeStepTr(table_id,obj){\r\n\tvar tr2 = $(obj).parent().parent();\r\n\tvar tr1 = tr2.prev();\r\n\tvar tr3 = tr2.next();\r\n\tvar stepNum = tr1.find(\".stepTdClass\");\r\n\tvar stepRid = tr2.find(\".rid\");\r\n\tvar url = \"../ajax/checkWophsStpExist.jsp?stepRid=\"+stepRid.val();\r\n\tvar pass = true;\r\n\t// 检查计划是否已设置了当前步骤\r\n\tjQuery.ajax({\r\n\t  type: \"post\",\r\n\t  async: false,//控制同步=false 异步=true\r\n\t  url: url,\r\n\t  contentType: \"application/json; charset=gbk\",\r\n\t  dataType: \"json\",\r\n\t  cache: false,\r\n\t  success: function (data) {\r\n\t  \tif(data.flag == \"true\")\r\n\t  \t{\r\n\t  \t\tif(confirm(\"计划已设置该步骤执行天，确定删除执行天的设置?\"))\r\n\t\t\t{\r\n\t\t\t\tdelWophsStp(stepRid.val());\r\n\t\t\t}\r\n\t\t\telse\r\n\t\t\t{\r\n\t\t\t\tpass = false;\r\n\t\t\t}\r\n\t  \t }\r\n\t  },\r\n\t  error: function (err) {\r\n\t\talert(err);\r\n\t  }\r\n\t});\r\n\t\r\n\t// 检查步骤是否入卡\r\n\tif(\"\" != $.trim(stepRid.val())  &&  1 != isStepIn($.trim(stepNum.text()), $.trim(stepRid.val()))){\r\n\t\tpass = false;\r\n\t}\r\n\t\r\n\tif(pass && 'Y' == $(\"#indInsp\").val()){// 独立检验删除后续步骤\r\n\t\tpass = delIndInspAffterStep(tr2);\r\n\t}\r\n\t\r\n\tif(!pass){\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\t// 删除步骤\r\n\tremove(tr1, tr2, tr3);\r\n\t\r\n\t// 删除步骤后，重新设置步骤号\r\n\talterStep(stepNum.html(),\"subtract\");\r\n}\r\n\r\n// 正式删除行操作，并保存需要删除行的rid\r\nfunction remove(tr1, tr2, tr3) {\r\n\tchangeTheValue();\r\n\t\r\n\t// 获取该行的rid\r\n\tvar rid = tr2.find(\".rid\").val();\r\n\tvar delrid = $(\"#delridId\");\r\n\tvar delridValue = delrid.val();\r\n\t\r\n\t// 记录需要删除的ID到一个隐藏域\r\n\tif(rid != \"\" && delridValue != \"\")\r\n\t{\r\n\t\tdelrid.attr(\"value\",delridValue+\",\"+rid);\r\n\t}\r\n\telse if(rid != \"\" && delridValue == \"\")\r\n\t{\r\n\t\tdelrid.attr(\"value\",rid);\r\n\t}\r\n\t\r\n\ttr1.remove();\r\n\ttr2.remove();\r\n\ttr3.remove();\r\n}\r\n\r\n// 当值有所改变时，对应的工种行，会有所改变\r\nfunction changeHTML(changeObj,textClassName,inputClassName)\r\n{\r\n\tchangeJCStp(changeObj);\r\n\tvar stepArray = $(\".stepTdClass\");\r\n\tvar selectValue = $(changeObj).attr(\"value\");\r\n\tvar selectParentTdClassName = $(changeObj).parent().attr(\"class\");\r\n\tvar stepTd = getObj($(changeObj).parent().parent(),\"stepTdClass\",\"onward\");\r\n\tvar selectTrStep = stepTd.html();\r\n\t// 迭代步骤\r\n\tfor(var i = 0;i < stepArray.length;i++)\r\n\t{\r\n\t\tvar stepTd = $(stepArray[i]);\r\n\t\tvar temp1 = stepTd.html();\r\n\t\t// 步骤号相同\r\n\t\tif(selectTrStep == temp1)\r\n\t\t{\r\n\t\t\tvar tr = stepTd.parent();\r\n\t\t\tvar td = getObj(tr,selectParentTdClassName,\"countermarch\");\r\n\t\t\tvar label = td.children(\".\"+textClassName);\r\n\t\t\tvar input = td.children(\".\"+inputClassName);\r\n\t\t\tvar temp2 = label.html();\r\n\t\t\tif(temp2 != null)\r\n\t\t\t{\r\n\t\t\t\tlabel.html(selectValue);\r\n\t\t\t\tinput.attr(\"value\",selectValue);\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n\r\nfunction selectUser(obj)\r\n{\r\n\tvar input = $(obj);\r\n\tvar code = input.attr(\"value\");\r\n\tvar url = \"../ajax/selectUser.jsp?info=\"+code+\"&field=code&jsonpcallback=?\";\r\n\tvar showNameTd = input.parent().next();\r\n\r\n\t$.getJSON(url,{},function(data){\r\n\t\tif(data.code!=\"\")\r\n\t\t{\r\n\t\t\tinput.attr(\"value\",data.code+\" \"+data.name);\r\n\t\t}\r\n\t\tchangeJobCard();\r\n\t});\r\n}\r\n\r\n// 提交方案(操作：方案完成、交互方案、步骤提交/撤销)\r\n/** \r\n\taction:singlePlan=单步骤提交,rollbackPlan=单步骤撤销,complexPlan=所有步骤提交\r\n\tstepRid:步骤RID\r\n\ttype:\r\n\tstepNum:步骤序号\r\n\tfunc:0=完成提交、1=交互提交\r\n**/\r\nfunction submitPlan(action,stepRid,type,stepNum,func,eSignInfo,StepStatus)\r\n{\r\n\tif(StepStatus!='N' && StepStatus!=''){\r\n\t\talert(\"步骤已关闭，不允许修改！\")\r\n\t\treturn;\r\n\t}\r\n    if (\"rollbackPlan\"==action){\r\n        if (checkUsing(stepRid)){\r\n            return;\r\n        }\r\n    }\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn;\r\n\t}\r\n\t\r\n\tvar mainlabor = $(\"select[name='mainlabor']\");\t//\t主工种\r\n\tvar jcSite = $(\"#jcSiteId\");\t\t\t\t\t//\t工作场所\r\n\tvar rii = $(\"#riiId\");\t\t\t\t\t\t\t//\t必检\r\n\tvar boothObj = $(\"#boothId\");\t\t\t\t\t//\t工卡站\r\n\tvar jcwo = \"500007989096\";\t\t\t\t//\t工卡指令号\r\n\tvar workOrder = \"120000587070\";\t\t\t//\t指令号\r\n\tvar nrc_version = \"V3\";\t\t\t//\tNRC版本\r\n\tvar stepArray = $(\".rid\");\r\n\tvar slnStatus = \"T\";\t\t\t\t\t\t//\t方案状态Y/N/T\r\n\tvar printer = $(\"#printerId\");\t\t\t\t//\t打印机\r\n\tvar majorMdo=$(\"#majorMdo\");\t\t\t\t//\t重大修理/改装\r\n\tvar pse=$(\"#pse\");\t\t\t\t\t\t\t//\t重要结构件\r\n\tvar outOfManual = $(\"#outOfManual\");\t\t//\t超规范修理\r\n\tvar external=$(\"#external\");\t\t\t\t//\t外表修理\r\n\tvar authApp = $(\"#authApp\");\t\t\t\t//\t需要局方批准\r\n\tvar exteriorDamage = $(\"#exteriorDamage\");\t//\t外表损伤\r\n\tvar appRef = $(\"#appRef\");\t\t\t\t\t//\t局方批文号/CAAC批文号\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t//\t判断工程师\r\n\tvar stepStatus = $(\".stepStatus\");\t\t\t//\t步骤状态\r\n\tvar workType = $(\"#workType\");\t\t\t\t//\t工作类型\r\n\tvar mustInput = \"\";\r\n\tvar strRii = \"\";\t\t\t\t// RII\r\n\tvar dateFlag = true;\t\t\t\t\r\n\tvar url = \"\";\r\n\tvar pass = true;\r\n\t// add by 700683 非卡可打印标示-180508 2018-05-09 start\r\n\tvar jcRii = \"\";\r\n\tvar stpCnt = \"1\";\r\n\tvar stpRiiCnt = \"1\";\r\n\t// add by 700683 非卡可打印标示-180508 2018-05-09 end\r\n\t// ADD BY 700683 非卡打印功能的改进 2018-05-10 START\r\n\tvar flagEPrt = \"\";\r\n\tvar qcFiBy = \"\";\r\n\t// ADD BY 700683 非卡打印功能的改进 2018-05-10 END\r\n\t// Add by 700683 限制打印没有英文的非卡 2018-10-29 start\r\n\tvar strCheckLevel = \"3C\"; \t\t\t// 定检级别\r\n\tvar jcDescEn = $(\"input[name='jcendesc']\").val();\t// 工卡描述(英文)\r\n\t// Add by 700683 限制打印没有英文的非卡 2018-10-29 end\r\n\t\r\n\tvar strRepair=$(\"#strRepair\").val();\t\t//\t结构修理\r\n\tvar fcs=$(\"#fcs\").val();\t\t\t\t\t//\t疲劳关键结构件\r\n\tvar causeStrr=$(\"#causeStrr\").val();\t\t//\t结构维修起因\r\n\tvar rplStrPart=$(\"#rplStrPart\").val();\t\t//\t涉及可更换结构件\r\n\t\r\n    var\tsstrRepair=\"\"\r\n\tvar\tsfcs=\"\"\r\n\tvar\tscauseStrr=\"\"\r\n\tvar\tsexternal=\"\"\r\n\tvar\tsrplStrPart=\"\"\r\n\t\r\n\t\r\n\tvar insp_date = '2026-01-14';\t\r\n\tvar ownerCode = $.trim($(\"#ownerCodeId\").val());//\t客户代码\r\n\tvar engCustomer = \"\"; //发动机客户 \r\n\tvar ownerCustomer = \"\";\r\n\tvar tailno = \"A6-EUD\"; //飞机号 \r\n\tvar planStartDate = $.trim($(\"#planStartDateId\").val());//计划时间\r\n\tvar a = planStartDate >=\"2019-12-10\";//false <\r\n\tvar b = insp_date>=\"2019-12-10\";//false <\r\n\tvar printType1 = \"\";\r\n\r\n\t// QA写卡授权检查\r\n\tif(\"\" != wgp && 1 != checkQAAuth()){\r\n\t\treturn;\r\n\t}\r\n\tif(\"CSN\"== ownerCode || \"CKG\" == ownerCode|| \"CSN\" == engCustomer|| \"CKG\" == engCustomer || \"CSG\" == ownerCode|| \"CSG\" == engCustomer || \"CSL\" == ownerCode|| \"CSL\" == engCustomer){\r\n\t\tif(rplStrPart=='Y'){\r\n\t\t\tif(!confirm(\"涉及可更换结构件,步骤方案已留工作者填写位置？\")){\r\n\t\t\t\treturn;\r\n\t\t\t}\t\r\n\t\t\r\n\t\t}\r\n\t\t\r\n\t\tif(func == \"0\" && action==\"complexPlan\"){// 方案完成才校验\r\n\t\t\t\r\n\t\t \tif(strRepair == \"\"){\r\n\t\t\t\talert(\"结构修理未填写\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t \t\r\n\t\t\tif(fcs == \"\"){\r\n\t\t\t\talert(\"疲劳关键结构件未填写\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t \r\n\t\t\tif(causeStrr == \"\"){\r\n\t\t\t\talert(\"结构维修起因未填写\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\r\n\t\t\tif(external == \"\"){\r\n\t\t\t\talert(\"外表修理未填写\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\r\n\t\t\tif(rplStrPart == \"\"){\r\n\t\t\t\talert(\"涉及可更换结构件未填写\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\t\r\n\t\t\r\n\t\r\n\t\t\t\r\n\t\t/* if(func==\"0\"){\r\n\t\t\t  if(strRepair==\"\"||fcs==\"\"||causeStrr==\"\"||external==\"\"||rplStrPart==\"\"){\r\n\t\t\t\t\r\n\t\t\t\tif(strRepair==\"\"){\r\n\t\t\t\t\tsstrRepair=\"结构修理未填写；\";\r\n\t\t\t\t}\r\n\t\r\n\t\t\t\tif(fcs==\"\"){\r\n\t\t\t\t\tsfcs=\"疲劳关键结构件未填写；\";\r\n\t\t\t\t}\r\n\t\r\n\t\t\t\tif(causeStrr==\"\"){\r\n\t\t\t\t\tscauseStrr=\"结构维修起因未填写；\";\r\n\t\t\t\t}\r\n\t\r\n\t\t\t\tif(external==\"\"){\r\n\t\t\t\t\tsexternal=\"外表修理未填写；\";\r\n\t\t\t\t}\r\n\t\r\n\t\t\t\tif(rplStrPart==\"\"){\r\n\t\t\t\t\tsrplStrPart=\"涉及可更换结构件未填写；\";\r\n\t\t\t\t}\r\n\t\t\t\talert(sstrRepair+sfcs+scauseStrr+sexternal+srplStrPart);\r\n\t\t\t\treturn;\r\n\t\t\t }\r\n\t\t} */\r\n\t\t\r\n\t\t/*\r\n\t\tif(func==\"1\"){\r\n\t\t\tif(rplStrPart==\"\"){\r\n\t\t\t\tsrplStrPart=\"涉及可更换结构件未填写；\";\r\n\t\t\t\talert(srplStrPart);\r\n\t\t\t\treturn;  \r\n\t\t\t}\r\n\t\t}\r\n\t\t*/\r\n\t\t\r\n\t//Add 700824 防空停判断 statr\r\n\t}else if(\"CHH\" == ownerCode || \"chh\" == ownerCode ){\r\n\t\tif($(\"#strFlagFif\").val() == \"\"){\r\n\t\t\talert(\"请判断是否涉及防空停项目！\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t//Add 700824 防空停判断 end\r\n\t\r\n\tif(false){\r\n\t\t//if(\"rollbackPlan\"==action && \"\"!=eSignInfo && \"未签\"!=eSignInfo){\r\n\t\tif(\"rollbackPlan\"==action && (\"已签\"==eSignInfo || StepStatus!='N' )){\r\n\t\t\talert(\"步骤已签署,不允许撤销!\");\r\n\t\t\treturn false;\r\n\t\t}\r\n\t}\r\n\t\r\n\tvar strWorkGroupRii = $(\"#strWorkGroupRiiId\");\t//工作组rii\r\n\t\r\n\t\r\n\tmustInput = {\"重大修理/改装\":majorMdo.val(),\"重要结构件\":pse.val(),\"超规范修理\":outOfManual.val(),\r\n\t\t\t\t\t \"外表修理\":external.val(),\"外表损伤\":exteriorDamage.val()};\r\n\t\r\n\t\r\n\t// 工艺组不能为空\r\n\tif(workgroupObj.val() == \"\" || workgroupObj.val() == \"--\")\r\n\t{\r\n\t\talert(\"工艺组不能为空!\");\r\n\t\treturn;\r\n\t}\r\n\t// 工卡类型不能为空\r\n\tif(jcType == \"\")\r\n\t{\r\n\t\talert(\"工卡类型不能为空!\");\r\n\t\treturn;\r\n\t}\r\n\t// 主工种不能为 -- （注：工卡站才必填）\r\n\tif(\"\"==wgp)\r\n\t{\r\n\t\tif(mainlabor.val() == \"--\")\r\n\t\t{\r\n\t\t\talert(\"主工种不能为 -- !\");\r\n\t\t\tmainlabor.focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t//RII\r\n\t// update by 700683 RII功能验证修订 2018-11-12 start\r\n\t//if(rii.val()==\"\" && strWorkGroupRii.val()==\"Y\" && func*1==0 && action==\"complexPlan\" && jcSite.val()!=\"LM\" && boothObj.val()!=\"A\" && boothObj.val()!=\"MOCC\")\r\n\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 start\r\n\t/* if(rii.val()==\"\" && strWorkGroupRii.val()==\"Y\" && func*1==0 && action==\"complexPlan\" && jcSite.val()!=\"LM\"\r\n\t\t\t&& boothObj.val()!=\"A\" && boothObj.val()!=\"MOCC\" && strCheckLevel == \"2-LNEMNT\") */\r\n\t// update by 700683 打印限制 2018-11-28 start\r\n\t//if(rii.val()==\"\" && strWorkGroupRii.val()==\"Y\" && func*1==0 && action==\"complexPlan\" && boothObj.val()!=\"A\" && boothObj.val()!=\"MOCC\")\r\n\t// delete by 700683 RII为空时可以方案完成提交但限制打印功能 2018-12-05 start\r\n\t/* if(rii.val()==\"\" && func*1==0 && action==\"complexPlan\")\r\n\t// update by 700683 打印限制 2018-11-28 end\r\n\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 end\r\n\t// update by 700683 RII功能验证修订 2018-11-12 end\r\n\t{\r\n\t\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 start\r\n\t\t//alert(\"工卡RII不能为空，请联系检验员处理!\");\r\n\t\talert(\"请联系检验或兼职检验判断工卡RII属性！\");\r\n\t\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 end\r\n\t\trii.focus();\r\n\t\treturn;\r\n\t} */\r\n\t// delete by 700683 RII为空时可以方案完成提交但限制打印功能 2018-12-05 end\r\n\t//非卡依据文件栏的版本号提醒\r\n\tif(!false){\r\n\t\tvar referenceDesc = $.trim($(\"#referenceDesc\").val());\r\n\t\tif(!(referenceDesc.indexOf(\"R.\")>-1 || referenceDesc.indexOf(\"V.\")>-1 \r\n\t\t\t\t|| referenceDesc.indexOf(\"REV.\")>-1 || referenceDesc.indexOf(\"VERSION\")>-1)){//不含“R.”/“V.”/“REV.”/\"VERSION\"\r\n\t\t\tif(!confirm(\"请检查依据文件栏录入了版本号！\")){\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t//方案完成才验证结构信息栏\r\n\tif(func*1==0 && action==\"complexPlan\")\r\n\t{\r\n\t\t// add by 700683 非卡可打印标示-180508 2018-05-09 start\r\n\t\t/*\r\n\t\tif (jcRii == \"Y\" && stpRiiCnt == \"0\") {\r\n\t\t\talert(\"必检非卡的所有步骤均为非必检，不允许标注方案完成！\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t*/\r\n\t\tif (stpCnt*1 == 0) {\r\n\t\t\talert(\"工卡没有步骤信息，不允许标注方案完成！\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t// add by 700683 非卡可打印标示-180508 2018-05-09 end\r\n\t\t\r\n\t\t//超规范修理非卡完成方案时不允许“批文号”栏留空或“N/A”\r\n\t\tif(\"Y\" == outOfManual.val()){\r\n\t\t\tif(\"\" == $.trim(appRef.val())){\r\n\t\t\t\talert(\"超规范修理完成方案时不允许“批文号”栏留空！\");\r\n\t\t\t\tappRef.focus();\r\n\t\t\t\treturn;\r\n\t\t\t}else if(\"N/A\" == $.trim(appRef.val())){\r\n\t\t\t\talert(\"超规范修理完成方案时不允许“批文号”栏为“N/A”！\");\r\n\t\t\t\tappRef.focus();\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\t// 不是Fedex的卡才需要验证结构信息栏\r\n\t\tif(ownerCode!=\"FEDEX\")\r\n\t\t{\r\n\t\t\t// FGM_WO表NRC_VERSION字段值不为“V1”且“V2”时，五个选项不能为空，必须选Y或N\r\n\t\t\tif(nrc_version.toUpperCase()!= \"V1\"&&nrc_version.toUpperCase()!= \"V2\")\r\n\t\t\t{\r\n\t\t\t\tfor(key in mustInput)\r\n\t\t\t\t{\r\n\t\t\t\t\tif(mustInput[key] == \"\") \r\n\t\t\t\t\t{\r\n\t\t\t\t\t\talert(key+\"选项不能为空!\");\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t}\r\n\t\tif(ownerCode==\"AAR\")\r\n\t\t{\r\n\t\t\tif(workType.val()==\"\")\r\n\t\t\t{\r\n\t\t\t\talert(\"请选择WORK TYPE!\");\r\n\t\t\t\tworkType.focus();\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t\t// 检查判断日期是否合法\r\n\t\tif($.trim(engSign.val())!=\"\" && !checkSignDate())\r\n\t\t{\r\n\t\t\treturn;\r\n\t\t}\r\n\t\tif(/^(CS(N|G|L))|(CKG)$/.test(ownerCode) || /^(CS(N|G|L))|(CKG)$/.test(engCustomer)){// CSN、CSG、CSL、CKG\r\n\t\t\t// 发动机序号\r\n\t\t\tif($(\"#engPn\").length && $(\"#engPn\").val() && !$(\"#engSn\").val()){\r\n\t\t\t\talert(\"发动机序号未填写!\");\r\n\t\t\t\t$(\"#engSn\").focus();\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t// 部件序号\r\n\t\t\tif($(\"#partNo\").length && $(\"#partNo\").val() && !$(\"#partSn\").val()){\r\n\t\t\t\talert(\"部件序号未填写!\");\r\n\t\t\t\t$(\"#partSn\").focus();\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t// 可更换结构件\r\n\t\t\tif($(\"#rsc\").length){\r\n\t\t\t\tif('Y' == $(\"#rsc\").val()){\r\n\t\t\t\t\tif(!$(\"#rscPn\").val()){//RSC件号\r\n\t\t\t\t\t\talert(\"RSC件号未填写!\");\r\n\t\t\t\t\t\t$(\"#rscPn\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t\tif(!$(\"#rscSn\").val()){//RSC序号\r\n\t\t\t\t\t\talert(\"RSC序号未填写!\");\r\n\t\t\t\t\t\t$(\"#rscSn\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t}else if(!$(\"#rsc\").val()){\r\n\t\t\t\t\talert(\"可更换结构件未选择!\");\r\n\t\t\t\t\t$(\"#rplStrPart\").focus();\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t// 结构修理附加任务\r\n\t\t\tif($(\"#srst\").length){\r\n\t\t\t\tif('Y' == $(\"#srst\").val()){\r\n\t\t\t\t\tif(!$(\"#srstNo\").val()){//RSC件号\r\n\t\t\t\t\t\talert(\"结构修理附加任务号未填写!\");\r\n\t\t\t\t\t\t$(\"#srstNo\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t}else if(!$(\"#srst\").val()){\r\n\t\t\t\t\talert(\"结构修理附加任务未选择!\");\r\n\t\t\t\t\t$(\"#srst\").focus();\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t\r\n\t//\t是否有步骤内容\r\n\tif(stepArray.length==0)\r\n\t{\r\n\t\talert(\"没有步骤需要提交!\");\r\n\t\treturn;\r\n\t}\r\n\t\r\n\t// 验证步骤内容(撤销操作不作验证)\r\n\tif(action!=\"rollbackPlan\"){\r\n\t\tif(!checkStpText())\r\n\t\t{\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t\r\n\t\t// Add by 700683 超规范方案接收日期及超期原因记录功能 2018-07-09 start\r\n\t\tif (!checkEngRsnValue()) {\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t// Add by 700683 超规范方案接收日期及超期原因记录功能 2018-07-09 end\r\n\t} else {\r\n\t\t//撤销步骤,验证是否已经完成签署,完成签署不允许撤销\r\n\t\t$.ajax({\r\n\t\t\turl: '/trace/fgm/fgmEsign.do?method=checkStepIsSign&stepRid=' + stepRid,\r\n\t\t\ttype: 'post',\r\n\t\t\tasync: false,\r\n\t\t\tdataType: 'json',\r\n\t\t\tcontentType: 'application/x-www-form-urlencoded;charset=utf-8',\r\n\t\t\tsuccess: function(data) {\r\n\t\t\t\tif(\"Y\" == data.sign){\r\n\t\t\t\t\talert(\"工作者已经完成签署,不允许撤销!\");\r\n\t\t\t\t\tpass = false;\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t},\r\n\t\t\terror: function() {\r\n\t\t\t\talert(\"系统异常,操作失败!\");\r\n\t\t\t\tpass = false;\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t});\r\n\t\tif(!pass){\r\n\t\t\treturn;\r\n\t\t}\r\n\t}\r\n\t\r\n\tif(action==\"complexPlan\")\r\n\t{\r\n\t\t// 是否存在必检步骤\r\n\t\tif(true && dateFlag && true && ownerCode != \"FEDEX\" && $(\"#riiFlag\").val().length == 0) {\r\n\t\t\turl = \"../ajax/checkNriiReview.jsp?jcRid=\"+jcRid+\"&ownerCode=\"+ownerCode+\"&dateFlag=\"+dateFlag+\"&flagHM=\"+true+\"&isLmJc\"+false;\r\n\t\t\t// 检查计划是否已设置了当前步骤\r\n\t\t\tjQuery.ajax({\r\n\t\t\t\ttype: \"post\",\r\n\t\t\t\tasync: false,//控制同步=false 异步=true\r\n\t\t\t\turl: url,\r\n\t\t\t\tcontentType: \"application/json; charset=gbk\",\r\n\t\t\t\tdataType: \"json\",\r\n\t\t\t\tcache: false,\r\n\t\t\t\tsuccess: function (data) {\r\n\t\t\t  \tif(data.flag == \"true\") {\r\n\t\t\t  \t\tpass = false;\r\n\t\t\t  \t}\r\n\t\t\t  },\r\n\t\t\t  error: function (err) {\r\n\t\t\t\t  alert(err);\r\n\t\t\t  }\r\n\t\t\t});\r\n\t\t}\r\n\t\tif(!pass) {\r\n\t\t\talert(\"非必检卡是否存在必检步骤？\");\r\n\t\t\t$(\"#riiFlag\").focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t\r\n\t\t//检查超规范锁定步骤\r\n\t\tif(\"N\" == outOfManual.val()){\r\n\t\t\tvar checkIsLockResult = getRequest(\"/trace/fgm/fgm.do?method=checkHasLockStep\",\r\n\t\t\t\t\t'{\"jcRid\":\"' +  $(\"#primaryJCId\").val() + '\", \"txtMenuID\":\"' + $(\"#txtMenuID\").val() + '\"}');\r\n\t\t\tif(false == checkIsLockResult){\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\tif(checkIsLockResult.flag){\r\n\t\t\t\talert(\"请先解除超规范锁定的步骤！\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\t//\t方案完成\r\n\t\tif(func == \"0\")\r\n\t\t{\r\n\t\t\t// 限制打印没有英文的非卡\r\n\t\t\tif (strCheckLevel != \"2-LNEMNT\" && $.trim(jcDescEn) == \"\") {\r\n\t\t\t\tif(jcMode!=\"H\") {\r\n\t\t\t\t\talert(\"非卡英文描述未填写！\");\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t// 登记FEDEX的解决措施\r\n\t\t\tif(registFedexRecAction()==false) {\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\tif(engSign.val()==\"\") {\r\n\t\t\t\talert(\"判断工程师不能为空!\");\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\tif(\"FEDEX\"==ownerCode){\r\n\t\t\t\t//a. 如果是“FEDEX”客户飞机，在现有检查逻辑后增加检查“签封面工种”栏，如果为空，提示“请选择签封面工种”\r\n\t\t\t\t//b. 检查“FEDEX JPF”栏，如果值为“有”(“Y”)，同时步骤数为1，提示“有JPF页时不能只有一个步骤！”\r\n\t\t\t\t//fedex并且是电子签时,签封面工种必填\r\n\t\t\t\tvar nmfTrade = $.trim($(\"#nmfTrade\").val());\r\n\t\t\t\tif((\"\"==nmfTrade || \"--\"==nmfTrade) && false){\r\n\t\t\t\t\talert(\"请选择签封面工种\");\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\tif(\"Y\"==$.trim('')){\r\n\t\t\t\t\tvar stepRidCount = 0;\r\n\t\t\t\t\t$.each($(\"input[name='primary']\"),function(i,n){\r\n\t\t\t\t\t\tif(\"\" != n.value){\r\n\t\t\t\t\t\t\t++stepRidCount;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t});\r\n\t\t\t\t\tif(1==stepRidCount){\r\n\t\t\t\t\t\talert(\"有JPF页时不能只有一个步骤！\");\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t}\r\n\t\t\t//检查“FEDEX JPF”栏，如果值为“无”(“N”)，同时步骤数不为1，提示“无JPF页时只能有一个步骤！”\r\n\t\t\tif(\"N\"==$.trim('')){\r\n\t\t\t\tvar stepRidCount = 0;\r\n\t\t\t\t$.each($(\"input[name='primary']\"),function(i,n){\r\n\t\t\t\t\tif(\"\" != n.value){\r\n\t\t\t\t\t\t++stepRidCount;\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t\tif(1 != stepRidCount){\r\n\t\t\t\t\talert(\"无JPF页时只能有一个步骤！\");\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t//汉莎\r\n\t\t\tif(\"DLH\" == ownerCode){\r\n\t\t\t\tif(\"\"==$.trim($(\"#refType\").val())){\r\n\t\t\t\t\talert(\"请选择参考文件类型!\");\r\n\t\t\t\t\t$(\"#refType\").focus();\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\tif(\"\"==$.trim($(\"#slnAtaNo\").val())){\r\n\t\t\t\t\talert(\"请填写参考文件ATA号!\");\r\n\t\t\t\t\t$(\"#slnAtaNo\").focus();\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\tif(\"\"==$.trim($(\"#fedexRecAction\").val())){\r\n\t\t\t\t\talert(\"请填写推荐措施!\");\r\n\t\t\t\t\t$(\"#fedexRecAction\").focus();\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\tif(\"\" == $(\"#flagHci\").val()){\r\n\t\t\t\t\talert(\"请选择\\\"CABIN ITEM\\\"!\");\r\n\t\t\t\t\t$(\"#flagHci\").focus();\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}else if(\"Y\" == $(\"#flagHci\").val()){\r\n\t\t\t\t\tif(\"\" == $(\"#dlhCz\").val()){\r\n\t\t\t\t\t\talert(\"请选择\\\"CABIN ZONE\\\"!\");\r\n\t\t\t\t\t\t$(\"#dlhCz\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t\tif(\"\" == $(\"#dlhApa\").val()){\r\n\t\t\t\t\t\talert(\"请选择\\\"AFFECTED PARTS ASSEMBLY\\\"!\");\r\n\t\t\t\t\t\t$(\"#dlhApa\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t\tif(\"\" == $(\"#dlhLpl\").val()){\r\n\t\t\t\t\t\talert(\"请选择\\\"LOCATION PER LOPA\\\"!\");\r\n\t\t\t\t\t\t$(\"#dlhLpl\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t\tif(\"\" == $(\"#dlhAction\").val()){\r\n\t\t\t\t\t\talert(\"请勾选\\\"ACTION\\\"!\");\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t\tif(\"\" == $(\"#dlhTof\").val()){\r\n\t\t\t\t\t\talert(\"请选择\\\"Typ of Finding\\\"!\");\r\n\t\t\t\t\t\t$(\"#dlhTof\").focus();\r\n\t\t\t\t\t\treturn;\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t// 打印状态\r\n\t\t\tvar getNrcHdPrtStatusResult = getNrcHdPrtStatus();\r\n\t\t\tif(1 == getNrcHdPrtStatusResult){\r\n\t\t\t\tif(\"CSN\"==ownerCode || \"CKG\"==ownerCode || \"CSG\"==ownerCode || \"CSL\"==ownerCode){\r\n\t\t\t\t\talert('独立页信息更新后请打印并交接！');\r\n\t\t\t\t}else{\r\n\t\t\t\t\talert('首页信息更新后请打印并交接！');\r\n\t\t\t\t}\r\n\t\t\t}else if(-1 == getNrcHdPrtStatusResult){\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t// RII为空时可以方案完成提交但限制打印功能\r\n\t\t\tif(rii.val() != \"\") {\r\n\t\t\t\tif(printer.val() == \"\") {\r\n\t\t\t\t\talert(\"打印机不能为空!\");\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\tif(!confirm(\"打印到：\"+printer.val()+\"?\")) {\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\r\n\t\t\tif(\"CHH\" == ownerCode || \"chh\" == ownerCode ){\r\n\t\t\t\t//700824 add 防空停\r\n\t\t\t\tif(!confirm(\"是否已正确判断防空停?\")){\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t\r\n\t\t\tif(confirm(\"您是否确定该方案已全部完成?\")) {\r\n\t\t\t\tslnStatus = 'Y';\r\n\t\t\t} else {\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t// 当前非卡属于电子签 且“重大修理/改装”或“超规范修理”设置为“Y”时\r\n\t\t\tif(false && (\"Y\"==majorMdo.val() || \"Y\"== outOfManual.val()) && !confirm(\"请确认相关资料文件已上传并已设置为归档！\")){\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t\r\n\t\t}\r\n\t\t//\t方案交互\r\n\t\telse\r\n\t\t{\r\n\t\t\tif(confirm(\"您是否确定交互该方案?\")) {\r\n\t\t\t\tslnStatus = 'T';\r\n\t\t\t} else {\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t\r\n\tif(tailno == \"GAM-ENG\"){\r\n\t\townerCustomer = engCustomer;\r\n\t}else{\r\n\t\townerCustomer = ownerCode;\r\n\t}\r\n\t\r\n\tif(ownerCustomer==\"CSN\" || ownerCustomer==\"CKG\" || ownerCustomer==\"CSG\" || ownerCustomer==\"CSL\") {\r\n\t\tif((strCheckLevel != \"2-LNEMNT\" && a==true) || (strCheckLevel == \"2-LNEMNT\" && b==true)) {\t\r\n\t\t\tprintType1 = \"C2\";\r\n\t\t}\r\n\t} else if(ownerCustomer==\"FEDEX\"){\r\n\t\tprintType1 = \"FDXC\";//FEDEX工卡为FDXC\r\n\t}\r\n\t\r\n\tvar strRiiFlag = $(\"#riiFlag\").val();\r\n\tvar url = \"updatePlan.jsp?action=\"+action+\"&stepRid=\"+stepRid+\"&type=\"+type+\"&stepNum=\"+stepNum+\"&slnStatus=\"+slnStatus\r\n\t\t+\"&strRiiFlag=\"+strRiiFlag+\"&flag41=\"+dateFlag+\"&flagEPrt=\"+flagEPrt+\"&qcFiBy=\"+qcFiBy+\"&wgp=\"+wgp+\"&printType1=\"+printType1;\r\n\t__CP_SET_URL_ATT__(document.form,'action', url);\r\n\tdocument.form.submit();\r\n\t\r\n\t$(\":button\").attr(\"disabled\",\"disabled\");\r\n}\r\n\r\n//检验结构信息栏\r\nfunction checkStructInfo()\r\n{\r\n\tvar nrc_version = \"V3\";\r\n\tvar majorMdo=$(\"#majorMdo\");\t\t\t//\t重大修理/改装\r\n\tvar pse=$(\"#pse\");\t\t\t\t\t\t//\t重要结构件\r\n\tvar outOfManual = $(\"#outOfManual\");\t//\t超规范修理\r\n\tvar external=$(\"#external\");\t\t\t//\t外表修理\r\n\tvar authApp = $(\"#authApp\");\t\t\t//\t需要局方批准\r\n\tvar appRef = $(\"#appRef\");\t\t\t\t//\t局方批文号/CAAC批文号\r\n\tvar engSign = $(\"#engSign\");\t\t\t//\t判断工程师\r\n\tvar mustInput = {\"重大修理/改装\":majorMdo.val(),\"重要结构件\":pse.val(),\"超规范修理\":outOfManual.val(),\r\n\t\t\t\t\t \"外表修理\":external.val(),\"需要局方批准\":authApp.val()};\r\n\t\r\n\t// FGM_WO表NRC_VERSION字段值不为“V1”且“V2”时，五个选项不能为空，必须选Y或N\r\n\tif(nrc_version.toUpperCase()!= \"V1\"&&nrc_version.toUpperCase()!= \"V2\")\r\n\t{\r\n\t\tfor(key in mustInput)\r\n\t\t{\r\n\t\t\tif(mustInput[key] == \"\") \r\n\t\t\t{\r\n\t\t\t\talert(key+\"选项不能为空!\");\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t// 检查判断日期是否合法\r\n\tif($.trim(engSign.val())!=\"\" && !checkSignDate())\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n\t// 如果“超规范修理”为“Y”,“需要局方批准”必须选Y或N\r\n\tif(outOfManual.val()==\"Y\" && authApp.val()==\"\")\r\n\t{\r\n\t\talert(\"是否需要局方批准?\");\r\n\t\tauthApp.focus();\r\n\t\treturn false;\r\n\t}\r\n\t// 如果“需要局方批准”为“Y”,“局方批文号”不为空\r\n\tif(authApp.val()==\"Y\")\r\n\t{\r\n\t\tif(outOfManual.val()!=\"Y\")\r\n\t\t{\r\n\t\t\talert(\"需要局方批准为【Y】时，超规范修理须为【Y】!\");\r\n\t\t\toutOfManual.focus();\r\n\t\t\treturn false;\r\n\t\t}\r\n\t}\r\n\t\r\n\treturn true;\r\n}\r\n\r\n\r\nfunction matsImport()\r\n{\r\n\tvar station = \"CAN\";\r\n\tvar url = \"matsImport.jsp?strFlnum=\"+strFlnum+\"&strCheckLevel=\"+strCheckLevel+\"&jobcard=\"+jobcard+\"&ownerCode=\"+ownerCode+\r\n\t\t\t\"&jcSeqId=\"+jcSeq+\"&jcRid=\"+jcRid+\"&txtMenuID=\"+ $(\"#txtMenuID\").val()+\"&strWorkOrder=\"+ strWorkOrder+\"&station=\"+ station\r\n\t\t\t+\"&strJcWorkOrder=\"+strJcWorkOrder+\"&strJcStatus=\"+strJcStatus+\"&strWgpDesc=\"+getEncodeURI(strWgpDesc)+\"&strJcDesc=\"+getEncodeURI(strJcDesc)+\"&strJcDescEn=\"+getEncodeURI(strJcDescEn);\r\n\t__CP_FUNC_open__(window,url,\"_blank\");\r\n}\r\n//选择下拉菜单的值\r\nfunction selectAll_N()\r\n{\r\n\tvar insertSISUser = '005558 WU WEILING';\t\t\t//\t当前用户署名\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t\t//\t判断工程师署名\r\n\tvar majorMdo = $(\"#majorMdo\");\r\n\tvar pse = $(\"#pse\");\r\n\tvar outOfManual = $(\"#outOfManual\");\r\n\tvar external = $(\"#external\");\r\n\tvar authApp = $(\"#authApp\");\r\n\tvar exteriorDamageObj = $(\"#exteriorDamage\");\r\n\t\r\n\tvar\tstrRepair=$(\"#strRepair\");\r\n\tvar fcs = $(\"#fcs\");\r\n\tvar\tcauseStrr=$(\"#causeStrr\");\r\n\tvar\trplStrPart=$(\"#rplStrPart\");\r\n\t\r\n \t// 验证用户署名   \r\n \tif(!checkSISUseName())\r\n \t{\r\n \t\talert(\"您好!您的中文名或拼音名不完整，请联系人事部门在人事系统完善信息后方可编写!\");\r\n \t\treturn;\r\n \t}\r\n\tif(remindUser())\r\n\t{\r\n\t\tmajorMdo.attr(\"value\",\"N\");\r\n\t\tpse.attr(\"value\",\"N\");\r\n\t\toutOfManual.attr(\"value\",\"N\");\r\n\t\texternal.attr(\"value\",\"N\");\r\n\t\tauthApp.attr(\"value\",\"N\");\r\n\t\texteriorDamageObj.attr(\"value\",\"N\");\r\n\t\tengSign.attr(\"value\",insertSISUser);\r\n\t\tfcs.attr(\"value\",\"N\");\r\n\t\tstrRepair.attr(\"value\",\"N\");\r\n\t\tcauseStrr.attr(\"value\",\"NA\");\r\n\t\trplStrPart.attr(\"value\",\"N\");\r\n\t\t$(\"#engPn\").val(\"N/A\");\r\n\t\t$(\"#engSn\").val(\"N/A\");\r\n\t\t$(\"#partNo\").val(\"N/A\");\r\n\t\t$(\"#partSn\").val(\"N/A\");\r\n\t\t$(\"#rsc\").val(\"N\");\r\n\t\t$(\"#rscPn\").val(\"N/A\");\r\n\t\t$(\"#rscSn\").val(\"N/A\");\r\n\t\t$(\"#srst\").val(\"N\");\r\n\t\t$(\"#srstNo\").val(\"N/A\");\r\n\t\tchangeJobCard();\r\n\t}\r\n\t//changeRep();\r\n}\r\n\r\n\r\n\r\nfunction allCancel()\r\n{\r\n\t\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t\t//\t判断工程师署名\r\n\tvar majorMdo = $(\"#majorMdo\");\r\n\tvar pse = $(\"#pse\");\r\n\tvar outOfManual = $(\"#outOfManual\");\r\n\tvar external = $(\"#external\");\r\n\tvar authApp = $(\"#authApp\");\r\n\tvar engSignDate = $(\"#engSignDate\");\r\n\tvar exteriorDamageObj = $(\"#exteriorDamage\");\r\n\t\r\n\tvar strRepair = $(\"#strRepair\");\r\n\tvar fcs = $(\"#fcs\");\r\n\tvar causeStrr = $(\"#causeStrr\");\r\n\tvar rplStrPart = $(\"#rplStrPart\");\r\n\tmajorMdo.attr(\"value\",\"\");\r\n\tpse.attr(\"value\",\"\");\r\n\toutOfManual.attr(\"value\",\"\");\r\n\texternal.attr(\"value\",\"\");\r\n\tauthApp.attr(\"value\",\"\");\r\n\tengSign.attr(\"value\",\"\");\r\n\tengSignDate.attr(\"value\",\"\");\r\n\texteriorDamageObj.attr(\"value\",\"\");\r\n\tstrRepair.attr(\"value\",\"\");\r\n\tfcs.attr(\"value\",\"\");\r\n\tcauseStrr.attr(\"value\",\"\");\r\n\trplStrPart.attr(\"value\",\"\");\r\n\t$(\"#engPn\").val(\"\");\r\n\t$(\"#engSn\").val(\"\");\r\n\t$(\"#partNo\").val(\"\");\r\n\t$(\"#partSn\").val(\"\");\r\n\t$(\"#rsc\").val(\"\");\r\n\t$(\"#rscPn\").val(\"\");\r\n\t$(\"#rscSn\").val(\"\");\r\n\t$(\"#srst\").val(\"\");\r\n\t$(\"#srstNo\").val(\"\");\r\n\tchangeJobCard();\r\n}\r\n\r\n\r\n\r\n//取消下拉菜单的值\r\nfunction cancelAll_N()\r\n{\r\n\t\r\n\tvar insertSISUser = '005558 WU WEILING';\t\t\t\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t\t//\t判断工程师署名\r\n\tvar majorMdo = $(\"#majorMdo\");\r\n\tvar pse = $(\"#pse\");\r\n\tvar outOfManual = $(\"#outOfManual\");\r\n\tvar external = $(\"#external\");\r\n\tvar authApp = $(\"#authApp\");\r\n\tvar engSignDate = $(\"#engSignDate\");\r\n\tvar exteriorDamageObj = $(\"#exteriorDamage\");\r\n\t\r\n\tvar strRepair = $(\"#strRepair\");\r\n\tvar fcs = $(\"#fcs\");\r\n\tvar causeStrr = $(\"#causeStrr\");\r\n\tvar rplStrPart = $(\"#rplStrPart\");\r\n\tvar insp_date = '2026-01-14';\t\r\n\tvar strCheckLevel = \"3C\"; \r\n\tvar ownerCode = $.trim($(\"#ownerCodeId\").val());//\t客户代码\r\n\tvar planStartDate = $.trim($(\"#planStartDateId\").val());//计划时间\r\n/* \talert(\"insp_date开卡日期\"+insp_date);\r\n\t\r\n\talert(\"strCheckLevel定检级别\"+strCheckLevel);\r\n\talert(\"ownerCode客户代码\"+ownerCode); */\r\n\t//alert(\"planStartDate计划日期\"+planStartDate);\r\n\tvar a = planStartDate >=\"2019-12-10\";//false <\r\n\tvar b = insp_date>=\"2019-12-10\";//false <\r\n\tif(ownerCode==\"CSN\" || ownerCode==\"CKG\" || ownerCode==\"CSG\" || ownerCode==\"CSL\"){\r\n\t\tif((strCheckLevel != \"2-LNEMNT\" && a==true) || (strCheckLevel == \"2-LNEMNT\" && b==true))\r\n\t\t{\t\r\n\t\t\tif(confirm(\"判断后需要重新打印结构信息页\"))\r\n\t\t\t{\r\n\t\t\t\tallCancel();\r\n\t\t\t}\r\n\t\t}else{\r\n\t\t\tif(confirm(\"确定取消？\\r\\n如已打印的，请重新打印工卡首页!\"))\r\n\t\t\t{\r\n\t\t\t\tallCancel();\r\n\t\t\t}\r\n\t\t}\r\n\t}else{\r\n\t\tif(confirm(\"确定取消？\\r\\n如已打印的，请重新打印工卡首页!\"))\r\n\t\t{\r\n\t\t\tallCancel();\r\n\t\t}\r\n\t}\r\n\r\n}\r\n\r\nfunction changeState()\r\n{\r\n\tvar insertSISUser = '005558 WU WEILING';\t\t\t//\t当前用户署名\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t\t//\t判断工程师署名\r\n\t\r\n\tremindUser();\r\n\tengSign.attr(\"value\",insertSISUser);\r\n\tchangeJobCard();\r\n\t\r\n}\r\n\r\n\r\n\r\n//显示判断工程师名字 \r\nfunction remindUser()\r\n{\r\n\tvar insertSISUser = '005558 WU WEILING';\t//\t当前用户署名\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t//\t判断工程师署名\r\n\tvar flag = true;\r\n\t\r\n\t// 是否已提示过\r\n\tif(!hasTip)\r\n\t{\r\n\t\t// 原来工程师与当前工程师是否一致\r\n\t\tif($.trim(engSign.val())!=insertSISUser)\r\n\t\t{\r\n\t\t\tif(confirm(\"判断工程师:\"+insertSISUser))\r\n\t\t\t{\r\n\t\t\t\thasTip = true;\r\n\t\t\t}\r\n\t\t\telse\r\n\t\t\t{\r\n\t\t\t\tflag = false;\t\t\t\t\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t\r\n\tif(flag)\r\n\t\tchangeJobCard();\r\n\t\r\n\treturn flag;\r\n}\r\n//检查判断日期是否合法\r\nfunction checkSignDate()\r\n{\r\n\tvar flag = true;\r\n\tvar insp_date = '2026-01-14';\t\t\t// 开卡日期\r\n\tvar engSignDate=$(\"#engSignDate\").val();\t// 判断日期\r\n\tvar engSign=$(\"#engSign\").val();\t\t\t// 判断工程师\r\n\tvar today = (new Date()).Format(\"yyyy-MM-dd\");// 今天日期\r\n\t//alert(today);\r\n\tif(engSign!=\"\"&&engSignDate==\"\")\r\n\t{\r\n\t\talert(\"判断日期不能为空!\");\r\n\t\treturn false;\r\n\t}\r\n\tif(insp_date>engSignDate)\r\n\t{\r\n\t\talert(\"判断日期不能早于开卡日期!\\n\"+\"开卡日期:\"+insp_date+\"\\n判断日期:\"+engSignDate);\r\n\t\treturn false;\r\n\t}\r\n\tif(engSignDate>today)\r\n\t{\r\n\t\talert(\"判断日期不能晚于今天!\\n\"+\"今天日期:\"+today+\"\\n判断日期:\"+engSignDate);\r\n\t\treturn false;\r\n\t}\r\n\treturn flag;\r\n}\r\n//修改开卡人\r\nfunction editInspector()\r\n{\r\n\tvar inspector = $(\"#inspectorId\");\r\n\tif(confirm(\"确认将开卡人更改为当前登陆人[005558 WU WEILING]?\"))\r\n\t{\r\n\t\tinspector.attr(\"value\",\"005558 WU WEILING\");\r\n\t}\r\n}\r\n//编辑Fedex的解决措施\r\nfunction editFedexRecAction()\r\n{\r\n\tvar insertSISUser = '005558 WU WEILING';\t\t\t//\t当前用户署名\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t\t//\t判断工程师署名\r\n\tvar fedexRecActionObj = $(\"#fedexRecActionId\");\t\t//\tFedex工卡解决措施\r\n\tvar fedexJpfObj = $(\"#fedexJpfId\");\t\t\t\t\t//\t是否有JPF\r\n\t\r\n\t// 验证用户署名\r\n \tif(!checkSISUseName())\r\n \t{\r\n \t\talert(\"您好!您的中文名或拼音名不完整，请联系人事部门在人事系统完善信息后方可编写!\");\r\n \t\treturn;\r\n \t}\r\n\t\r\n\tif(!remindUser())\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tengSign.attr(\"value\",insertSISUser);\t\r\n\tfedexRecActionObj.removeAttr(\"readonly\");\r\n\t//fedexJpfObj.removeAttr(\"disabled\");\r\n\t\r\n\tchangeJobCard();\r\n}\r\n\r\n// 检查计划是否已设置了当前步骤\r\nfunction checkWophsStpExist(obj,stepRid)\r\n{\r\n\tvar workOrder = \"120000587070\";\t//\t销售指令号\r\n\tvar flag = false;\r\n\t//alert(workOrder);\r\n\t//alert(stepRid);\r\n\t\r\n\tvar url = \"../ajax/checkWophsStpExist.jsp?salesOrder=\"+workOrder+\"&stepRid=\"+stepRid;\r\n\t\r\n\tjQuery.ajax({\r\n\t  type: \"post\",\r\n\t  async: true,//控制同步=false 异步=true\r\n\t  url: url,\r\n\t  contentType: \"application/json; charset=gbk\",\r\n\t  dataType: \"json\",\r\n\t  cache: false,\r\n\t  success: function (data) {\r\n\t  \tif(data.flag == \"true\")\r\n\t  \t{\r\n\t  \t\tif(confirm(\"计划已设置该步骤执行天，确定删除执行天的设置?\"))\r\n\t\t\t{\r\n\t\t\t\tdelWophsStp(stepRid);\r\n\t\t\t}\r\n\t\t\telse\r\n\t\t\t{\r\n\t\t\t\t$(obj).get(0).selectedIndex = 0;\r\n\t\t\t}\r\n\t  \t }\r\n\t  },\r\n\t  error: function (err) {\r\n\t\talert(err);\r\n\t  }\r\n\t});\r\n}\r\n\r\n//弹出选择对话框\r\nvar eventObj = null;\r\nfunction showChangeModel(obj, model){\r\n\tif('more' == model && isChange){// 多步骤导入时检查页面是否修改\r\n\t\talert('请先保存当前修改！');\r\n\t\treturn false;\r\n\t}\r\n\teventObj = $(obj);\r\n\t//var lastTrackingNo = '';\r\n\t//var strJcWorkOrder = '500007989096';\r\n\t\r\n\tvar workOrderByLTN = '';\r\n\tvar addTable='<div class=\\\"uniq_win\\\"><br><table align=\\\"center\\\" valign=\\\"middle\\\">';\r\n\tvar addTr = '<tr><td><a href=\\\"#\\\" onclick=\\\"changeMoel(\\''+model+'\\',\\'1\\')\\\">使用模板导入</a></td></tr>';\r\n\taddTr += '<tr><td><a href=\\\"#\\\" onclick=\\\"changeMoel(\\''+model+'\\',\\'2\\')\\\">使用工作包工卡导入</a></td></tr>';\r\n\t\r\n\t//如果非卡对应的参考工卡记录有“上次保留跟踪号”\r\n\tif(workOrderByLTN != \"\"){\r\n\t\taddTr += '<tr><td><a href=\\\"#\\\" onclick=\\\"changeMoel(\\''+model+'\\',\\'3\\')\\\">使用保留工卡指令号'+workOrderByLTN+'导入</a></td></tr>';\r\n\t}\r\n\taddTable = addTable + addTr +'</table><br></div>';\r\n\tshowWin(addTable,\"请选择导入方式\",300);\r\n}\r\n\r\n\r\n\r\n// 参考文档\r\nfunction showAtt(stepRid,stepSeq)\r\n{\r\n\tif(stepRid.length == 0){\r\n\t\tstepRid = \"\";\t\r\n\t}\r\n\tvar qcFiBy = \"\";\r\n\tvar jobcard = $(\"#jobcardId\").val();\r\n\tvar jcWorkorder = $(\"input[name='jc_workorder']\").val();\r\n\tvar jcDesc = $(\"input[name='jcdesc']\").val();\r\n\tvar jcDescEn = $(\"input[name='jcendesc']\").val();\r\n\t\r\n\tif($.trim(jcDesc).length == 0)\r\n\t\tjcDesc = jcDescEn; \r\n\t\r\n\t\r\n\tvar url = \"esign/pic/nrcAttList.jsp?salesOrder=120000587070&jcRid=\"+jcRid+\"&jobcard=\"+jobcard+\"&jcWorkorder=\"+jcWorkorder+\"&stepRid=\"+stepRid+\"&stepSeq=\"+stepSeq+\"&wgp=\"+wgp+\"&qcFiBy=\"+qcFiBy;\r\n\t//var value = window.showModalDialog(url,\"\",\"dialogWidth:1024px;dialogHeight:700px;dialogTop:100px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tJqueryDialog.Open1(\"签署参考文档（非例卡）\",url,document.body.clientWidth-50,document.body.clientHeight-100);\r\n}\r\n\r\n// 步骤签署\r\nfunction showPic()\r\n{\r\n\t//return false;// 功能未上线\r\n\tvar url = \"esign/pic/nrcPicList.jsp?salesOrder=120000587070&jcRid=\"+jcRid;\r\n\t//var value = window.showModalDialog(url,\"\",\"dialogWidth:1240px;dialogHeight:400px;help:no;status:no;resizable:yes;toolbar:no;menubar:no\");\r\n\tvar value = __CP_FUNC_open__(window,url,\"\",\"width=1240px,height=400px,toolbar=no,menubar=no,scrollbars=yes,resizable=yes,status=no\");\r\n}\r\n/