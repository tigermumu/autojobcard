\"updatedBy\" value=\"005558 WU WEILING\"/>\r\n\t\t<input class=\"editorGrpClass\" type=\"hidden\" name=\"editorGrp\" value=\"3_CABIN_TPG\"/>\r\n\t\t<input class=\"hiddenStepClass\" type=\"hidden\" name=\"step\" value=\"1\"/>\r\n\t\t<input class=\"isupdClass\" type=\"hidden\" name=\"isupd\" value=\"false\"/>\r\n\t\t<input class=\"onlyUpdStepClass\" type=\"hidden\" name=\"onlyUpdStep\" value=\"false\"/>\r\n\t\t<input class=\"vidClass\" type=\"hidden\" name=\"stepVid\" value=\"5\"/>\r\n\t\t<input class=\"stepRiiClass\" type=\"hidden\" name=\"stepRii\" value=\"\"/>\r\n\t\t<input type=\"hidden\" name=\"taskDsc\" value=\"\"/>\r\n\t\t<input type=\"hidden\" class=\"qc1st\" value=\"\"/>\r\n\t\t<input type=\"hidden\" class=\"qc2nd\" value=\"\"/>\r\n\t</td>\r\n\t<td class=\"eSignTdClass\">\r\n\t\r\n\t</td>\r\n\t<td>\r\n\t</td>\r\n</tr>\r\n<tr align=\"center\" bgcolor=\"#FFFFFF\">\r\n\t<td align=\"right\" style=\"padding-right: 4px;\">进入燃油箱工作</td>\r\n\t<td>\r\n \t\t\r\n \t\t<select name=\"flagTank\" class=\"flagTank\" onchange=\"changeJCStp(this)\" style=\"width: 100%;\" >\r\n \t\t\t<option selected value=\"N\">N</option>\r\n \t\t\t<option  value=\"Y\">Y</option>\r\n \t\t</select>\r\n \t\t\t \t\t\r\n\t</td>\r\n\t<td colspan=\"12\"></td>\r\n</tr>\r\n\r\n</table>\r\n<table width=\"1150px\" border=\"0\" align=\"center\" cellpadding=\"2\" cellspacing=\"1\" bgcolor=\"#3366FF\">\r\n<tr bgcolor=\"#FFFFFF\"> \r\n\t<td align=\"center\">\r\n\t\t<input id=\"addTrButton2\" type=\"button\" value=\"添加步骤\" onclick=\"checkCurrentlyStep('jcTable','typeOfStep2',0)\" />\r\n\t\t&nbsp;\r\n\t\t<input type=\"text\" style=\"width:30px\" id=\"typeOfStep2\" />\r\n\t\t&nbsp;&nbsp;&nbsp;&nbsp;\r\n\t\t<input id=\"save2\" type=\"button\" value=\"保 存\" onclick=\"updateJCSTP()\" />\r\n\t\t&nbsp;&nbsp;&nbsp;&nbsp;\r\n\t\t<input id=\"\" type=\"button\" value=\"方案完成\" onclick=\"submitPlan('complexPlan','','M','0','0','','')\"  class=\"submitPlanClass\"/>\r\n\t\t&nbsp;&nbsp;&nbsp;&nbsp;\r\n\t\t<input id=\"\" type=\"button\" value=\"交互方案\" onclick=\"submitPlan('complexPlan','','M','0','1','','')\"  class=\"submitPlanClass\"/>\r\n\t\t&nbsp;&nbsp;&nbsp;&nbsp;\r\n\t\t<input id=\"\" type=\"button\" value=\"步骤批量处理\" onclick=\"stpBatchDeal()\"  class=\"submitPlanClass\"/>\r\n\t\t&nbsp;&nbsp;&nbsp;&nbsp;\r\n\t\t\r\n\t\t<input id=\"\" type=\"button\" value=\"返回\" onclick=\"goBack()\">\r\n\t</td>\r\n</tr>\r\n</table>\r\n<input type=\"hidden\" name=\"checkStepExist\" id=\"checkStepExist\" value=\"true\"/>\r\n<input type=\"hidden\" name=\"txtMenuID\" id=\"txtMenuID\" value=\"22800\"/>\r\n<input type=\"hidden\" name=\"nrcHdPrt\" id=\"nrcHdPrt\"/>\r\n</form>\r\n<script type=\"text/javascript\">\r\nvar BASE_URL = '/trace';// 其他js文件使用路径\r\n__CP_DOC_WRITE__(document,\"<div id=\\\"tooltip\\\" style=\\\"position:absolute;visibility:hidden; \"\r\n+\"padding:3px;border:1px solid #528AC6;\\;background-color:#ffdfd0; height: 19px; left: 77px; top: 96px\\\"></div>\"); \r\nvar isChange = false;\t//\t是否有修改\r\nvar hasTip = false;\t\t//\t是否有提示判断工程师署名\r\nvar tempId = \"\";\r\nvar tempResult = \"\";\r\nvar tempType = \"\";\r\nvar printer = \"\";\r\nvar oneTime = true;\t\t\t\t\t\t\t\t//\t添加步骤只提示一次用户名信息的标志\r\nvar msgObj = $(\"#txtMessageId\");\t\t\t\t//\t提示信息\r\nvar printed = $.trim($(\"#printedId\").val());\t//\t是否已打印机过的标识符\r\nvar addJC = $.trim($(\"#addJCId\").val());\t\t//\t添加工卡的标识符\r\nvar wgp = $.trim($(\"#wgpId\").val());\t\t\t//\t当前编写组\r\nvar workgroupObj = $(\"#workgroupId\");\t\t\t//\t工卡所属的编写组\r\nvar ownerCode = $.trim($(\"#ownerCodeId\").val());//\t客户代码\r\nvar woRid = $.trim($(\"#woRidId\").val());\t\t//\t工作包主键\r\nvar jcRid = $.trim($(\"#primaryJCId\").val());\t//\t工卡主键\r\nvar woStatus = $.trim($(\"#woStatusId\").val());\t//\t工作包状态\r\nvar jcStatus = $.trim($(\"#jcStatusId\").val());\t//\t工卡状态\r\nvar corrosion = $.trim($(\"#corrosionId\").val());//\t腐蚀\r\nvar jcType = $.trim($(\"#jcTypeId\").val());\t\t//\t工卡类型\r\nvar jobcard = $.trim($(\"#jobcardId\").val());\t//\t工卡号\r\nvar jcSeq = $.trim($(\"#jcSeqId\").val());\t\t//\t工卡序号\r\nvar strFlnum = $.trim($(\"#strFlnum\").val());\t//\t飞机号\r\nvar strCheckLevel = $.trim($(\"#strCheckLevel\").val());\t//\t定检级别\r\nvar strJcWorkOrder = $.trim($(\"#strJcWorkOrder\").val());\t//\t工卡指令号\r\nvar strWgpDesc = $.trim($(\"#strWgpDesc\").val());\t//\t工艺组\r\nvar strJcDesc = $.trim($(\"#strJcDesc\").val());\t//\t工卡描述中文\r\nvar strJcDescEn = $.trim($(\"#strJcDescEn\").val());\t//\t工卡描述英文\r\nvar strJcStatus = $.trim($(\"#strJcStatus\").val());\t//\t工卡状态\r\nvar strWorkOrder = $.trim($(\"#strWorkOrder\").val());\r\nvar im = $(\"#strRepair\").val();\t\t\t\t\t//\t结构修理\r\nvar jcMode = $(\"#jcMode\").val();\t\t\t\t//\t工卡中英文模式(H/C/E)\r\n\r\n// 在DOM加载完后运行\r\n$(document).ready(function(){\r\n\tvar scrollTop=\"0\";\r\n\tvar scrollLeft=\"0\";\r\n\twindow.scrollTo(scrollLeft, scrollTop);\r\n\t// 提示信息\r\n\tif($.trim(msgObj.val())!=\"\")\r\n\t{\r\n\t\talert(msgObj.val());\r\n\t}\r\n\t\r\n\tif(woStatus==\"N\" && jcStatus==\"N\")\r\n\t{\r\n\t\tif(wgp == '')\r\n\t\t{\r\n\t\t\t$(\"#btnStpPrint\").removeAttr('disabled');\r\n\t\t\t$(\"#btnMatPrint\").removeAttr('disabled');\r\n\t\t\t$(\"#save\").removeAttr('disabled');\r\n\t\t\t$(\"#save2\").removeAttr('disabled');\r\n\t\t\t\r\n\t\t}\r\n\t}\r\n\t\r\n\t//是Fedex飞机 且为QC角色 提供修改否则 只能查看\r\n\t\r\n\tfedexRoleQcShow()\r\n/* \t// 如果结构修理选择了\"N\"\r\n\t if(im==\"N\") {\r\n\t\tchangeRep();\r\n\t}  */\r\n\t\r\n\t// 去前后空格\r\n\t$(\"input[type='text']\").blur(function(){\r\n\t\t$(this).val($.trim($(this).val()));\r\n\t});\r\n\t// 涉及可更换结构件修改时更改可更换结构件\r\n\t$(\"#rplStrPart\").change(function(){ \r\n\t\t$(\"#rsc\").val($(this).val());\r\n\t});\r\n});\r\n\r\nfunction fedexRoleQcShow(){\r\n\tvar wgp=\"3_CABIN_TPG\";\r\n\tvar strJcStatus=\"N\";\r\n\tvar qcFiBy=\"\";\r\n\t\r\n\tif( !(wgp=='QC' && strJcStatus!='N' && qcFiBy.length>0) ){\r\n\t\t$(\"#fedexCheck\").find('input[type=checkbox]').attr('disabled', true);\r\n\t\t$(\"#sdrTrNo\").attr('disabled', true);\r\n\t}\r\n}\r\n\r\n// Add by 700683 超规范方案接收日期及超期原因记录功能 2018-07-09 start\r\nfunction checkEngRsnValue() {\r\n\tvar engRsn = $(\"input[name='engRsn']\").val(); \t\t\t\t\t\t\t\t\t// 超要求期限原因\r\n\tvar slnReqDate = $(\"input[name='slnReqDate']\").val(); \t\t\t\t\t\t\t// 方案要求期限\r\n\tvar outOfManual = $(\"#outOfManual\").val(); \t\t\t\t\t\t\t\t\t\t// 超规范修理\r\n\tvar today = new Date().Format(\"yyyy-MM-dd\");\t\t\t\t\t\t\t\t\t// 当前日期\r\n\tvar engSlnRcpDate = $(\"#engSlnRcpDate\").val();\t\t\t\t\t\t\t\t\t// 超规范方案接收日期 接收日期\r\n\tvar editor = \"DMDOR,ENG_AV,ENG_CABIN,ENG_ENG,ENG_FTM,ENG_SD,ENG_STR,ENG_SP\"; \t// 编写人身份集\r\n\t\r\n\tif ($.trim(engRsn) == \"\" && $.trim(slnReqDate) != \"\" && $.trim(outOfManual) == \"Y\" && comparedate(today, $.trim(slnReqDate))\r\n\t\t\t&& ($.trim(engSlnRcpDate) == \"\" || comparedate($.trim(engSlnRcpDate), $.trim(slnReqDate)))\r\n\t\t\t&& editor.indexOf(wgp) != -1) {\r\n\t\talert(\"超要求期限原因不可空！\");\r\n\t\t$(\"input[name='engRsn']\").select();\r\n\t\treturn false;\r\n\t} else {\r\n\t\treturn true;\r\n\t}\r\n}\r\n\r\n//比较两个日期\r\nfunction comparedate(startDate, endDate) {\r\n\tvar sd = new Date(startDate.replace(/-/g, \"\\/\"));\r\n\tvar ed = new Date(endDate.replace(/-/g, \"\\/\"));\r\n\treturn sd > ed;\r\n}\r\n// Add by 700683 超规范方案接收日期及超期原因记录功能 2018-07-09 end\r\n\r\n// 复制模板/工作包工卡信息到工卡上\r\nvar jcInfoObj;\r\nfunction jcInfo(op) {\r\n\tif(isChange) {\r\n\t\talert(\"有数据修改过，请保存后再导入步骤!\");\r\n\t\treturn;\r\n\t}\r\n\tvar url = \"\";\r\n\tvar width = (screen.width-180);\r\n\tvar height = \"500\";\r\n\tvar obj = new Object();\r\n\tobj.maxStep = \"1\";\r\n\tobj.nrcJobCardRid = jcRid;\r\n\tobj.workGroup = wgp;\r\n\tobj.acType = \"A380\";\r\n\tobj.flnum = \"A6-EUD\";\r\n\tobj.stepCtrl = \"Y\";\r\n\tobj.flagHM = \"true\";\t\t\t\t\t// 判断是否大修部门\r\n\tobj.flagRob = \"false\";\t\t\t\t\t// 判断是否串件卡\r\n\tobj.jcMode = \"E\";\t\t\t\t\t// 中英文模式\r\n\t\r\n\tif(op == \"3\"){\r\n\t\tobj.workOrder = \"\";\r\n\t}\r\n\t// 模板导入\r\n\tif(op == \"1\") {\r\n\t\turl = \"./copy/nrcTpl.jsp\";\r\n\t}\r\n\t// 工作包工卡导入\r\n\telse if(op == \"2\" || op == \"3\") {\r\n\t\turl = \"./copy/nrc.jsp\";\r\n\t}\r\n\t\r\n\t//var value = window.showModalDialog(url,obj,\"dialogWidth:\" + width + \" ;dialogHeight:\" + height + \";help:no;status:no;resizable:yes;location=no\");\r\n\t//document.form.action = \"alterJCSTPNRC.jsp?wgp=\"+wgp+\"&jcrid=\"+jcRid+\"&woRid=\"+woRid+\"&jcType=\"+jcType;\r\n\t//document.form.submit();\r\n\t//document.form.action = \"\";\r\n\tjcInfoObj = obj;\r\n\tvar top = (window.screen.height - 30 - height) / 2; //获取窗口的垂直位置\r\n\tvar left = (window.screen.width - 10 - width) / 2; //获取窗口的水平位置\r\n\tvar win = __CP_FUNC_open__(window,url, \"copy\", 'height=' + height + ',width=' + width + ',top=' + top + ',left=' + left \r\n\t\t\t+ ',toolbar=no,menubar=no,scrollbars=yes,location=no,status=no,alwaysRaised=yes,directories=no,personalbar=no');\r\n\tvar loop = __CP_FUNC_SET_INTERVAL__(self,function(){\r\n\t\tif(win.closed){\r\n\t\t\tclearInterval(loop);\r\n\t\t\t$(\"input[type='button']\").attr(\"disabled\",true);\r\n\t\t\t__CP_SET_URL_ATT__(document.form,'action', \"alterJCSTPNRC.jsp?wgp=\"+wgp+\"&jcrid=\"+jcRid+\"&woRid=\"+woRid+\"&jcType=\"+jcType);\r\n\t\t\tdocument.form.submit();\r\n\t\t}\r\n\t}, 1);\r\n\t\r\n}\r\n\r\n// 读取模板/工作包工卡信息到步骤上\r\nvar setStepInfoObj;\r\nfunction stepInfo(obj,op)\r\n{\r\n\tvar width = (screen.width-110);\r\n\tvar height = \"500\";\r\n\t\r\n\tvar paramObj = new Object();\r\n\tparamObj.workGroup = wgp;\r\n\tparamObj.acType = \"A380\";\r\n\tparamObj.workOrder = \"\";\r\n\tparamObj.jcMode = \"E\";\t\t\t\t\t// 中英文模式\r\n\t\r\n\t// 模板导入\r\n\tif(op == \"1\")\r\n\t{\r\n\t\turl = \"./copy/stepTpl.jsp\";\r\n\t}\r\n\t// 工作包工卡 或 上次追踪号导入\r\n\telse if(op == \"2\" || op == \"3\")\r\n\t{\r\n\t\turl = \"./copy/step.jsp\";\r\n\t}\r\n\t\r\n\t//var value = window.showModalDialog(url,paramObj,\"dialogWidth:\" + width + \";dialogHeight:\" + height + \";help:no;status:no;resizable:yes\");\r\n\tsetStepInfoObj = obj;\r\n\tjcInfoObj = paramObj;\r\n\tvar top = (window.screen.height - 30 - height) / 2; //获取窗口的垂直位置\r\n\tvar left = (window.screen.width - 10 - width) / 2; //获取窗口的水平位置\r\n\tvar win = __CP_FUNC_open__(window,url, \"copy\", 'height=' + height + ',width=' + width + ',top=' + top + ',left=' + left \r\n\t\t\t+ ',toolbar=no,menubar=no,scrollbars=aut,location=no,status=no,alwaysRaised=yes,directories=no,personalbar=no');\r\n}\r\n//其他窗口填充数据\r\nfunction setStepInfo(value){\r\n\t\r\n\t//console.log(value);\r\n\tif(value != null && value != \"\"){\r\n\t\tvar info = jQuery.parseJSON(value);\r\n\t\tvar innerTable = $(setStepInfoObj).parent().parent().parent().parent();\r\n\t\tvar firstTr = innerTable.parent().parent();\r\n\t\tvar secondTr = firstTr.next();\r\n\t\tvar thirdTr = secondTr.next();\r\n\r\n\t\t\r\n\t\t\r\n\t\tinnerTable.find(\"input[name='stepDesc']\").attr(\"value\",info.descCn);\r\n\t\tinnerTable.find(\"input[name='stepEnDesc']\").attr(\"value\",info.descEn);\r\n\t\titemDefault(secondTr.find(\"select[name='schedtrade']\"),info.trade);\r\n\t\titemDefault(secondTr.find(\"select[name='schedzone']\"),info.zone);\r\n\t\tsecondTr.find(\"input[name='remark']\").attr(\"value\",info.remark);\r\n\t\tsecondTr.find(\"input[name='schedlabor']\").attr(\"value\",info.labor);\r\n\t\tsecondTr.find(\"input[name='schedmh']\").attr(\"value\",info.mh);\r\n\t\tsecondTr.find(\"input[name='isupd']\").attr(\"value\",\"true\");\r\n\t\tsecondTr.find(\".summanhourTdClass\").html(info.labor * info.mh);\r\n\t\t\r\n\t\t// 进入燃油箱工作\r\n\t\tvar flagTank = thirdTr.find(\".flagTank\");\r\n\t\tflagTank.css('width', '45px');\r\n\t\tflagTank.attr(\"value\", (info.flagTank ? info.flagTank : 'N'));\r\n\t\tvar flagTankTd = flagTank.parent();\r\n\t\tif(0 == flagTankTd.find('span')){\r\n\t\t\tvar span = $('<span>').text('留意复核');\r\n\t\t\tspan.css('color', '#f30303');\r\n\t\t\tspan.css('margin-left', '5px');\r\n\t\t\tflagTankTd.append(span);\r\n\t\t}\r\n\t\tisChange = true;\r\n\t}\r\n}\r\n// 根据不同页数设置步骤\r\nfunction reportStep()\r\n{\r\n\tvar page = $(\"#reportPageId\");\r\n\tvar step = $(\"#stepNumberId\");\r\n\tvar pageValue = page.attr(\"value\");\r\n\t\r\n\tif(+pageValue == 1)\r\n\t{\r\n\t\titemDefault(step,\"1\");\r\n\t}\r\n\telse if(+pageValue == 2)\r\n\t{\r\n\t\titemDefault(step,\"6\");\r\n\t}\r\n\telse if(+pageValue == 3)\r\n\t{\r\n\t\titemDefault(step,\"14\");\r\n\t}\r\n}\r\n\r\n// 根据不同步骤设置第几页\r\nfunction reportPage()\r\n{\r\n\tvar page = $(\"#reportPageId\");\r\n\tvar step = $(\"#stepNumberId\");\r\n\tvar stepValue = step.attr(\"value\");\r\n\t\r\n\tif(stepValue == \"\")\r\n\t\treturn false;\r\n\t\r\n\tif(+stepValue > 5 && +stepValue < 14)\r\n\t{\r\n\t\titemDefault(page,\"2\");\r\n\t}\r\n\telse if(+stepValue > 13 && +stepValue < 22)\r\n\t{\r\n\t\titemDefault(page,\"3\");\r\n\t}\r\n\telse\r\n\t{\r\n\t\titemDefault(page,\"1\");\r\n\t}\r\n}\r\n// 显示结束步骤\r\nfunction showEndStep()\r\n{\r\n\tvar selTarget = document.getElementById(\"selID\");\r\n\tselTarget.Add(new Option(\"text\",\"value\"));\r\n\t\r\n\t//alert($(\"#stepEndNumberId\"));\r\n\tvar stepEndNum = $(\"#stepEndNumberId\");\r\n\t//alert(stepEndNum.length);\r\n\tstepEndNum.options.each(function(){\r\n\t\talert($(this).val());\r\n\t});\r\n}\r\n\r\n// 导出word\r\nfunction reportWord()\r\n{\r\n\t/*\r\n\tvar page = $(\"#reportPageId\");\r\n\tvar step = $(\"#stepNumberId\");\r\n\tvar stepValue = step.attr(\"value\");\r\n\t\r\n\tvar order = $(\"#reportOrderId\");\r\n\tvar acno = $(\"#reportAcnoId\");\r\n\t\r\n\tvar orderIsCheck = \"no\";\r\n\tvar acnoIsCheck = \"no\";\r\n\tvar jcIsCheck = \"no\";\r\n\t\r\n\tvar url;\r\n\t\r\n\tif(order.attr(\"checked\") == true)\r\n\t{\r\n\t\torderIsCheck = \"yes\";\r\n\t}\r\n\tif(acno.attr(\"checked\") == true)\r\n\t{\r\n\t\tacnoIsCheck = \"yes\";\r\n\t}\r\n\tif(jobcard.attr(\"checked\") == true)\r\n\t{\r\n\t\tjcIsCheck = \"yes\";\r\n\t}\r\n\t\r\n\turl = encodeURI(\"http://10.240.2.133:8082/dmdorWord/nrc/toWordForNRC.jsp?workorder=%=strWorkOrder%>\"\r\n\t\t\t\t+\"&jobcard=%=strJobCard%>&exportno=\"+page.attr(\"value\")\r\n\t\t\t\t+\"&count=%=stepCount%>&acno=\"+acnoIsCheck+\"&jobcarddesc=\"+jcIsCheck+\"&stepbegin=\"\r\n\t\t\t\t+step.attr(\"value\")+\"&order=\"+orderIsCheck);\r\n\t\r\n\tlocation.href = url;\r\n\t*/\r\n}\r\n\r\n// 步骤打印非例行卡\r\n//type = 1 为打印工卡步骤 ，2 为打印航材单，3 为打印FEDEX工时审核单\r\nfunction printNRC(isRead,type)\r\n{\r\n\tif(isChange) {\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn;\r\n\t}\r\n\t\r\n\tvar nrc_version = \"V3\";\t\t//\t工卡版本号\r\n\tvar engSign = $(\"#engSign\");\t\t\t\t\t//\t判断工程师\r\n\tvar authApp = $(\"#authApp\");\t\t\t\t\t//\t需要局方批准\r\n\tvar appRef = $(\"#appRef\");\t\t\t\t\t\t//\t局方批文号/CAAC批文号\r\n\tvar pageValue = 1;\t\t\t\t\t\t\t\t//\t第几页\r\n\tvar startStep = $(\"#stepNumberId\");\r\n\tvar startStepValue = startStep.attr(\"value\");\t//\t开始步骤\r\n\tvar endStep = $(\"#stepEndNumberId\");\r\n\tvar endStepValue = endStep.attr(\"value\");\t\t//\t结束步骤\r\n\tvar printer = $(\"#printerId\").attr(\"value\");\t//\t打印机\r\n\tvar rii = $(\"#riiId\");\t\t\t\t\t\t\t//\t必检\r\n\tvar jcSite = $(\"#jcSiteId\");\t\t\t\t\t//\t工作场所\r\n\tvar boothObj = $(\"#boothId\");\t\t\t\t\t//\t工卡站\r\n\tvar workOrder = \"120000587070\";\r\n\tvar jcwo = \"500007989096\";\r\n\tvar orderIsCheck = \"no\";\r\n\tvar acnoIsCheck = \"no\";\r\n\tvar jcIsCheck = \"no\";\r\n\tvar flag = \"false\";\r\n\tvar rsmsg = \"\";\r\n\tvar url;\r\n\tvar rid = \"13042134\";\r\n\tvar dateFlag = true;\r\n\t// ADD BY 700683 非卡打印功能的改进 2018-05-10 START\r\n\tvar flagEPrt = \"\";\r\n\tvar qcFiBy = \"\";\r\n\tvar wgp = \"3_CABIN_TPG\";\r\n\t// ADD BY 700683 非卡打印功能的改进 2018-05-10 END\r\n\t// Add by 700683 限制打印没有英文的非卡 2018-10-29 start\r\n\tvar strCheckLevel = \"3C\"; \t\t\t// 定检级别\r\n\tvar jcDescEn = $(\"input[name='jcendesc']\").val();\t// 工卡描述(英文)\r\n\t// Add by 700683 限制打印没有英文的非卡 2018-10-29 end\r\n\t// add by 700683 2019-02-03 start\r\n\tvar slnStatus = \"T\";\t\t\t\t// 方案状态\r\n\t// add by 700683 2019-02-03 end\r\n\tvar rplStrPart = $(\"#rplStrPart\");\t\t\t\t\t//\t涉及可更换结构件\r\n\tvar insp_date = '2026-01-14';\t\r\n\tvar ownerCode = $.trim($(\"#ownerCodeId\").val());//\t客户代码\r\n\tvar engCustomer = \"\"; //发动机客户 \r\n\tvar ownerCustomer = \"\";\r\n\tvar tailno = \"A6-EUD\"; //飞机号 \r\n\tvar planStartDate = $.trim($(\"#planStartDateId\").val());//计划时间\r\n\tvar a = planStartDate >=\"2019-12-10\";//false <\r\n\tvar b = insp_date>=\"2019-12-10\";//false <\r\n\tvar printType1 = \"\";\r\n\tvar printDate = '2026-01-13'>=\"2021-01-01\";\t// 打印约束的开始日期\r\n\tvar customerNo = $.trim($(\"#customerNoId\").val());\t\t\t\t// 客户指令号\r\n\tvar csnJcWorkOrder = $.trim($(\"#strCsnJcWorkOrderId\").val());\t// 工卡指令号\r\n\tvar stpCnt = \"1\";\r\n\tvar stpRiiCnt = \"1\";\r\n\t\r\n\t// 步骤打印\r\n\tif(type == \"1\") {\r\n\t\t// 2021年1月1日进厂的南航/重航非卡打印增加指令号不为空才能打印的约束\r\n\t\tif (printDate==true && (ownerCode==\"CSN\" || ownerCode==\"CKG\"|| ownerCode==\"CSG\"|| ownerCode==\"CSL\")) {\r\n\t\t\tif(customerNo!=\"\") {\r\n\t\t\t\tif(csnJcWorkOrder==\"\") {\r\n\t\t\t\t\talert(\"缺南航工卡指令号不允许打印！\");\r\n\t\t\t\t\treturn false;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t\tif ($.trim(jcDescEn) == \"\") {\r\n\t\t\tif(jcMode!=\"H\") {\r\n\t\t\t\talert(\"非卡英文描述未填写！\");\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t\tif (flagEPrt == \"Y\" && wgp != \"\") {\r\n\t\t\talert(\"电子签署工卡不允许打印！\");\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\t//检验字段\r\n\t\tif(startStepValue==\"\") {\r\n\t\t\talert(\"请选择开始步骤!\");\r\n\t\t\tstartStep.focus();\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\t//RII\r\n\t\t// update by 700683 RII功能验证修订 2018-11-12 start\r\n\t\t//if(rii.val()==\"\" && jcSite.val()!=\"LM\" && boothObj.val()!=\"A\" && boothObj.val()!=\"MOCC\")\r\n\t\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 start\r\n\t\t//if(rii.val()==\"\" && jcSite.val()!=\"LM\" && boothObj.val()!=\"A\" && boothObj.val()!=\"MOCC\" && strCheckLevel == \"2-LNEMNT\")\r\n\t\t// update by 700683 打印限制 2018-11-28 start\r\n\t\t//if(rii.val()==\"\" && boothObj.val()!=\"A\" && boothObj.val()!=\"MOCC\")\r\n\t\tif(rii.val()==\"\")\r\n\t\t// update by 700683 打印限制 2018-11-28 end\r\n\t\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 end\r\n\t\t// update by 700683 RII功能验证修订 2018-11-12 end\r\n\t\t{\r\n\t\t\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 start\r\n\t\t\t//alert(\"工卡RII不能为空，请联系检验员处理!\");\r\n\t\t\talert(\"请联系检验或兼职检验判断工卡RII属性！\");\r\n\t\t\t// update by 700683 航线工卡打印增加RII判断的限制 2018-11-15 end\r\n\t\t\trii.focus();\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\t//检查结构信息栏\r\n\t\tif(nrc_version.toUpperCase()!= \"V1\" && nrc_version.toUpperCase()!= \"V2\" && engSign.val()==\"\") {\r\n\t\t\tif(!confirm(\"结构信息栏没填写，确定打印?\")) {\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t\t// 检验打印步骤是否合法\r\n\t\tif(endStepValue==\"\") {\r\n\t\t\tif(!confirm(\"请选择结束步骤，不选默认到最后步骤!\\n确定到最后步骤?\")) {\r\n\t\t\t\tendStep.focus();\r\n\t\t\t\treturn false;\r\n\t\t\t}\r\n\t\t}\r\n\t\t// add by 700683 2019-02-03 start\r\n\t\t//if (strCheckLevel != \"2-LNEMNT\" && (slnStatus != \"Y\" || slnStatus != \"T\")) {\r\n\t\t//if (strCheckLevel != \"2-LNEMNT\" && slnStatus != \"Y\" && slnStatus != \"T\") {// 航线打印与定检的逻辑一致\r\n\t\tif (slnStatus != \"Y\" && slnStatus != \"T\") {\r\n\t\t\talert(\"请确认方案完成或交互之后方可打印！\");\r\n\t\t\treturn false;\r\n\t\t}\r\n\t\t// add by 700683 2019-02-03 end\r\n\t\t// add by 005245 2019-09-09 start\r\n\t\t/*非卡打印增加“涉及可更换结构件”值非空才允许打印的逻辑(暂时不上生产)\r\n\t\t// 涉及可更换结构件\r\n\t\tif(rplStrPart.val()==\"\"){\r\n\t\t\talert(\"请选择涉及可更换结构件！\");\r\n\t\t\trplStrPart.focus();\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t*/\r\n\t\tif (stpCnt*1 == 0) {\r\n\t\t\talert(\"工卡没有步骤信息，不允许打印！\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t// add by 005245 2019-09-09 end\r\n\t\t// 检验开始步骤与结束步骤是否符合重打要求\r\n\t\turl = \"../ajax/checkStpPrint.jsp?workorder=\"+workOrder+\"&jobcard=\"+jobcard\r\n\t\t\t+\"&txtStartStep=\"+startStepValue+\"&txtEndStep=\"+endStepValue+\"&rid=\"+rid+\"&flag41=\"+dateFlag;\r\n\t\t$.ajax({\r\n\t\t\ttype: \"POST\",\t\t\t\t\t// 请求方式\r\n\t\t\turl: url,\t\t\t\t\t\t// 请求地址\r\n\t\t\tjsonp: \"jsonpcallback\",\t\t\t// 回调函数名字\r\n\t\t\tasync: false,\t\t\t\t\t// 设置是否需要异步\r\n\t\t\tdataType: \"jsonp\",\t\t\t\t// 返回的数据格式\r\n\t\t\tsuccess: function(data)\t\t\t// 成功返回时，所调用的回调函数\t\r\n\t\t\t{\r\n\t\t\t\t$.each(data,function(key,value){\r\n\t\t\t\t\tif(key==\"flag\")\r\n\t\t\t\t\t\tflag = value;\r\n\t\t\t\t\tif(key==\"rsmsg\")\r\n\t\t\t\t\t\trsmsg = value;\t\t\t\t\t\t\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\t// 航材打印\r\n\telse if(type == \"2\") {\r\n\t\t// 检验是否满足打印要求\r\n\t\turl = \"../ajax/checkMatPrint.jsp?workorder=\"+workOrder+\"&jobcard=\"+jobcard;\r\n\t\t$.ajax({\r\n\t\t\ttype: \"POST\",\t\t\t\t\t// 请求方式\r\n\t\t\turl: url,\t\t\t\t\t\t// 请求地址\r\n\t\t\tjsonp: \"jsonpcallback\",\t\t\t// 回调函数名字\r\n\t\t\tasync: false,\t\t\t\t\t// 设置是否需要异步\r\n\t\t\tdataType: \"jsonp\",\t\t\t\t// 返回的数据格式\r\n\t\t\tsuccess: function(data)\t\t\t// 成功返回时，所调用的回调函数\t\r\n\t\t\t{\r\n\t\t\t\t$.each(data,function(key,value){\r\n\t\t\t\t\tif(key==\"flag\")\r\n\t\t\t\t\t\tflag = value;\r\n\t\t\t\t\tif(key==\"rsmsg\")\r\n\t\t\t\t\t\trsmsg = value;\t\t\t\t\t\t\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\t// FEDEX工时审核单\r\n\telse if(type == \"3\") {\r\n\t\t// 检验该卡工时是否超限\r\n\t\turl = \"../ajax/checkOverAlarmMh.jsp?workorder=\"+workOrder+\"&jcwo=\"+jcwo;\r\n\t\t$.ajax({\r\n\t\t\ttype: \"POST\",\t\t\t\t\t// 请求方式\r\n\t\t\turl: url,\t\t\t\t\t\t// 请求地址\r\n\t\t\tjsonp: \"jsonpcallback\",\t\t\t// 回调函数名字\r\n\t\t\tasync: false,\t\t\t\t\t// 设置是否需要异步\r\n\t\t\tdataType: \"jsonp\",\t\t\t\t// 返回的数据格式\r\n\t\t\tsuccess: function(data)\t\t\t// 成功返回时，所调用的回调函数\t\r\n\t\t\t{\r\n\t\t\t\t$.each(data,function(key,value){\r\n\t\t\t\t\tif(key==\"flag\")\r\n\t\t\t\t\t\tflag = value;\r\n\t\t\t\t\tif(key==\"rsmsg\")\r\n\t\t\t\t\t\trsmsg = value;\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\tif(flag==\"false\") {\r\n\t\talert(rsmsg);\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tif(printer==\"\") {\r\n\t\talert(\"请选择打印机!\");\r\n\t\treturn false;\r\n\t}\r\n\tif(!confirm(\"打印到：\"+printer+\"?\")) {\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\tif(tailno == \"GAM-ENG\"){\r\n\t\townerCustomer = engCustomer;\r\n\t}else{\r\n\t\townerCustomer = ownerCode;\r\n\t}\r\n\t\r\n\t// 打印类型\r\n\tif(ownerCustomer==\"CSN\" || ownerCustomer==\"CKG\" || ownerCustomer==\"CSG\" || ownerCustomer==\"CSL\") {\r\n\t\tif((strCheckLevel != \"2-LNEMNT\" && a==true) || (strCheckLevel == \"2-LNEMNT\" && b==true)) {\t\r\n\t\t\tprintType1 = \"C2\";\r\n\t\t}\r\n\t}\r\n\t\r\n\tif(type == \"1\")\t{// type=1 步骤打印\r\n\t\turl = \"rprintJCNRC.jsp?action=rpintStep&txtStartStep=\"\r\n\t\t+startStepValue+\"&txtEndStep=\"+endStepValue+\"&jcwo=\"+jcwo+\"&printType1=\"+printType1;\r\n\t} else if(type == \"2\") {// type=2 航材打印\r\n\t\turl = \"rprintJCNRC.jsp?action=printMATList&jcwo=\"+jcwo;\r\n\t} else if(type == \"3\") {// type=3 FEDEX工时审核单\r\n\t\turl = \"rprintJCNRC.jsp?action=printFedexAlarmMh&jcwo=\"+jcwo;\r\n\t} else {\r\n\t\talert(\"打印类型不存在，请联系管理员!\");\r\n\t\treturn false;\r\n\t}\r\n\t\r\n\t$(\":button\").attr(\"disabled\",\"disabled\");\r\n\t__CP_SET_URL_ATT__(document.form,'action', url);\r\n\tdocument.form.submit();\r\n//}\r\n}\r\n// Fedex非卡打印\r\nfunction printFedexNrc()\r\n{\r\n\tif(isChange)\r\n\t{\r\n\t\tvar save = window.confirm(\"部分数据被修改过，请保存后操作!\");\r\n\t\treturn;\r\n\t}\r\n\t\r\n\tvar printerObj = $(\"#printerId\");\t\t//\t打印机\r\n\tvar riiObj = $(\"#riiId\");\t\t\t\t//\t必检\r\n\tvar workOrder = \"120000587070\";\t//\t销售指令号\r\n\tvar jcwo = \"500007989096\";\t\t//\t工卡指令号\r\n\tvar startStepObj = $(\"#stepNumberId\");\t//\t开始步骤对象\r\n\tvar startStep = startStepObj.val();\t\t//\t开始步骤\r\n\tvar fedexRecActionObj = $(\"#fedexRecActionId\");\t// Fedex工卡推荐措施\r\n\tvar jcSite = \"HG\";\t\t\t//\t工作地点(定检HG/航线LM)\r\n\tvar planStartDate = $.trim($(\"#planStartDateId\").val());//计划时间\r\n\tvar flag = \"\";\r\n\tvar rsmsg = \"\";\r\n\tvar url;\r\n\t// update by 700683 RII功能验证修订 2018-11-12 start\r\n\tvar strCheckLevel = \"3C\"; \t\t\t// 定检级别\r\n\t// update by 700683 RII功能验证修订 2018-11-12 end\r\n\t/*\r\n\tif(jcSite==\"LM\")\r\n\t{\r\n\t\talert(\"航线FEDEX非例卡暂不提供打印!\");\r\n\t\treturn false;\r\n\t}\r\n\t*/\r\n\tif(startStepObj.val()==\"\")\r\n\t{\r\n\t\talert(\"请选择打印步骤!\");\r\n\t\tstartStepObj.focus();\r\n\t\t