            "text": "\n\n\n\nvar ___fnbTitleBG\t= \"#FDC778\";  \t\t\nvar ___fnbButtonsBG\t= \"#c0c0c0\";  \t\nvar ___fnbTitleStr  = \"CP Mobile\";  \nvar ___fnbTitleFG\t= \"#000000\";  \t\t\nvar ___fnbWinWidth\t= 240;\nvar ___fnbSSOHeight\t= 200;\nvar ___fntSSOScrollSpeed = 10;\nvar ___fnbSSOShowHint = false;\nvar ___fnbSSOEffectiveHeight = 0;\n\nvar ___fnbTries\t\t\t= 6;\nvar ___fnbDragMode\t\t= false;\nvar ___fnbLastMouseX\t= 0;\nvar ___fnbLastMouseY\t= 0;\nvar ___fnbRightMargine  = 20;\nvar ___fnbBottomMargine = 5;\nvar ___fnbHorizontalMargin = 1;\nvar ___fnbVerticalMargin = 1;\nvar ___fnbLastScrollX\t= 0;\nvar ___fnbLastScrollY\t= 0;\nvar ___fnbDropDownState = true;\nvar ___fnbResizeCounter = false;\nvar ___fnbMainDivName\t= \"___fnbMainDiv\";\nvar ___fnbSSODivId\t\t= \"___fnbSSODiv\";\nvar ___fnbSSOUserName\t= \"___fnbSSOUserName\";\nvar ___fnbSSOAppName\t= \"___fnbSSOAppName\";\nvar ___fnbSSOAdminHint\t= \"___fnbSSOAdminHint\";\nvar ___fnbSSOAdminHintLink\t= \"___fnbSSOAdminHintLink\";\nvar ___fnbSSOButtons\t= \"___fnbSSOButtons\";\nvar ___fnbSSOAsk\t\t= \"___fnbSSOAsk\";\nvar\t___fnbSSODisplayAsk = false;\n\n\nvar ___fnbSSONeedToShow = false;\nvar ___fnbWasDrawn \t\t= false;\nvar ___SSOuserName \t\t= \"\";\nvar ___SSOappName \t\t= \"\";\nvar ___SSOadminHint \t= \"\";\nvar ___SSOnotifyOnly \t= false;\nvar ___SSOcallBack \t\t= null;\n\n\nvar ___fnbOldUnload\t\t= null;\nvar ___cookieExpireDays = 180;\nvar ___cp_cvpn_prefix_portal = window.___cp_cvpn_prefix_portal || \"\";\t\t\nvar ___homeURL\t\t\t= ___cp_cvpn_prefix_portal + \"/\";\nvar ___logOutURL\t\t= ___cp_cvpn_prefix_portal + \"/Portal/SignOut\";\nvar ___bookmarkURL\t= ___cp_cvpn_prefix_portal + \"/Portal/AddToFavorite\";\nvar ___SSOHelpURL\t= ___cp_cvpn_prefix_portal + \"/Portal/SSO/Help\";\nvar ___tableStyle\t\t= \"direction: ltr; padding: 0xp; margin: 0px; \" +\n\t\t\t\t\t\t  \"font-family: Tahoma; font-size: 10px; \" +\n\t\t\t\t\t\t  \"text-color: \" + ___fnbTitleFG + \"; \" +\n\t\t\t\t\t\t  \"vertical