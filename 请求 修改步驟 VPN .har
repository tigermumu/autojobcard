            "text": "//the focus on the line Highlight\r\nfunction OnOverItem()\r\n{\r\n\tvar oTR = event.srcElement;\r\n\twhile ( oTR.tagName != \"TR\" )\r\n\t{\r\n\t\toTR = oTR.parentElement;\r\n\t}\r\n\toTR.style.backgroundColor = \"#BDD0FD\";\r\n\treturn;\r\n}\r\n\r\n//the focus on the line not Highlight\r\nfunction OnOutItem()\r\n{\r\n\tvar oTR = event.srcElement;\r\n\twhile ( oTR.tagName != \"TR\" )\r\n\t{\r\n\t\toTR = oTR.parentElement;\r\n\t}\r\n\toTR.style.backgroundColor = \"\";\r\n\treturn;\r\n}\r\n\r\n//check is number\r\nfunction isNumber(s)\r\n{\r\n\tvar regu=\"^[0-9]+$\";\r\n\tvar re=new RegExp(regu);\r\n\tif (s.search(re)!=-1)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\telse\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n}\r\n\r\n//check is number 2 decimal\r\nfunction checkText(obj)\r\n{\r\n\tvar text = obj;\r\n\tvar textValue = text.value.toString().Trim();\r\n\tif(textValue==\"\")\r\n\t\treturn true;\r\n\tvar re2 = new RegExp(\"^(([0-9]+$|^[0-9]+\\.{1}[0-9]{1,2})|(-(([0-9]+\\.[0-9]*[1-9][0-9]*)|([0-9]*[1-9][0-9]*\\.[0-9]+)|([0-9]*[1-9][0-9]*))))$\");\r\n\tif(!re2.test(textValue))\r\n\t{\r\n\t\talert(\"Please enter valid values!\");\r\n\t\tobj.select();\r\n\t\treturn true;\r\n\t}\r\n\t\r\n\treturn false;\r\n}\r\n\r\n//check is number 2 decimal\r\nfunction checkText2(s)\r\n{\r\n\tif(s==\"\")\r\n\t\treturn true;\r\n\tvar re2 = new RegExp(\"^(([0-9]+$|^[0-9]+\\.{1}[0-9]{1,2})|(-(([0-9]+\\.[0-9]*[1-9][0-9]*)|([0-9]*[1-9][0-9]*\\.[0-9]+)|([0-9]*[1-9][0-9]*))))$\");\r\n\tif(!re2.test(s))\r\n\t{\r\n\t\talert(\"Please enter valid values!\");\r\n\t\treturn true;\r\n\t}\r\n\t\r\n\treturn false;\r\n}\r\n\r\n//trim place\r\nString.prototype.Trim = function()     \r\n{     \r\n\treturn this.replace(/(^\\s*)|(\\s*$)/g, \"\");     \r\n}\r\n\r\n//enable button 页面多个input会很慢\r\nfunction setButton()\r\n{\r\n\tvar coll = document.getElementsByTagName(\"input\");\r\n\t\r\n\tif (coll!=null) \r\n\t{\r\n\t\tfor (i=0; i<coll.length; i++)\r\n\t\t{\r\n\t\t\tif(coll[i].type==\"button\" || coll[i].type==\"submit\" || coll[i].type==\"reset\")\r\n\t\t\t{\r\n\t\t\t\tcoll[i].disabled = !(coll[i].disabled);\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n\r\n//check checkbox\r\nfunction checkItem(name)\r\n{\t\t\r\n\tvar rs = document.getElementsByName(name);\r\n\t\t\r\n\tvar flag = false; \r\n\t\t\r\n\tfor (var i=0; i <rs.length; i++) \r\n\t{ \r\n\t\tif (rs[i].checked == true) \r\n\t\t{ \r\n\t\t\tflag = true; \r\n\t\t\tbreak; \r\n\t\t}\r\n\t}\r\n\t\r\n\tif (!flag)\r\n    {\r\n    \treturn false;\r\n    }\r\n    \r\n    return true;\r\n}\r\n\r\n//check date\r\nfunction checkDateFormat(value)\r\n{\r\n    \tif(value=='')\r\n    \t{\r\n  \t\treturn true;\r\n    \t}\r\n\tif(value.length!=10)\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n\tvar year=value.substring(0,4);\r\n\tif(year>\"2100\"||year<\"1900\")\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n\r\n \tvar month=value.substring(5,7);\r\n \t{\r\n\t\tif(month>\"12\"||month<\"01\")return false;\r\n\t}\r\n\r\n\tvar day=value.substring(8,10);\r\n\tif(day>\"31\"||day<\"01\")\r\n\t{\r\n\t\treturn false;\r\n\t}\r\n\treturn true; \r\n}\r\n\r\n//check all checkbox\r\nfunction checkAll(obj,cbName)\r\n{\r\n\tvar bl = obj.checked;\r\n\tvar checkbox = document.getElementsByName(cbName);\r\n\t\r\n\tfor(var i=0;i<checkbox.length;i++)\r\n\t{\r\n\t\tcheckbox[i].checked = bl;\r\n\t}\r\n}\r\n\r\n\r\n// 对Date的扩展，将 Date 转化为指定格式的String    \r\n// 月(M)、日(d)、小时(h)、分(m)、秒(s)、季度(q) 可以用 1-2 个占位符，    \r\n// 年(y)可以用 1-4 个占位符，毫秒(S)只能用 1 个占位符(是 1-3 位的数字)    \r\n// 例子：    \r\n// (new Date()).Format(\"yyyy-MM-dd hh:mm:ss.S\") ==> 2006-07-02 08:09:04.423    \r\n// (new Date()).Format(\"yyyy-M-d h:m:s.S\")      ==> 2006-7-2 8:9:4.18    \r\nDate.prototype.Format = function(fmt)   \r\n{\r\n  var o = {\r\n    \"M+\" : this.getMonth()+1,                 //月份    \r\n    \"d+\" : this.getDate(),                    //日    \r\n    \"h+\" : this.getHours(),                   //小时    \r\n    \"m+\" : this.getMinutes(),                 //分    \r\n    \"s+\" : this.getSeconds(),                 //秒    \r\n    \"q+\" : Math.floor((this.getMonth()+3)/3), //季度    \r\n    \"S\"  : this.getMilliseconds()             //毫秒    \r\n  };   \r\n  if(/(y+)/.test(fmt))   \r\n    fmt=fmt.replace(RegExp.$1, (this.getFullYear()+\"\").substr(4 - RegExp.$1.length));   \r\n  for(var k in o)   \r\n    if(new RegExp(\"(\"+ k +\")\").test(fmt))   \r\n  fmt = fmt.replace(RegExp.$1, (RegExp.$1.length==1) ? (o[k]) : ((\"00\"+ o[k]).substr((\"\"+ o[k]).length)));   \r\n  return fmt;   \r\n}\r\n\r\n// <br/>转\\r\\n\r\nfunction setValueAddBR(str)\r\n{\r\n\treturn str.replace(/\\<br\\/\\>/g,\"\\r\\n\");\r\n}\r\n\r\n// DateDiff\r\nfunction dateDiff(s1,s2)\r\n{\r\n\tvar date1 = new Date(Date.parse(s1.replace(/-/g,\"/\")));\r\n\tvar date2 = new Date(Date.parse(s2.replace(/-/g,\"/\")));\r\n\tvar diff = date2.getTime()-date1.getTime();\r\n\treturn diff/86400000;\r\n}\r\n\r\n// 这个函数用来把字符串转换为日期格式\r\nfunction parseDate(str)\r\n{\r\n\treturn new Date(Date.parse(str.replace(/-/g,\"/\")));\r\n}\r\n//判断字符串以什么字符(串)开头  Wallace on2015-08-18\r\nString.prototype.startWith=function(str){\r\n    var reg=new RegExp(\"^\"+str);\r\n    return reg.test(this);\r\n}\r\n//判断字符串以什么字符(串)结尾  Wallace on2015-08-18\r\nString.prototype.endWith=function(str){\r\n    var reg=new RegExp(str+\"$\");\r\n    return reg.test(this);\r\n}\r\n\r\n//计算字符串长度(英文占1个字符，中文汉字占2个字符) Wallace add on 2017-08-21\r\nfunction getStrGbLen(str){\r\n    var len = 0;\r\n    for (var i=0; i<str.length; i++) { \r\n\t     var c = str.charCodeAt(i); \r\n\t     //单字节加1 \r\n\t     if ((c >= 0x0001 && c <= 0x007e) || (0xff60<=c && c<=0xff9f)) { \r\n\t       len++; \r\n\t     }else { \r\n\t       len+=2;   //双字节加2 \r\n\t     } \r\n    } \r\n    return len;\r\n}\r\n\r\n/**\r\n * 方法作用：计算字符串长度(英文占1个字节，中文汉字占2个字节)\r\n * 调用示例：if (getStrLength($(\"#userId\"), 20, \"用户ID\")) {return false;}\r\n *\r\n * @param str\t标签对象\r\n * @param length\t长度最大值\r\n * @param msg\t提示信息\r\n * @returns {Boolean}\ttrue：字符长度超过最大值   false：字符长度没有超过最大值\r\n */\r\nfunction getStrLength(str, length, msg) {\r\n\tvar len = 0;\r\n\tvar status = false;\r\n\tvar strVal=$.trim($(str).val());\r\n\tfor (var i = 0; i < strVal.length; i++) {\r\n\t\tvar c = strVal.charCodeAt(i);\r\n\t\t//单字节加1\r\n\t\tif ((c >= 0x0001 && c <= 0x007e) || (0xff60 <= c && c <= 0xff9f)) {\r\n\t\t\tlen++;\r\n\t\t} else {\r\n\t\t\tlen += 2; //双字节加2\r\n\t\t}\r\n\t}\r\n\tif (len > length) {\r\n\t\talert(msg + \"长度不能超过\" + length + \"字节!\");\r\n\t\tstatus = true;\r\n\t\tstr.focus();//定位焦点\r\n\t}\r\n\treturn status;\r\n}\r\n\r\n/* \r\n用途：检查输入对象的值是否符合E-Mail格式 \r\n输入：str 输入的字符串 \r\n返回：如果通过验证返回true,否则返回false \r\nadd by 700718 20180910\r\n*/ \r\nfunction isEmail(str) { \r\n\tvar myReg = /^([A-Za-z0-9_\\-\\.])+\\@([A-Za-z0-9_\\-\\.])+\\.([A-Za-z]{2,4})$/;\r\n\tif (myReg.test(str)) return true; \r\n\treturn false; \r\n}\r\n\r\n/* 比较日期的大小（前后）\r\n * 参数date为日期类型(Date)\r\n * 返回值为1 表示date在该日期之后\r\n * 返回值为-1 表示date在该日期之前\r\n * 返回值为0 表示date与该日期相同\r\n * Author 700683\r\n * CreateDate 2018-11-20\r\n */\r\nDate.prototype.compare = function(date) {\r\n\tvar val1 = date.getTime();\r\n\tvar val2 = this.getTime();\r\n\t\r\n\tif (val1 > val2) {\r\n\t\treturn 1;\r\n\t} else if (val1 < val2) {\r\n\t\treturn -1;\r\n\t} else {\r\n\t\treturn 0;\r\n\t}\r\n}\r\n\r\n//检验时间类型(yyyy-MM-dd 或者yyyy/MM/dd)---精确判断(例如2月30号返回false),\r\n//空值或者正确返回true,错误返回false ADD 2019-06-25 Ryan\r\nfunction checkDate(date){\r\n\tif(\"\"==date){\r\n\t\treturn true;\r\n\t}\r\n\treturn new Date(date).getDate()==date.substring(date.length-2);\r\n}"
          },
