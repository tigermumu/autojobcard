# 环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/aircraft_workcard

# Redis配置
REDIS_URL=redis://localhost:6379

# Qwen API配置
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Gemini API配置
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# 默认大模型
DEFAULT_LLM_MODEL=Qwen

# 工卡导入配置
WORKCARD_IMPORT_BASE_URL=http://10.240.2.131:9080
WORKCARD_IMPORT_VERIFY_SSL=false
# WORKCARD_IMPORT_COOKIES=selected_realm=ssl_vpn; ___fnbDropDownState=1; ...
WORKCARD_IMPORT_PRINTER=\\lx-ps01\\Prt2Q09L非例卡(机上客舱工艺组)
WORKCARD_IMPORT_OUTPUT_DIR=storage/import_logs
WORKCARD_IMPORT_SAVE_HTML=true

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:8000"]

# 相似度阈值
SIMILARITY_THRESHOLD=75.0

# 算法权重配置
ALGORITHM_WEIGHTS={"system": 0.3, "component": 0.3, "description": 0.4}
